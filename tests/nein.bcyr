# --- validate ---

fn bench_validate_identifier_short() { validate_identifier("eth0"); return 0; }
fn bench_validate_identifier_long() { validate_identifier("my_really_long_table_name_for_container_network"); return 0; }
fn bench_validate_addr_ipv4() { validate_addr("192.168.1.100"); return 0; }
fn bench_validate_addr_cidr() { validate_addr("10.0.0.0/8"); return 0; }
fn bench_validate_addr_ipv6() { validate_addr("fe80::1"); return 0; }
fn bench_validate_iface() { validate_iface("br-container"); return 0; }
fn bench_validate_comment() { validate_comment("container port mapping 8080 to internal 80"); return 0; }
fn bench_validate_ct_state() { validate_ct_state("established"); return 0; }
fn bench_validate_family() { validate_family("inet"); return 0; }

# --- rule render ---

fn bench_rule_render_simple() {
    var r = allow_tcp(443);
    rule_render(r);
    return 0;
}

fn bench_rule_render_service() {
    var r = allow_service("192.168.1.0/24", PROTO_TCP, 8090);
    rule_set_comment(r, "bench service rule");
    rule_render(r);
    return 0;
}

fn bench_rule_render_complex() {
    var r = rule_new(verdict_accept());
    rule_add_match(r, match_source_addr("10.0.0.0/8"));
    rule_add_match(r, match_protocol(PROTO_TCP));
    rule_add_match(r, match_dport(443));
    rule_add_match(r, match_iif("eth0"));
    rule_add_match(r, match_ct_state("established, related"));
    rule_add_match(r, match_limit(100, RATE_SECOND, 200));
    rule_set_comment(r, "complex rule bench");
    rule_render(r);
    return 0;
}

# --- rule validate ---

fn bench_rule_validate_simple() {
    var r = allow_tcp(443);
    rule_validate(r);
    return 0;
}

fn bench_rule_validate_complex() {
    var r = rule_new(verdict_accept());
    rule_add_match(r, match_source_addr("10.0.0.0/8"));
    rule_add_match(r, match_protocol(PROTO_TCP));
    rule_add_match(r, match_dport(443));
    rule_add_match(r, match_iif("eth0"));
    rule_set_comment(r, "complex rule bench");
    rule_validate(r);
    return 0;
}

# --- nein_err / nein_ok ---

fn bench_nein_err() { nein_err(ERR_INVALID_RULE); return 0; }
fn bench_nein_ok() { nein_ok(); return 0; }

fn bench_table_render() {
    var t = table_new("filter", FAMILY_INET);
    var c = chain_base("input", CHAIN_FILTER, HOOK_INPUT, 0, POLICY_DROP);
    chain_add_rule(c, allow_established());
    chain_add_rule(c, allow_tcp(22));
    chain_add_rule(c, allow_tcp(443));
    table_add_chain(t, c);
    var s = nft_set_new("blocklist", SET_IPV4_ADDR);
    nft_set_add_element(s, "10.0.0.1");
    table_add_set(t, s);
    table_render(t);
    return 0;
}

fn bench_chain_render() {
    var c = chain_base("input", CHAIN_FILTER, HOOK_INPUT, 0, POLICY_DROP);
    chain_add_rule(c, allow_tcp(22));
    chain_render(c);
    return 0;
}

fn bench_nat_dnat_render() {
    var n = port_forward(8080, "172.17.0.2", 80);
    nat_render(n);
    return 0;
}

fn bench_nat_masquerade_render() {
    var n = container_masquerade("172.17.0.0/16", "eth0");
    nat_render(n);
    return 0;
}

fn bench_nat_validate() {
    var n = port_forward(8080, "172.17.0.2", 80);
    nat_validate(n);
    return 0;
}

fn bench_basic_host_firewall() {
    var fw = basic_host_firewall();
    firewall_render(fw);
    return 0;
}

fn bench_container_bridge() {
    var fw = container_bridge("br0", "172.17.0.0/16", "eth0");
    firewall_render(fw);
    return 0;
}

fn bench_firewall_validate() {
    var fw = basic_host_firewall();
    firewall_validate(fw);
    return 0;
}

fn bench_policy_to_rules() {
    var np = agent_to_agent("p", "10.0.0.1", "10.0.0.2", PROTO_TCP, 8090);
    policy_to_rules(np);
    return 0;
}

fn bench_geoip_render() {
    var bl = geoip_new();
    var c = vec_new();
    vec_push(c, "1.0.0.0/8");
    vec_push(c, "2.0.0.0/8");
    geoip_block_country(bl, country_block_v4("CN", c));
    firewall_render(geoip_to_firewall(bl));
    return 0;
}

fn bench_mesh_render() {
    var m = mesh_envoy();
    firewall_render(mesh_to_firewall(m));
    return 0;
}

fn bench_engine_10_agents_render() {
    var e = policy_engine_new();
    var i = 0;
    while (i < 10) {
        var sb = str_builder_new();
        str_builder_add_cstr(sb, "agent_");
        str_builder_add_int(sb, i);
        var s = str_builder_build(sb);
        var id = alloc(str_len(s) + 1);
        memcpy(id, str_data(s), str_len(s));
        store8(id + str_len(s), 0);

        var addr_sb = str_builder_new();
        str_builder_add_cstr(addr_sb, "10.100.");
        str_builder_add_int(addr_sb, i);
        str_builder_add_cstr(addr_sb, ".1");
        var as = str_builder_build(addr_sb);
        var addr = alloc(str_len(as) + 1);
        memcpy(addr, str_data(as), str_len(as));
        store8(addr + str_len(as), 0);

        var p = agent_policy_new(id, addr);
        ap_allow_inbound(p, ps_tcp(80));
        ap_allow_inbound(p, ps_tcp(443));
        ap_allow_outbound(p, ps_udp(53));
        pe_add_agent(e, p);
        i = i + 1;
    }
    firewall_render(pe_to_firewall(e));
    return 0;
}

fn bench_netns_render() {
    var nsf = namespace_firewall_new("bench-agent");
    nsf_allow_inbound(nsf, ps_tcp(8080));
    nsf_allow_outbound(nsf, ps_tcp(443));
    nsf_allow_outbound(nsf, ps_udp(53));
    nsf_allow_outbound_host(nsf, "10.0.0.0/8");
    firewall_render(nsf_build(nsf));
    return 0;
}

fn bench_bridge_render() {
    var bf = bridge_firewall_new(bridge_config_new("br0", "172.17.0.0/16", "eth0"));
    bf_add_port_mapping(bf, pm_tcp(8080, "172.17.0.2", 80));
    bf_add_port_mapping(bf, pm_tcp(8443, "172.17.0.3", 443));
    var iso = vec_new(); vec_push(iso, "172.17.1.0/24");
    bf_add_isolation_group(bf, isolation_group_new("web", iso));
    firewall_render(bf_to_firewall(bf));
    return 0;
}

fn bench_set_render() {
    var s = nft_set_new("blocklist", SET_IPV4_ADDR);
    nft_set_add_element(s, "10.0.0.1");
    nft_set_add_element(s, "192.168.0.0/16");
    nft_set_render(s);
    return 0;
}

fn main() {
    alloc_init();
    var all = vec_new();
    var b = 0;

    b = bench_new("validate_identifier/short"); bench_run(b, &bench_validate_identifier_short, 100000); vec_push(all, b);
    b = bench_new("validate_identifier/long"); bench_run(b, &bench_validate_identifier_long, 100000); vec_push(all, b);
    b = bench_new("validate_addr/ipv4"); bench_run(b, &bench_validate_addr_ipv4, 100000); vec_push(all, b);
    b = bench_new("validate_addr/cidr"); bench_run(b, &bench_validate_addr_cidr, 100000); vec_push(all, b);
    b = bench_new("validate_addr/ipv6"); bench_run(b, &bench_validate_addr_ipv6, 100000); vec_push(all, b);
    b = bench_new("validate_iface"); bench_run(b, &bench_validate_iface, 100000); vec_push(all, b);
    b = bench_new("validate_comment"); bench_run(b, &bench_validate_comment, 100000); vec_push(all, b);
    b = bench_new("validate_ct_state"); bench_run(b, &bench_validate_ct_state, 100000); vec_push(all, b);
    b = bench_new("validate_family"); bench_run(b, &bench_validate_family, 100000); vec_push(all, b);

    b = bench_new("rule_render/simple"); bench_run(b, &bench_rule_render_simple, 100000); vec_push(all, b);
    b = bench_new("rule_render/service"); bench_run(b, &bench_rule_render_service, 100000); vec_push(all, b);
    b = bench_new("rule_render/complex"); bench_run(b, &bench_rule_render_complex, 100000); vec_push(all, b);

    b = bench_new("rule_validate/simple"); bench_run(b, &bench_rule_validate_simple, 100000); vec_push(all, b);
    b = bench_new("rule_validate/complex"); bench_run(b, &bench_rule_validate_complex, 100000); vec_push(all, b);

    b = bench_new("nein_err"); bench_run(b, &bench_nein_err, 1000000); vec_push(all, b);
    b = bench_new("nein_ok"); bench_run(b, &bench_nein_ok, 1000000); vec_push(all, b);

    b = bench_new("table_render/full"); bench_run(b, &bench_table_render, 10000); vec_push(all, b);
    b = bench_new("chain_render/base"); bench_run(b, &bench_chain_render, 100000); vec_push(all, b);
    b = bench_new("set_render"); bench_run(b, &bench_set_render, 100000); vec_push(all, b);

    b = bench_new("nat_dnat_render"); bench_run(b, &bench_nat_dnat_render, 100000); vec_push(all, b);
    b = bench_new("nat_masquerade_render"); bench_run(b, &bench_nat_masquerade_render, 100000); vec_push(all, b);
    b = bench_new("nat_validate"); bench_run(b, &bench_nat_validate, 100000); vec_push(all, b);

    b = bench_new("basic_host_firewall"); bench_run(b, &bench_basic_host_firewall, 10000); vec_push(all, b);
    b = bench_new("container_bridge"); bench_run(b, &bench_container_bridge, 10000); vec_push(all, b);
    b = bench_new("firewall_validate"); bench_run(b, &bench_firewall_validate, 10000); vec_push(all, b);

    b = bench_new("policy_to_rules"); bench_run(b, &bench_policy_to_rules, 100000); vec_push(all, b);
    b = bench_new("geoip_render"); bench_run(b, &bench_geoip_render, 10000); vec_push(all, b);
    b = bench_new("mesh_render"); bench_run(b, &bench_mesh_render, 10000); vec_push(all, b);
    b = bench_new("bridge_render"); bench_run(b, &bench_bridge_render, 10000); vec_push(all, b);
    b = bench_new("engine_10_agents_render"); bench_run(b, &bench_engine_10_agents_render, 1000); vec_push(all, b);
    b = bench_new("netns_render"); bench_run(b, &bench_netns_render, 10000); vec_push(all, b);

    bench_report_all(all);
    return 0;
}

var r = main();
syscall(60, r);
