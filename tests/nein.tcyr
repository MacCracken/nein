# ================================================================
# Error tests
# ================================================================

fn test_error() {
    test_group("error");
    assert(ERR_NFT_FAILED != 0, "ERR_NFT_FAILED nonzero");
    assert(ERR_INVALID_RULE != 0, "ERR_INVALID_RULE nonzero");
    assert(ERR_TABLE_NOT_FOUND != 0, "ERR_TABLE_NOT_FOUND nonzero");
    assert(ERR_CHAIN_NOT_FOUND != 0, "ERR_CHAIN_NOT_FOUND nonzero");
    assert(ERR_PERMISSION_DENIED != 0, "ERR_PERMISSION_DENIED nonzero");
    assert(ERR_PARSE != 0, "ERR_PARSE nonzero");
    assert(ERR_IO != 0, "ERR_IO nonzero");

    assert(ERR_NFT_FAILED != ERR_INVALID_RULE, "nft != invalid");
    assert(ERR_INVALID_RULE != ERR_TABLE_NOT_FOUND, "invalid != table");
    assert(ERR_TABLE_NOT_FOUND != ERR_CHAIN_NOT_FOUND, "table != chain");
    assert(ERR_CHAIN_NOT_FOUND != ERR_PERMISSION_DENIED, "chain != perm");
    assert(ERR_PERMISSION_DENIED != ERR_PARSE, "perm != parse");
    assert(ERR_PARSE != ERR_IO, "parse != io");

    var e = nein_err(ERR_NFT_FAILED);
    assert(is_err_result(e) == 1, "nein_err returns Err");
    assert_eq(err_code(e), ERR_NFT_FAILED, "err_code extracts code");

    var ok = nein_ok();
    assert(is_ok(ok) == 1, "nein_ok returns Ok");
    return 0;
}

# ================================================================
# Validate tests
# ================================================================

fn test_validate_identifier() {
    test_group("validate_identifier");
    assert(is_ok(validate_identifier("filter")) == 1, "filter ok");
    assert(is_ok(validate_identifier("my_table")) == 1, "my_table ok");
    assert(is_ok(validate_identifier("agnos-policy")) == 1, "agnos-policy ok");
    assert(is_ok(validate_identifier("0eth0")) == 1, "numeric start ok");
    assert(is_ok(validate_identifier("123")) == 1, "all numeric ok");
    assert(is_err_result(validate_identifier("")) == 1, "empty rejected");
    assert(is_err_result(validate_identifier("has space")) == 1, "space rejected");
    assert(is_err_result(validate_identifier("evil;drop")) == 1, "semicolon rejected");
    assert(is_err_result(validate_identifier("has{brace")) == 1, "brace rejected");

    var buf64[520];
    memset(&buf64, 97, 64);
    store8(&buf64 + 64, 0);
    assert(is_ok(validate_identifier(&buf64)) == 1, "64 chars ok");
    memset(&buf64, 97, 65);
    store8(&buf64 + 65, 0);
    assert(is_err_result(validate_identifier(&buf64)) == 1, "65 chars rejected");
    return 0;
}

fn test_validate_addr() {
    test_group("validate_addr");
    assert(is_ok(validate_addr("10.0.0.1")) == 1, "10.0.0.1 ok");
    assert(is_ok(validate_addr("192.168.0.0/16")) == 1, "CIDR ok");
    assert(is_ok(validate_addr("172.17.0.2")) == 1, "172 ok");
    assert(is_ok(validate_addr("::1")) == 1, "::1 ok");
    assert(is_ok(validate_addr("fe80::/10")) == 1, "fe80 CIDR ok");
    assert(is_ok(validate_addr("2001:db8::1")) == 1, "2001:db8 ok");
    assert(is_err_result(validate_addr("")) == 1, "empty rejected");
    assert(is_err_result(validate_addr("not_an_addr")) == 1, "alpha rejected");
    assert(is_err_result(validate_addr("10.0.0.1;drop")) == 1, "semicolon rejected");
    assert(is_err_result(validate_addr("10.0.0.1|evil")) == 1, "pipe rejected");
    return 0;
}

fn test_validate_iface() {
    test_group("validate_iface");
    assert(is_ok(validate_iface("eth0")) == 1, "eth0 ok");
    assert(is_ok(validate_iface("br-container")) == 1, "br-container ok");
    assert(is_ok(validate_iface("veth1.2")) == 1, "veth1.2 ok");
    assert(is_ok(validate_iface("lo")) == 1, "lo ok");
    assert(is_err_result(validate_iface("")) == 1, "empty rejected");
    assert(is_err_result(validate_iface("evil;drop")) == 1, "semicolon rejected");

    var buf16[24];
    memset(&buf16, 97, 15);
    store8(&buf16 + 15, 0);
    assert(is_ok(validate_iface(&buf16)) == 1, "15 chars ok");
    memset(&buf16, 97, 16);
    store8(&buf16 + 16, 0);
    assert(is_err_result(validate_iface(&buf16)) == 1, "16 chars rejected");
    return 0;
}

fn test_validate_ct_state() {
    test_group("validate_ct_state");
    assert(is_ok(validate_ct_state("new")) == 1, "new ok");
    assert(is_ok(validate_ct_state("established")) == 1, "established ok");
    assert(is_ok(validate_ct_state("related")) == 1, "related ok");
    assert(is_ok(validate_ct_state("invalid")) == 1, "invalid ok");
    assert(is_ok(validate_ct_state("untracked")) == 1, "untracked ok");
    assert(is_err_result(validate_ct_state("bogus")) == 1, "bogus rejected");
    assert(is_err_result(validate_ct_state("established; drop")) == 1, "injection rejected");
    return 0;
}

fn test_validate_comment() {
    test_group("validate_comment");
    assert(is_ok(validate_comment("SSH access")) == 1, "normal comment ok");
    assert(is_ok(validate_comment("container port 8080->80")) == 1, "arrow comment ok");
    assert(is_err_result(validate_comment("has \"quotes\"")) == 1, "quotes rejected");
    assert(is_err_result(validate_comment("has;semicolon")) == 1, "semicolon rejected");
    assert(is_err_result(validate_comment("has{brace")) == 1, "brace rejected");
    assert(is_err_result(validate_comment("has}brace")) == 1, "close brace rejected");
    assert(is_err_result(validate_comment("has|pipe")) == 1, "pipe rejected");
    assert(is_err_result(validate_comment("has`tick")) == 1, "backtick rejected");
    assert(is_err_result(validate_comment("has$dollar")) == 1, "dollar rejected");

    var buf130[136];
    memset(&buf130, 97, 128);
    store8(&buf130 + 128, 0);
    assert(is_ok(validate_comment(&buf130)) == 1, "128 chars ok");
    memset(&buf130, 97, 129);
    store8(&buf130 + 129, 0);
    assert(is_err_result(validate_comment(&buf130)) == 1, "129 chars rejected");
    return 0;
}

fn test_validate_log_prefix() {
    test_group("validate_log_prefix");
    assert(is_ok(validate_log_prefix("NEIN_DROP: ")) == 1, "prefix ok");
    assert(is_ok(validate_log_prefix("fw-input ")) == 1, "fw-input ok");
    assert(is_err_result(validate_log_prefix("has\"quote")) == 1, "quote rejected");
    assert(is_err_result(validate_log_prefix("has;semi")) == 1, "semicolon rejected");

    var buf66[72];
    memset(&buf66, 97, 64);
    store8(&buf66 + 64, 0);
    assert(is_ok(validate_log_prefix(&buf66)) == 1, "64 chars ok");
    memset(&buf66, 97, 65);
    store8(&buf66 + 65, 0);
    assert(is_err_result(validate_log_prefix(&buf66)) == 1, "65 chars rejected");
    return 0;
}

fn test_validate_nft_element() {
    test_group("validate_nft_element");
    assert(is_ok(validate_nft_element("10.0.0.1")) == 1, "ip ok");
    assert(is_ok(validate_nft_element("80")) == 1, "port ok");
    assert(is_ok(validate_nft_element("192.168.0.0/16")) == 1, "cidr ok");
    assert(is_ok(validate_nft_element("::1")) == 1, "ipv6 ok");
    assert(is_err_result(validate_nft_element("")) == 1, "empty rejected");
    assert(is_err_result(validate_nft_element("evil;inject")) == 1, "semicolon rejected");
    assert(is_err_result(validate_nft_element("has\"quote")) == 1, "quote rejected");
    return 0;
}

fn test_validate_family() {
    test_group("validate_family");
    assert(is_ok(validate_family("inet")) == 1, "inet ok");
    assert(is_ok(validate_family("ip")) == 1, "ip ok");
    assert(is_ok(validate_family("ip6")) == 1, "ip6 ok");
    assert(is_ok(validate_family("arp")) == 1, "arp ok");
    assert(is_ok(validate_family("bridge")) == 1, "bridge ok");
    assert(is_ok(validate_family("netdev")) == 1, "netdev ok");
    assert(is_err_result(validate_family("")) == 1, "empty rejected");
    assert(is_err_result(validate_family("ipv4")) == 1, "ipv4 rejected");
    assert(is_err_result(validate_family("filter")) == 1, "filter rejected");
    assert(is_err_result(validate_family("inet; drop")) == 1, "injection rejected");
    return 0;
}

fn test_dangerous_chars_all() {
    test_group("dangerous_chars_exhaustive");
    assert(is_err_result(validate_comment("t;v")) == 1, "comment ; rejected");
    assert(is_err_result(validate_comment("t{v")) == 1, "comment { rejected");
    assert(is_err_result(validate_comment("t}v")) == 1, "comment } rejected");
    assert(is_err_result(validate_comment("t|v")) == 1, "comment | rejected");
    assert(is_err_result(validate_comment("t`v")) == 1, "comment ` rejected");
    assert(is_err_result(validate_comment("t$v")) == 1, "comment $ rejected");
    assert(is_err_result(validate_log_prefix("t;v")) == 1, "prefix ; rejected");
    assert(is_err_result(validate_log_prefix("t{v")) == 1, "prefix { rejected");
    assert(is_err_result(validate_log_prefix("t}v")) == 1, "prefix } rejected");
    assert(is_err_result(validate_log_prefix("t|v")) == 1, "prefix | rejected");
    assert(is_err_result(validate_log_prefix("t`v")) == 1, "prefix ` rejected");
    assert(is_err_result(validate_log_prefix("t$v")) == 1, "prefix $ rejected");
    assert(is_err_result(validate_nft_element("t;v")) == 1, "elem ; rejected");
    assert(is_err_result(validate_nft_element("t{v")) == 1, "elem { rejected");
    assert(is_err_result(validate_nft_element("t|v")) == 1, "elem | rejected");
    return 0;
}

# ================================================================
# Rule render tests
# ================================================================

fn test_rule_render_basic() {
    test_group("rule_render_basic");

    # allow_tcp(443)
    var s = rule_render(allow_tcp(443));
    assert(streq(str_data(s), "tcp dport 443 accept") == 1, "allow_tcp(443)");

    # allow_udp(53)
    s = rule_render(allow_udp(53));
    assert(streq(str_data(s), "udp dport 53 accept") == 1, "allow_udp(53)");

    # deny_source
    s = rule_render(deny_source("10.0.0.0/8"));
    assert(streq(str_data(s), "ip saddr 10.0.0.0/8 drop") == 1, "deny_source");

    # allow_established
    s = rule_render(allow_established());
    assert(streq(str_data(s), "ct state { established, related } accept") == 1, "established");

    # allow_service
    s = rule_render(allow_service("192.168.1.0/24", PROTO_TCP, 8090));
    assert(streq(str_data(s), "ip saddr 192.168.1.0/24 tcp dport 8090 accept") == 1, "allow_service");

    # with comment
    var r = allow_tcp(22);
    rule_set_comment(r, "SSH access");
    s = rule_render(r);
    assert(streq(str_data(s), "tcp dport 22 accept comment \"SSH access\"") == 1, "with comment");

    return 0;
}

fn test_rule_render_verdicts() {
    test_group("rule_render_verdicts");

    # reject
    var s = rule_render(rule_new(verdict_reject()));
    assert(streq(str_data(s), "reject") == 1, "reject");

    # return
    s = rule_render(rule_new(verdict_return()));
    assert(streq(str_data(s), "return") == 1, "return");

    # counter
    var r = rule_new(verdict_counter());
    rule_add_match(r, match_protocol(PROTO_TCP));
    rule_add_match(r, match_dport(80));
    s = rule_render(r);
    assert(streq(str_data(s), "tcp dport 80 counter") == 1, "counter");

    # jump
    r = rule_new(verdict_jump("container_rules"));
    rule_add_match(r, match_oif("br0"));
    s = rule_render(r);
    assert(streq(str_data(s), "oif \"br0\" jump container_rules") == 1, "jump");

    # goto
    s = rule_render(rule_new(verdict_goto("other_chain")));
    assert(streq(str_data(s), "goto other_chain") == 1, "goto");

    # log with prefix
    r = rule_new(verdict_log("NEIN_DROP: "));
    rule_add_match(r, match_protocol(PROTO_TCP));
    s = rule_render(r);
    assert(streq(str_data(s), "tcp log prefix \"NEIN_DROP: \"") == 1, "log prefix");

    # log without prefix
    s = rule_render(rule_new(verdict_log(0)));
    assert(streq(str_data(s), "log") == 1, "log bare");

    # set mark
    r = rule_new(verdict_set_mark(42));
    rule_add_match(r, match_protocol(PROTO_TCP));
    rule_add_match(r, match_dport(80));
    s = rule_render(r);
    assert(streq(str_data(s), "tcp dport 80 meta mark set 42") == 1, "set mark");

    # set ct mark
    s = rule_render(rule_new(verdict_set_ct_mark(255)));
    assert(streq(str_data(s), "ct mark set 255") == 1, "set ct mark");

    # reject with tcp reset
    r = rule_new(verdict_reject_with(REJECT_TCP_RESET));
    rule_add_match(r, match_protocol(PROTO_TCP));
    rule_add_match(r, match_dport(80));
    s = rule_render(r);
    assert(streq(str_data(s), "tcp dport 80 reject with tcp reset") == 1, "reject tcp reset");

    # reject with icmp
    s = rule_render(rule_new(verdict_reject_with(REJECT_ICMP_HOST_UNREACH)));
    assert(streq(str_data(s), "reject with icmp type host-unreachable") == 1, "reject icmp host");

    # reject with icmpx
    s = rule_render(rule_new(verdict_reject_with(REJECT_ICMPX_ADMIN_PROHIB)));
    assert(streq(str_data(s), "reject with icmpx type admin-prohibited") == 1, "reject icmpx");

    # counter named
    r = rule_new(verdict_counter_named("http_hits"));
    rule_add_match(r, match_protocol(PROTO_TCP));
    rule_add_match(r, match_dport(80));
    s = rule_render(r);
    assert(streq(str_data(s), "tcp dport 80 counter name \"http_hits\"") == 1, "counter named");

    return 0;
}

fn test_rule_render_matches() {
    test_group("rule_render_matches");

    # sport
    var r = rule_new(verdict_accept());
    rule_add_match(r, match_protocol(PROTO_TCP));
    rule_add_match(r, match_sport(1024));
    var s = rule_render(r);
    assert(streq(str_data(s), "tcp sport 1024 accept") == 1, "sport");

    # dport range
    r = rule_new(verdict_accept());
    rule_add_match(r, match_protocol(PROTO_TCP));
    rule_add_match(r, match_dport_range(8000, 9000));
    s = rule_render(r);
    assert(streq(str_data(s), "tcp dport 8000-9000 accept") == 1, "dport range");

    # dest addr
    s = rule_render(rule_add_match(rule_new(verdict_drop()), match_dest_addr("10.0.0.1")));
    assert(streq(str_data(s), "ip daddr 10.0.0.1 drop") == 1, "dest addr");

    # ipv6 source
    s = rule_render(rule_add_match(rule_new(verdict_accept()), match_source_addr6("fe80::/10")));
    assert(streq(str_data(s), "ip6 saddr fe80::/10 accept") == 1, "source addr6");

    # ipv6 dest
    s = rule_render(rule_add_match(rule_new(verdict_drop()), match_dest_addr6("::1")));
    assert(streq(str_data(s), "ip6 daddr ::1 drop") == 1, "dest addr6");

    # deny_source6
    s = rule_render(deny_source6("2001:db8::/32"));
    assert(streq(str_data(s), "ip6 saddr 2001:db8::/32 drop") == 1, "deny_source6");

    # icmp protocol
    s = rule_render(rule_add_match(rule_new(verdict_accept()), match_protocol(PROTO_ICMP)));
    assert(streq(str_data(s), "icmp accept") == 1, "icmp");

    # icmpv6 protocol
    s = rule_render(rule_add_match(rule_new(verdict_accept()), match_protocol(PROTO_ICMPV6)));
    assert(streq(str_data(s), "icmpv6 accept") == 1, "icmpv6");

    # set lookup
    s = rule_render(rule_add_match(rule_new(verdict_drop()), match_set_lookup("ip saddr", "blocklist")));
    assert(streq(str_data(s), "ip saddr @blocklist drop") == 1, "set lookup");

    # ct helper
    s = rule_render(rule_add_match(rule_new(verdict_accept()), match_ct_helper("ftp")));
    assert(streq(str_data(s), "ct helper \"ftp\" accept") == 1, "ct helper");

    # tcp flags
    s = rule_render(rule_add_match(rule_new(verdict_drop()), match_tcp_flags("syn, fin")));
    assert(streq(str_data(s), "tcp flags { syn, fin } drop") == 1, "tcp flags");

    # icmp type
    s = rule_render(rule_add_match(rule_new(verdict_accept()), match_icmp_type("echo-request")));
    assert(streq(str_data(s), "icmp type echo-request accept") == 1, "icmp type");

    # icmpv6 type
    s = rule_render(rule_add_match(rule_new(verdict_accept()), match_icmpv6_type("echo-request")));
    assert(streq(str_data(s), "icmpv6 type echo-request accept") == 1, "icmpv6 type");

    # meta mark
    s = rule_render(rule_add_match(rule_new(verdict_accept()), match_meta_mark(1)));
    assert(streq(str_data(s), "meta mark 1 accept") == 1, "meta mark");

    # limit
    r = rule_new(verdict_accept());
    rule_add_match(r, match_limit(10, RATE_SECOND, 20));
    s = rule_render(r);
    assert(streq(str_data(s), "limit rate 10/second burst 20 packets accept") == 1, "limit");

    # quota over
    s = rule_render(rule_add_match(rule_new(verdict_drop()), match_quota(QUOTA_OVER, 25, QUNIT_MBYTES)));
    assert(streq(str_data(s), "quota over 25 mbytes drop") == 1, "quota over");

    # quota until
    s = rule_render(rule_add_match(rule_new(verdict_accept()), match_quota(QUOTA_UNTIL, 100, QUNIT_GBYTES)));
    assert(streq(str_data(s), "quota until 100 gbytes accept") == 1, "quota until");

    # flow offload
    s = rule_render(rule_add_match(rule_new(verdict_accept()), match_flow_offload("ft")));
    assert(streq(str_data(s), "flow offload @ft accept") == 1, "flow offload");

    # ct timeout set
    s = rule_render(rule_add_match(rule_new(verdict_accept()), match_ct_timeout_set("tcp-long")));
    assert(streq(str_data(s), "ct timeout set \"tcp-long\" accept") == 1, "ct timeout set");

    # icmp type + code
    s = rule_render(rule_add_match(rule_new(verdict_drop()), match_icmp_type_code("echo-request", 0)));
    assert(streq(str_data(s), "icmp type echo-request icmp code 0 drop") == 1, "icmp type+code");

    # icmpv6 type + code
    s = rule_render(rule_add_match(rule_new(verdict_drop()), match_icmpv6_type_code("echo-request", 0)));
    assert(streq(str_data(s), "icmpv6 type echo-request icmpv6 code 0 drop") == 1, "icmpv6 type+code");

    # vlan id
    s = rule_render(rule_add_match(rule_new(verdict_accept()), match_vlan_id(100)));
    assert(streq(str_data(s), "vlan id 100 accept") == 1, "vlan id");

    # dscp
    s = rule_render(rule_add_match(rule_new(verdict_accept()), match_dscp(46)));
    assert(streq(str_data(s), "ip dscp 46 accept") == 1, "dscp");

    # ipv6 ext hdr
    s = rule_render(rule_add_match(rule_new(verdict_drop()), match_ipv6_ext_hdr(EXT_ROUTING)));
    assert(streq(str_data(s), "exthdr rt exists drop") == 1, "ipv6 ext hdr");

    # frag off
    s = rule_render(rule_add_match(rule_new(verdict_drop()), match_frag_off(8192, NFT_CMP_NE, 0)));
    assert(streq(str_data(s), "ip frag-off & 0x2000 != 0x0 drop") == 1, "frag off more-fragments");

    # pkt type broadcast
    s = rule_render(rule_add_match(rule_new(verdict_drop()), match_pkt_type(PKT_BROADCAST)));
    assert(streq(str_data(s), "meta pkttype broadcast drop") == 1, "pkt type broadcast");

    # pkt type multicast
    s = rule_render(rule_add_match(rule_new(verdict_accept()), match_pkt_type(PKT_MULTICAST)));
    assert(streq(str_data(s), "meta pkttype multicast accept") == 1, "pkt type multicast");

    # conn limit
    r = rule_new(verdict_drop());
    rule_add_match(r, match_protocol(PROTO_TCP));
    rule_add_match(r, match_dport(22));
    rule_add_match(r, match_conn_limit(10));
    rule_set_comment(r, "SSH conn limit");
    s = rule_render(r);
    assert(streq(str_data(s), "tcp dport 22 ct count over 10 drop comment \"SSH conn limit\"") == 1, "conn limit");

    # raw
    s = rule_render(rule_add_match(rule_new(verdict_accept()), match_raw("dport { 80, 443, 8080 }")));
    assert(streq(str_data(s), "dport { 80, 443, 8080 } accept") == 1, "raw match");

    return 0;
}

fn test_rule_render_log_advanced() {
    test_group("rule_render_log_advanced");

    # full
    var s = rule_render(rule_new(verdict_log_advanced("NEIN: ", NFT_LOG_WARN, 1, 128)));
    assert(streq(str_data(s), "log prefix \"NEIN: \" level warn group 1 snaplen 128") == 1, "log advanced full");

    # level only
    s = rule_render(rule_new(verdict_log_advanced(0, NFT_LOG_DEBUG, 0, 0)));
    assert(streq(str_data(s), "log level debug") == 1, "log advanced level");

    # group only
    s = rule_render(rule_new(verdict_log_advanced(0, 0, 5, 0)));
    assert(streq(str_data(s), "log group 5") == 1, "log advanced group");

    # bare
    s = rule_render(rule_new(verdict_log_advanced(0, 0, 0, 0)));
    assert(streq(str_data(s), "log") == 1, "log advanced bare");

    return 0;
}

# ================================================================
# Rule validate tests
# ================================================================

fn test_rule_validate() {
    test_group("rule_validate");

    # Good rule
    assert(is_ok(rule_validate(allow_service("10.0.0.0/8", PROTO_TCP, 80))) == 1, "good rule ok");

    # Bad addr
    assert(is_err_result(rule_validate(deny_source("10.0.0.1; flush ruleset"))) == 1, "bad addr rejected");

    # Bad iface
    var r = rule_new(verdict_accept());
    rule_add_match(r, match_iif("eth0; drop"));
    assert(is_err_result(rule_validate(r)) == 1, "bad iface rejected");

    # Bad comment
    r = allow_tcp(22);
    rule_set_comment(r, "has \"quotes\"");
    assert(is_err_result(rule_validate(r)) == 1, "bad comment rejected");

    # Bad jump target
    assert(is_err_result(rule_validate(rule_new(verdict_jump("evil;chain")))) == 1, "bad jump rejected");

    # Bad goto target
    assert(is_err_result(rule_validate(rule_new(verdict_goto("bad;chain")))) == 1, "bad goto rejected");

    # Good goto
    assert(is_ok(rule_validate(rule_new(verdict_goto("valid_chain")))) == 1, "good goto ok");

    # Bad log prefix
    assert(is_err_result(rule_validate(rule_new(verdict_log("bad;prefix")))) == 1, "bad log prefix rejected");

    # Good log prefix
    assert(is_ok(rule_validate(rule_new(verdict_log("GOOD: ")))) == 1, "good log ok");

    # Port range valid
    r = rule_new(verdict_accept());
    rule_add_match(r, match_dport_range(80, 443));
    assert(is_ok(rule_validate(r)) == 1, "port range ok");

    # Port range equal
    r = rule_new(verdict_accept());
    rule_add_match(r, match_dport_range(80, 80));
    assert(is_ok(rule_validate(r)) == 1, "port range equal ok");

    # Port range inverted
    r = rule_new(verdict_accept());
    rule_add_match(r, match_dport_range(443, 80));
    assert(is_err_result(rule_validate(r)) == 1, "port range inverted rejected");

    # Raw match skipped
    r = rule_new(verdict_accept());
    rule_add_match(r, match_raw("anything goes here;{}"));
    assert(is_ok(rule_validate(r)) == 1, "raw match skipped");

    # DSCP valid/invalid
    r = rule_new(verdict_accept());
    rule_add_match(r, match_dscp(63));
    assert(is_ok(rule_validate(r)) == 1, "dscp 63 ok");
    r = rule_new(verdict_accept());
    rule_add_match(r, match_dscp(64));
    assert(is_err_result(rule_validate(r)) == 1, "dscp 64 rejected");

    # VLAN ID valid/invalid
    r = rule_new(verdict_accept());
    rule_add_match(r, match_vlan_id(4094));
    assert(is_ok(rule_validate(r)) == 1, "vlan 4094 ok");
    r = rule_new(verdict_accept());
    rule_add_match(r, match_vlan_id(4095));
    assert(is_err_result(rule_validate(r)) == 1, "vlan 4095 rejected");

    # Bad counter named
    assert(is_err_result(rule_validate(rule_new(verdict_counter_named("bad;counter")))) == 1, "bad counter rejected");
    assert(is_ok(rule_validate(rule_new(verdict_counter_named("my-counter")))) == 1, "good counter ok");

    # Bad log advanced prefix
    assert(is_err_result(rule_validate(rule_new(verdict_log_advanced("bad;prefix", 0, 0, 0)))) == 1, "bad adv prefix rejected");
    assert(is_ok(rule_validate(rule_new(verdict_log_advanced("TEST: ", NFT_LOG_INFO, 0, 0)))) == 1, "good adv prefix ok");

    # Bad set lookup
    r = rule_new(verdict_accept());
    rule_add_match(r, match_set_lookup("ip saddr", "bad;set"));
    assert(is_err_result(rule_validate(r)) == 1, "bad set_lookup rejected");

    # Bad ct helper
    r = rule_new(verdict_accept());
    rule_add_match(r, match_ct_helper("bad;helper"));
    assert(is_err_result(rule_validate(r)) == 1, "bad ct_helper rejected");

    # Bad flow offload
    r = rule_new(verdict_accept());
    rule_add_match(r, match_flow_offload("bad;ft"));
    assert(is_err_result(rule_validate(r)) == 1, "bad flow_offload rejected");

    # Bad ct timeout set
    r = rule_new(verdict_accept());
    rule_add_match(r, match_ct_timeout_set("evil;timeout"));
    assert(is_err_result(rule_validate(r)) == 1, "bad ct_timeout rejected");

    # Bad icmp type
    r = rule_new(verdict_accept());
    rule_add_match(r, match_icmp_type("bad;type"));
    assert(is_err_result(rule_validate(r)) == 1, "bad icmp_type rejected");

    return 0;
}

# ================================================================
# Set tests
# ================================================================

fn test_set_render() {
    test_group("set_render");

    # Basic set with elements
    var s = nft_set_new("blocklist", SET_IPV4_ADDR);
    nft_set_add_element(s, "10.0.0.1");
    nft_set_add_element(s, "10.0.0.2");
    nft_set_add_element(s, "192.168.1.0/24");
    var rendered = nft_set_render(s);
    assert(str_contains_cstr(rendered, "set blocklist") == 1, "set name");
    assert(str_contains_cstr(rendered, "type ipv4_addr") == 1, "set type");
    assert(str_contains_cstr(rendered, "10.0.0.1, 10.0.0.2, 192.168.1.0/24") == 1, "set elements");

    # Set with flags
    s = nft_set_new("ratelimit", SET_IPV4_ADDR);
    nft_set_add_flag(s, SETFLAG_INTERVAL);
    nft_set_add_flag(s, SETFLAG_TIMEOUT);
    rendered = nft_set_render(s);
    assert(str_contains_cstr(rendered, "flags interval, timeout") == 1, "set flags");

    # Empty set
    s = nft_set_new("empty", SET_INET_SERVICE);
    rendered = nft_set_render(s);
    assert(str_contains_cstr(rendered, "set empty") == 1, "empty name");
    assert(str_contains_cstr(rendered, "type inet_service") == 1, "empty type");

    # Ports
    s = nft_set_new("webports", SET_INET_SERVICE);
    nft_set_add_element(s, "80");
    nft_set_add_element(s, "443");
    nft_set_add_element(s, "8080");
    rendered = nft_set_render(s);
    assert(str_contains_cstr(rendered, "80, 443, 8080") == 1, "port elements");

    # IPv6
    s = nft_set_new("v6block", SET_IPV6_ADDR);
    nft_set_add_element(s, "::1");
    nft_set_add_element(s, "fe80::/10");
    rendered = nft_set_render(s);
    assert(str_contains_cstr(rendered, "type ipv6_addr") == 1, "ipv6 type");
    assert(str_contains_cstr(rendered, "::1, fe80::/10") == 1, "ipv6 elements");

    return 0;
}

fn test_set_validate() {
    test_group("set_validate");

    var s = nft_set_new("test", SET_IPV4_ADDR);
    nft_set_add_element(s, "10.0.0.1");
    assert(is_ok(nft_set_validate(s)) == 1, "good set ok");

    s = nft_set_new("bad;name", SET_IPV4_ADDR);
    assert(is_err_result(nft_set_validate(s)) == 1, "bad name rejected");

    s = nft_set_new("test", SET_IPV4_ADDR);
    nft_set_add_element(s, "evil;inject");
    assert(is_err_result(nft_set_validate(s)) == 1, "bad element rejected");

    return 0;
}

fn test_map_render() {
    test_group("map_render");

    # Basic map
    var m = nft_map_new("country_verdict", SET_IPV4_ADDR);
    nft_map_add_entry(m, "10.0.0.0/8", MAPV_ACCEPT, 0);
    nft_map_add_entry(m, "192.168.0.0/16", MAPV_DROP, 0);
    var rendered = nft_map_render(m);
    assert(str_contains_cstr(rendered, "map country_verdict") == 1, "map name");
    assert(str_contains_cstr(rendered, "type ipv4_addr : verdict") == 1, "map type");
    assert(str_contains_cstr(rendered, "10.0.0.0/8 : accept") == 1, "map accept entry");
    assert(str_contains_cstr(rendered, "192.168.0.0/16 : drop") == 1, "map drop entry");

    # Jump map
    m = nft_map_new("dispatch", SET_INET_SERVICE);
    nft_map_add_entry(m, "80", MAPV_JUMP, "web_chain");
    nft_map_add_entry(m, "22", MAPV_JUMP, "ssh_chain");
    rendered = nft_map_render(m);
    assert(str_contains_cstr(rendered, "80 : jump web_chain") == 1, "jump entry 80");
    assert(str_contains_cstr(rendered, "22 : jump ssh_chain") == 1, "jump entry 22");

    # Empty map
    m = nft_map_new("empty", SET_IPV4_ADDR);
    rendered = nft_map_render(m);
    assert(str_contains_cstr(rendered, "map empty") == 1, "empty map");

    return 0;
}

fn test_map_validate() {
    test_group("map_validate");

    var m = nft_map_new("test", SET_IPV4_ADDR);
    nft_map_add_entry(m, "10.0.0.1", MAPV_ACCEPT, 0);
    nft_map_add_entry(m, "10.0.0.2", MAPV_JUMP, "mychain");
    assert(is_ok(nft_map_validate(m)) == 1, "good map ok");

    m = nft_map_new("bad;name", SET_IPV4_ADDR);
    assert(is_err_result(nft_map_validate(m)) == 1, "bad name rejected");

    m = nft_map_new("test", SET_IPV4_ADDR);
    nft_map_add_entry(m, "evil;key", MAPV_ACCEPT, 0);
    assert(is_err_result(nft_map_validate(m)) == 1, "bad key rejected");

    m = nft_map_new("test", SET_IPV4_ADDR);
    nft_map_add_entry(m, "10.0.0.1", MAPV_JUMP, "bad;chain");
    assert(is_err_result(nft_map_validate(m)) == 1, "bad jump target rejected");

    return 0;
}

# ================================================================
# Chain tests
# ================================================================

fn test_chain_render() {
    test_group("chain_render");

    # Base chain
    var c = chain_base("input", CHAIN_FILTER, HOOK_INPUT, 0, POLICY_DROP);
    var rendered = chain_render(c);
    assert(str_contains_cstr(rendered, "chain input") == 1, "base chain name");
    assert(str_contains_cstr(rendered, "type filter hook input priority 0; policy drop;") == 1, "base header");

    # Regular chain
    c = chain_regular("my_chain");
    rendered = chain_render(c);
    assert(str_contains_cstr(rendered, "chain my_chain") == 1, "regular name");

    # Chain with rules
    c = chain_base("input", CHAIN_FILTER, HOOK_INPUT, 0, POLICY_DROP);
    chain_add_rule(c, allow_tcp(22));
    chain_add_rule(c, allow_tcp(443));
    rendered = chain_render(c);
    assert(str_contains_cstr(rendered, "tcp dport 22 accept") == 1, "rule 1");
    assert(str_contains_cstr(rendered, "tcp dport 443 accept") == 1, "rule 2");

    # NAT chain type
    c = chain_base("prerouting", CHAIN_NAT, HOOK_PREROUTING, 0 - 100, POLICY_ACCEPT);
    rendered = chain_render(c);
    assert(str_contains_cstr(rendered, "type nat hook prerouting priority -100; policy accept;") == 1, "nat chain");

    return 0;
}

# ================================================================
# Table tests
# ================================================================

fn test_table_render() {
    test_group("table_render");

    # Empty table
    var t = table_new("filter", FAMILY_INET);
    var rendered = table_render(t);
    assert(str_contains_cstr(rendered, "table inet filter") == 1, "table header");

    # Table with define
    t = table_new("filter", FAMILY_INET);
    table_add_define(t, define_new("LAN", "192.168.0.0/16"));
    rendered = table_render(t);
    assert(str_contains_cstr(rendered, "define $LAN = 192.168.0.0/16;") == 1, "define in table");

    # Table with set
    t = table_new("filter", FAMILY_INET);
    var s = nft_set_new("blocklist", SET_IPV4_ADDR);
    nft_set_add_element(s, "10.0.0.1");
    nft_set_add_element(s, "10.0.0.2");
    table_add_set(t, s);
    rendered = table_render(t);
    assert(str_contains_cstr(rendered, "set blocklist") == 1, "set in table");
    assert(str_contains_cstr(rendered, "10.0.0.1, 10.0.0.2") == 1, "set elements in table");

    # Table with map
    t = table_new("filter", FAMILY_INET);
    var m = nft_map_new("portmap", SET_INET_SERVICE);
    nft_map_add_entry(m, "80", MAPV_JUMP, "web");
    table_add_map(t, m);
    rendered = table_render(t);
    assert(str_contains_cstr(rendered, "map portmap") == 1, "map in table");
    assert(str_contains_cstr(rendered, "80 : jump web") == 1, "map entry in table");

    # Table with chain
    t = table_new("filter", FAMILY_INET);
    var c = chain_base("input", CHAIN_FILTER, HOOK_INPUT, 0, POLICY_DROP);
    chain_add_rule(c, allow_established());
    chain_add_rule(c, allow_tcp(22));
    table_add_chain(t, c);
    rendered = table_render(t);
    assert(str_contains_cstr(rendered, "chain input") == 1, "chain in table");
    assert(str_contains_cstr(rendered, "ct state { established, related } accept") == 1, "rule in chain");

    return 0;
}

fn test_table_render_order() {
    test_group("table_render_order");

    var t = table_new("filter", FAMILY_INET);
    table_add_define(t, define_new("WAN", "eth0"));

    var devs = vec_new();
    vec_push(devs, "eth0");
    table_add_flowtable(t, flowtable_new("ft", 0, devs));
    table_add_ct_timeout(t, ct_timeout_new("tcp-timeout", PROTO_TCP));
    table_add_set(t, nft_set_new("myset", SET_IPV4_ADDR));
    table_add_map(t, nft_map_new("mymap", SET_INET_SERVICE));
    table_add_chain(t, chain_regular("mychain"));

    var rendered = table_render(t);
    var rd = str_data(rendered);

    # Check ordering: define < flowtable < ct timeout < set < map < chain
    var def_pos = str_index_of_cstr(rendered, "define $WAN");
    var ft_pos = str_index_of_cstr(rendered, "flowtable ft");
    var ct_pos = str_index_of_cstr(rendered, "ct timeout tcp-timeout");
    var set_pos = str_index_of_cstr(rendered, "set myset");
    var map_pos = str_index_of_cstr(rendered, "map mymap");
    var chain_pos = str_index_of_cstr(rendered, "chain mychain");

    assert(def_pos < ft_pos, "define before flowtable");
    assert(ft_pos < ct_pos, "flowtable before ct_timeout");
    assert(ct_pos < set_pos, "ct_timeout before set");
    assert(set_pos < map_pos, "set before map");
    assert(map_pos < chain_pos, "map before chain");

    return 0;
}

fn test_define_validate() {
    test_group("define_validate");
    assert(is_ok(define_validate(define_new("MY_VAR", "10.0.0.1"))) == 1, "good define ok");
    assert(is_err_result(define_validate(define_new("bad;name", "value"))) == 1, "bad name rejected");
    assert(is_err_result(define_validate(define_new("ok", "evil;inject"))) == 1, "bad value rejected");
    return 0;
}

fn test_flowtable() {
    test_group("flowtable");

    # Render
    var devs = vec_new();
    vec_push(devs, "eth0");
    vec_push(devs, "eth1");
    var ft = flowtable_new("ft", 0, devs);
    var rendered = flowtable_render(ft);
    assert(str_contains_cstr(rendered, "flowtable ft {") == 1, "ft name");
    assert(str_contains_cstr(rendered, "hook ingress priority 0;") == 1, "ft hook");
    assert(str_contains_cstr(rendered, "devices = { eth0, eth1 }") == 1, "ft devices");

    # Validate good
    devs = vec_new();
    vec_push(devs, "eth0");
    ft = flowtable_new("ft", 0, devs);
    assert(is_ok(flowtable_validate(ft)) == 1, "good ft ok");

    # Validate empty devices
    ft = flowtable_new("ft", 0, vec_new());
    assert(is_err_result(flowtable_validate(ft)) == 1, "empty devices rejected");

    # Validate bad name
    devs = vec_new();
    vec_push(devs, "eth0");
    ft = flowtable_new("bad;ft", 0, devs);
    assert(is_err_result(flowtable_validate(ft)) == 1, "bad ft name rejected");

    # Validate bad device
    devs = vec_new();
    vec_push(devs, "evil;dev");
    ft = flowtable_new("ft", 0, devs);
    assert(is_err_result(flowtable_validate(ft)) == 1, "bad device rejected");

    return 0;
}

fn test_ct_timeout() {
    test_group("ct_timeout");

    # Render with l3proto and policy
    var ct = ct_timeout_new("tcp-long", PROTO_TCP);
    ct_timeout_set_l3proto(ct, FAMILY_IP);
    ct_timeout_add_timeout(ct, "established", 7200);
    ct_timeout_add_timeout(ct, "close_wait", 60);
    var rendered = ct_timeout_render(ct);
    assert(str_contains_cstr(rendered, "ct timeout tcp-long {") == 1, "ct name");
    assert(str_contains_cstr(rendered, "protocol tcp;") == 1, "ct proto");
    assert(str_contains_cstr(rendered, "l3proto ip;") == 1, "ct l3proto");
    assert(str_contains_cstr(rendered, "established: 7200, close_wait: 60") == 1, "ct policy");

    # Render without l3proto
    ct = ct_timeout_new("udp-short", PROTO_UDP);
    ct_timeout_add_timeout(ct, "unreplied", 30);
    rendered = ct_timeout_render(ct);
    assert(str_contains_cstr(rendered, "protocol udp;") == 1, "udp proto");

    # Validate good
    ct = ct_timeout_new("my-timeout", PROTO_TCP);
    ct_timeout_add_timeout(ct, "established", 3600);
    assert(is_ok(ct_timeout_validate(ct)) == 1, "good ct ok");

    # Validate bad protocol
    ct = ct_timeout_new("t", PROTO_ICMP);
    assert(is_err_result(ct_timeout_validate(ct)) == 1, "bad proto rejected");

    # Validate bad l3proto
    ct = ct_timeout_new("t", PROTO_TCP);
    ct_timeout_set_l3proto(ct, FAMILY_BRIDGE);
    assert(is_err_result(ct_timeout_validate(ct)) == 1, "bad l3proto rejected");

    # Validate bad name
    ct = ct_timeout_new("bad;name", PROTO_TCP);
    assert(is_err_result(ct_timeout_validate(ct)) == 1, "bad ct name rejected");

    # Validate bad state
    ct = ct_timeout_new("ok", PROTO_TCP);
    ct_timeout_add_timeout(ct, "evil;state", 100);
    assert(is_err_result(ct_timeout_validate(ct)) == 1, "bad state rejected");

    return 0;
}

# ================================================================
# NAT tests
# ================================================================

fn test_nat_render() {
    test_group("nat_render");

    # DNAT IPv4
    var n = port_forward(8080, "172.17.0.2", 80);
    var rd = str_data(nat_render(n));
    assert(streq(rd, "tcp dport 8080 dnat to 172.17.0.2:80 comment \"container port fwd\"") == 1, "port_forward");

    # DNAT IPv6 brackets
    n = nat_dnat(PROTO_TCP, 443, "2001:db8::1", 8443, 0);
    rd = str_data(nat_render(n));
    assert(streq(rd, "tcp dport 443 dnat to [2001:db8::1]:8443") == 1, "dnat ipv6 brackets");

    # DNAT IPv4 no brackets
    n = nat_dnat(PROTO_TCP, 80, "10.0.0.1", 8080, 0);
    rd = str_data(nat_render(n));
    assert(streq(rd, "tcp dport 80 dnat to 10.0.0.1:8080") == 1, "dnat ipv4 no brackets");

    # DNAT with comment
    n = nat_dnat(PROTO_TCP, 443, "10.0.0.1", 8443, "TLS forward");
    var rendered = nat_render(n);
    assert(str_contains_cstr(rendered, "dnat to 10.0.0.1:8443") == 1, "dnat target");
    assert(str_contains_cstr(rendered, "comment \"TLS forward\"") == 1, "dnat comment");

    # SNAT plain
    n = nat_snat("10.0.0.0/8", "1.2.3.4", 0);
    rd = str_data(nat_render(n));
    assert(streq(rd, "ip saddr 10.0.0.0/8 snat to 1.2.3.4") == 1, "snat");

    # SNAT with comment
    n = nat_snat("10.0.0.0/8", "1.2.3.4", "outbound SNAT");
    rendered = nat_render(n);
    assert(str_contains_cstr(rendered, "snat to 1.2.3.4") == 1, "snat target");
    assert(str_contains_cstr(rendered, "comment \"outbound SNAT\"") == 1, "snat comment");

    # MASQUERADE no oif
    n = nat_masquerade("10.0.0.0/8", 0, 0);
    rd = str_data(nat_render(n));
    assert(streq(rd, "ip saddr 10.0.0.0/8 masquerade") == 1, "masquerade no oif");

    # MASQUERADE with oif + comment
    n = container_masquerade("172.17.0.0/16", "eth0");
    rd = str_data(nat_render(n));
    assert(streq(rd, "ip saddr 172.17.0.0/16 oif \"eth0\" masquerade comment \"container outbound NAT\"") == 1, "container_masquerade");

    # REDIRECT plain
    n = nat_redirect(PROTO_TCP, 80, 8080, 0);
    rd = str_data(nat_render(n));
    assert(streq(rd, "tcp dport 80 redirect to :8080") == 1, "redirect");

    # REDIRECT with comment
    n = nat_redirect(PROTO_TCP, 80, 8080, "local redirect");
    rendered = nat_render(n);
    assert(str_contains_cstr(rendered, "redirect to :8080") == 1, "redirect target");
    assert(str_contains_cstr(rendered, "comment \"local redirect\"") == 1, "redirect comment");

    return 0;
}

fn test_nat_validate() {
    test_group("nat_validate");

    # Good DNAT
    assert(is_ok(nat_validate(port_forward(8080, "172.17.0.2", 80))) == 1, "good DNAT ok");

    # Bad SNAT addr
    var n = nat_snat("10.0.0.0/8; drop", "1.2.3.4", 0);
    assert(is_err_result(nat_validate(n)) == 1, "bad SNAT source rejected");

    n = nat_snat("10.0.0.0/8", "bad;addr", 0);
    assert(is_err_result(nat_validate(n)) == 1, "bad SNAT target rejected");

    # Bad MASQUERADE iface
    n = nat_masquerade("10.0.0.0/8", "eth0; drop", 0);
    assert(is_err_result(nat_validate(n)) == 1, "bad masquerade iface rejected");

    # Bad DNAT comment
    n = nat_dnat(PROTO_TCP, 80, "10.0.0.1", 8080, "bad;comment");
    assert(is_err_result(nat_validate(n)) == 1, "bad DNAT comment rejected");

    # Bad REDIRECT comment
    n = nat_redirect(PROTO_TCP, 80, 8080, "bad;comment");
    assert(is_err_result(nat_validate(n)) == 1, "bad redirect comment rejected");

    # Bad MASQUERADE comment
    n = nat_masquerade("10.0.0.0/8", 0, "bad;comment");
    assert(is_err_result(nat_validate(n)) == 1, "bad masquerade comment rejected");

    # Good SNAT/redirect/masquerade with valid comments
    assert(is_ok(nat_validate(nat_snat("10.0.0.0/8", "1.2.3.4", "valid"))) == 1, "good SNAT ok");
    assert(is_ok(nat_validate(nat_redirect(PROTO_TCP, 80, 8080, "valid"))) == 1, "good redirect ok");

    return 0;
}

fn test_nat_dnat_range() {
    test_group("nat_dnat_range");

    # Render IPv4
    var n = port_range_forward(80, 89, "172.17.0.2", 8080);
    var rendered = nat_render(n);
    assert(str_contains_cstr(rendered, "tcp dport 80-89 dnat to 172.17.0.2:8080-8089") == 1, "range forward");

    # Render IPv6
    n = nat_dnat_range(PROTO_TCP, 80, 89, "2001:db8::1", 8080, 8089, 0);
    var rd = str_data(nat_render(n));
    assert(streq(rd, "tcp dport 80-89 dnat to [2001:db8::1]:8080-8089") == 1, "range ipv6 brackets");

    # With comment
    n = nat_dnat_range(PROTO_TCP, 80, 89, "10.0.0.1", 8080, 8089, "web range");
    rendered = nat_render(n);
    assert(str_contains_cstr(rendered, "comment \"web range\"") == 1, "range comment");

    # Validate good
    assert(is_ok(nat_validate(port_range_forward(80, 89, "172.17.0.2", 8080))) == 1, "good range ok");

    # Validate bad addr
    n = nat_dnat_range(PROTO_TCP, 80, 89, "evil;addr", 8080, 8089, 0);
    assert(is_err_result(nat_validate(n)) == 1, "bad addr rejected");

    # Inverted dest
    n = nat_dnat_range(PROTO_TCP, 89, 80, "10.0.0.1", 8080, 8089, 0);
    assert(is_err_result(nat_validate(n)) == 1, "inverted dest rejected");

    # Size mismatch
    n = nat_dnat_range(PROTO_TCP, 80, 89, "10.0.0.1", 8080, 8085, 0);
    assert(is_err_result(nat_validate(n)) == 1, "size mismatch rejected");

    # Bad comment
    n = nat_dnat_range(PROTO_TCP, 80, 89, "10.0.0.1", 8080, 8089, "bad;comment");
    assert(is_err_result(nat_validate(n)) == 1, "bad range comment rejected");

    # Single port (start == end)
    n = nat_dnat_range(PROTO_TCP, 80, 80, "10.0.0.1", 8080, 8080, 0);
    assert(is_ok(nat_validate(n)) == 1, "single port range ok");

    return 0;
}

# ================================================================
# Firewall tests
# ================================================================

fn test_firewall() {
    test_group("firewall");

    # Empty firewall
    var fw = firewall_new();
    var rendered = firewall_render(fw);
    assert(str_len(rendered) == 0, "empty render");

    # Add table
    firewall_add_table(fw, table_new("test", FAMILY_INET));
    assert(vec_len(firewall_tables(fw)) == 1, "one table");

    # Multiple tables
    fw = firewall_new();
    firewall_add_table(fw, table_new("t1", FAMILY_INET));
    firewall_add_table(fw, table_new("t2", FAMILY_IP));
    rendered = firewall_render(fw);
    assert(str_contains_cstr(rendered, "table inet t1") == 1, "table t1");
    assert(str_contains_cstr(rendered, "table ip t2") == 1, "table t2");
    assert(vec_len(firewall_tables(fw)) == 2, "two tables");

    # Dry run flag
    fw = firewall_new();
    firewall_set_dry_run(fw, 1);
    assert(firewall_dry_run(fw) == 1, "dry run set");

    return 0;
}

fn test_firewall_validate() {
    test_group("firewall_validate");

    # Empty is valid
    assert(is_ok(firewall_validate(firewall_new())) == 1, "empty valid");

    # Bad table name rejected
    var fw = firewall_new();
    firewall_add_table(fw, table_new("evil;drop", FAMILY_INET));
    assert(is_err_result(firewall_validate(fw)) == 1, "bad table name rejected");

    # Bad chain name rejected
    fw = firewall_new();
    var t = table_new("good", FAMILY_INET);
    table_add_chain(t, chain_regular("bad;chain"));
    firewall_add_table(fw, t);
    assert(is_err_result(firewall_validate(fw)) == 1, "bad chain name rejected");

    # Good firewall passes
    fw = firewall_new();
    t = table_new("filter", FAMILY_INET);
    var c = chain_base("input", CHAIN_FILTER, HOOK_INPUT, 0, POLICY_DROP);
    chain_add_rule(c, allow_tcp(22));
    table_add_chain(t, c);
    firewall_add_table(fw, t);
    assert(is_ok(firewall_validate(fw)) == 1, "good firewall ok");

    # Bad rule in chain rejected
    fw = firewall_new();
    t = table_new("filter", FAMILY_INET);
    c = chain_regular("input");
    var bad = rule_new(verdict_accept());
    rule_add_match(bad, match_source_addr("evil;addr"));
    chain_add_rule(c, bad);
    table_add_chain(t, c);
    firewall_add_table(fw, t);
    assert(is_err_result(firewall_validate(fw)) == 1, "bad rule in chain rejected");

    return 0;
}

# ================================================================
# Builder tests
# ================================================================

fn test_builder() {
    test_group("builder");

    # basic_host_firewall
    var fw = basic_host_firewall();
    var rendered = firewall_render(fw);
    assert(str_contains_cstr(rendered, "table inet filter") == 1, "host fw table");
    assert(str_contains_cstr(rendered, "policy drop") == 1, "host fw policy");
    assert(str_contains_cstr(rendered, "ct state { established, related } accept") == 1, "host fw established");
    assert(str_contains_cstr(rendered, "dport 22 accept") == 1, "host fw SSH");

    # container_bridge
    fw = container_bridge("br0", "172.17.0.0/16", "eth0");
    rendered = firewall_render(fw);
    assert(str_contains_cstr(rendered, "table inet filter") == 1, "bridge filter");
    assert(str_contains_cstr(rendered, "table ip nat") == 1, "bridge nat");
    assert(str_contains_cstr(rendered, "container to internet") == 1, "bridge internet");
    assert(str_contains_cstr(rendered, "masquerade") == 1, "bridge masquerade");

    # service_policy
    var ports = vec_new();
    vec_push(ports, _port_pair_new(PROTO_TCP, 8090));
    fw = service_policy("10.0.0.1", ports);
    rendered = firewall_render(fw);
    assert(str_contains_cstr(rendered, "ip saddr 10.0.0.1") == 1, "service policy source");
    assert(str_contains_cstr(rendered, "dport 8090") == 1, "service policy port");

    # All builder firewalls validate
    assert(is_ok(firewall_validate(basic_host_firewall())) == 1, "host fw validates");
    assert(is_ok(firewall_validate(container_bridge("br0", "172.17.0.0/16", "eth0"))) == 1, "bridge validates");

    return 0;
}

# ================================================================
# Policy tests
# ================================================================

fn test_policy() {
    test_group("policy");

    # agent_to_agent policy
    var np = agent_to_agent("hoosh-to-daimon", "10.0.0.1", "10.0.0.2", PROTO_TCP, 8090);
    var rules = policy_to_rules(np);
    assert(vec_len(rules) == 1, "one rule");
    var rendered = rule_render(vec_get(rules, 0));
    assert(str_contains_cstr(rendered, "ip saddr 10.0.0.1") == 1, "source addr");
    assert(str_contains_cstr(rendered, "dport 8090") == 1, "dport");
    assert(str_contains_cstr(rendered, "accept") == 1, "accept");

    # Validate good
    assert(is_ok(policy_validate(np)) == 1, "good policy ok");

    # Bad name
    np = agent_to_agent("evil;name", "10.0.0.1", "10.0.0.2", PROTO_TCP, 80);
    assert(is_err_result(policy_validate(np)) == 1, "bad name rejected");

    # Bad peer
    np = agent_to_agent("allow-web", "10.0.0.1; drop", "10.0.0.2", PROTO_TCP, 80);
    assert(is_err_result(policy_validate(np)) == 1, "bad peer rejected");

    # Egress policy
    np = network_policy_new("egress-test", "10.0.0.1", PACT_DENY);
    var pr = policy_rule_new("10.0.0.2");
    policy_rule_add_port(pr, PROTO_TCP, 443);
    policy_add_egress(np, pr);
    rules = policy_to_rules(np);
    assert(vec_len(rules) == 1, "egress one rule");
    rendered = rule_render(vec_get(rules, 0));
    assert(str_contains_cstr(rendered, "ip daddr 10.0.0.2") == 1, "egress dest");
    assert(str_contains_cstr(rendered, "dport 443") == 1, "egress dport");
    assert(str_contains_cstr(rendered, "egress to 10.0.0.2") == 1, "egress comment");

    # "any" source: no saddr match
    np = network_policy_new("public-web", "webserver", PACT_DENY);
    pr = policy_rule_new("any");
    policy_rule_add_port(pr, PROTO_TCP, 80);
    policy_rule_add_port(pr, PROTO_TCP, 443);
    policy_add_ingress(np, pr);
    rules = policy_to_rules(np);
    assert(vec_len(rules) == 2, "two rules from 2 ports");
    rendered = rule_render(vec_get(rules, 0));
    assert(str_contains_cstr(rendered, "saddr") == 0, "any src has no saddr");

    # "any" dest: no daddr match
    np = network_policy_new("egress-any", "10.0.0.1", PACT_ALLOW);
    pr = policy_rule_new("any");
    policy_rule_add_port(pr, PROTO_TCP, 80);
    policy_add_egress(np, pr);
    rules = policy_to_rules(np);
    assert(vec_len(rules) == 1, "any egress one rule");
    rendered = rule_render(vec_get(rules, 0));
    assert(str_contains_cstr(rendered, "daddr") == 0, "any dst has no daddr");

    return 0;
}

# ================================================================
# GeoIP tests
# ================================================================

fn test_geoip() {
    test_group("geoip");

    # Empty blocklist
    var bl = geoip_new();
    assert(str_len(firewall_render(geoip_to_firewall(bl))) == 0, "empty render");

    # Single country v4
    bl = geoip_new();
    var cidrs = vec_new();
    vec_push(cidrs, "1.0.0.0/8");
    vec_push(cidrs, "2.0.0.0/8");
    geoip_block_country(bl, country_block_v4("CN", cidrs));
    var rendered = firewall_render(geoip_to_firewall(bl));
    assert(str_contains_cstr(rendered, "table ip nein_geoip") == 1, "v4 table");
    assert(str_contains_cstr(rendered, "set geo_cn") == 1, "v4 set");
    assert(str_contains_cstr(rendered, "type ipv4_addr") == 1, "v4 type");
    assert(str_contains_cstr(rendered, "flags interval") == 1, "interval flag");
    assert(str_contains_cstr(rendered, "1.0.0.0/8, 2.0.0.0/8") == 1, "v4 cidrs");
    assert(str_contains_cstr(rendered, "ip saddr @geo_cn drop") == 1, "v4 rule");
    assert(str_contains_cstr(rendered, "geoblock CN") == 1, "v4 comment");

    # Dual stack
    bl = geoip_new();
    var v4 = vec_new(); vec_push(v4, "5.0.0.0/8");
    var v6 = vec_new(); vec_push(v6, "2a00::/12");
    geoip_block_country(bl, country_block_dual("RU", v4, v6));
    rendered = firewall_render(geoip_to_firewall(bl));
    assert(str_contains_cstr(rendered, "table ip nein_geoip") == 1, "dual v4 table");
    assert(str_contains_cstr(rendered, "table ip6 nein_geoip_v6") == 1, "dual v6 table");
    assert(str_contains_cstr(rendered, "type ipv4_addr") == 1, "dual v4 type");
    assert(str_contains_cstr(rendered, "type ipv6_addr") == 1, "dual v6 type");
    assert(str_contains_cstr(rendered, "ip saddr @geo_ru") == 1, "dual v4 rule");
    assert(str_contains_cstr(rendered, "ip6 saddr @geo_ru") == 1, "dual v6 rule");

    # Custom table name
    bl = geoip_new();
    geoip_set_table_name(bl, "aegis_geo");
    var c = vec_new(); vec_push(c, "1.0.0.0/8");
    geoip_block_country(bl, country_block_v4("CN", c));
    rendered = firewall_render(geoip_to_firewall(bl));
    assert(str_contains_cstr(rendered, "table ip aegis_geo") == 1, "custom table name");

    # Custom hook
    bl = geoip_new();
    geoip_set_hook(bl, HOOK_FORWARD);
    c = vec_new(); vec_push(c, "1.0.0.0/8");
    geoip_block_country(bl, country_block_v4("CN", c));
    rendered = firewall_render(geoip_to_firewall(bl));
    assert(str_contains_cstr(rendered, "hook forward") == 1, "custom hook");

    # Validate good
    bl = geoip_new();
    c = vec_new(); vec_push(c, "3.0.0.0/8");
    geoip_block_country(bl, country_block_v4("US", c));
    assert(is_ok(geoip_validate(bl)) == 1, "good geoip ok");
    # firewall validates too
    assert(is_ok(firewall_validate(geoip_to_firewall(bl))) == 1, "geoip firewall valid");

    # Bad country code
    bl = geoip_new();
    c = vec_new(); vec_push(c, "1.0.0.0/8");
    geoip_block_country(bl, country_block_v4("invalid", c));
    assert(is_err_result(geoip_validate(bl)) == 1, "bad country code rejected");

    # Bad cidr
    bl = geoip_new();
    c = vec_new(); vec_push(c, "evil;cidr");
    geoip_block_country(bl, country_block_v4("CN", c));
    assert(is_err_result(geoip_validate(bl)) == 1, "bad cidr rejected");

    # Bad v6 cidr
    bl = geoip_new();
    v4 = vec_new();
    v6 = vec_new(); vec_push(v6, "evil;v6");
    geoip_block_country(bl, country_block_dual("RU", v4, v6));
    assert(is_err_result(geoip_validate(bl)) == 1, "bad v6 cidr rejected");

    # Bad table name
    bl = geoip_new();
    geoip_set_table_name(bl, "bad;table");
    assert(is_err_result(geoip_validate(bl)) == 1, "bad table name rejected");

    # v6-only country: only v6 table rendered
    bl = geoip_new();
    v4 = vec_new();
    v6 = vec_new(); vec_push(v6, "2001::/16");
    geoip_block_country(bl, country_block_dual("JP", v4, v6));
    rendered = firewall_render(geoip_to_firewall(bl));
    assert(str_contains_cstr(rendered, "table ip nein_geoip {") == 0, "no v4 table");
    assert(str_contains_cstr(rendered, "table ip6 nein_geoip_v6") == 1, "v6 table only");

    return 0;
}

# ================================================================
# Mesh tests
# ================================================================

fn test_mesh() {
    test_group("mesh");

    # Envoy defaults
    var m = mesh_envoy();
    assert_eq(mesh_inbound_port(m), 15006, "inbound port");
    assert_eq(mesh_outbound_port(m), 15001, "outbound port");
    assert_eq(mesh_proxy_uid(m), 1337, "proxy uid");
    var cidrs = mesh_excl_out_cidrs(m);
    assert(vec_len(cidrs) == 1, "one cidr");
    assert(streq(vec_get(cidrs, 0), "127.0.0.0/8") == 1, "localhost");

    # Render envoy defaults
    m = mesh_envoy();
    var rendered = firewall_render(mesh_to_firewall(m));
    assert(str_contains_cstr(rendered, "table ip nein_mesh") == 1, "table");
    assert(str_contains_cstr(rendered, "chain mesh_outbound") == 1, "outbound chain");
    assert(str_contains_cstr(rendered, "chain mesh_inbound") == 1, "inbound chain");
    assert(str_contains_cstr(rendered, "meta skuid 1337") == 1, "skuid");
    assert(str_contains_cstr(rendered, "skip proxy traffic") == 1, "skip proxy comment");
    assert(str_contains_cstr(rendered, "ip daddr 127.0.0.0/8") == 1, "localhost daddr");
    assert(str_contains_cstr(rendered, "skip outbound 127.0.0.0/8") == 1, "localhost comment");
    assert(str_contains_cstr(rendered, "redirect to :15001") == 1, "outbound redirect");
    assert(str_contains_cstr(rendered, "redirect to :15006") == 1, "inbound redirect");

    # Custom ports + UID
    m = mesh_envoy();
    mesh_set_inbound_port(m, 20000);
    mesh_set_outbound_port(m, 20001);
    mesh_set_proxy_uid(m, 5000);
    rendered = firewall_render(mesh_to_firewall(m));
    assert(str_contains_cstr(rendered, "meta skuid 5000") == 1, "custom uid");
    assert(str_contains_cstr(rendered, "redirect to :20001") == 1, "custom outbound");
    assert(str_contains_cstr(rendered, "redirect to :20000") == 1, "custom inbound");

    # Exclude outbound ports
    m = mesh_envoy();
    mesh_exclude_outbound_port(m, 9090);
    mesh_exclude_outbound_port(m, 8081);
    rendered = firewall_render(mesh_to_firewall(m));
    assert(str_contains_cstr(rendered, "skip outbound port 9090") == 1, "excl out 9090");
    assert(str_contains_cstr(rendered, "skip outbound port 8081") == 1, "excl out 8081");
    assert(str_contains_cstr(rendered, "dport 9090") == 1, "excl out dport");

    # Exclude inbound ports
    m = mesh_envoy();
    mesh_exclude_inbound_port(m, 15090);
    mesh_exclude_inbound_port(m, 15021);
    rendered = firewall_render(mesh_to_firewall(m));
    assert(str_contains_cstr(rendered, "skip inbound port 15090") == 1, "excl in 15090");
    assert(str_contains_cstr(rendered, "skip inbound port 15021") == 1, "excl in 15021");

    # Exclude outbound CIDRs
    m = mesh_envoy();
    mesh_exclude_outbound_cidr(m, "10.0.0.0/8");
    mesh_exclude_outbound_cidr(m, "169.254.0.0/16");
    rendered = firewall_render(mesh_to_firewall(m));
    assert(str_contains_cstr(rendered, "skip outbound 10.0.0.0/8") == 1, "excl cidr 10");
    assert(str_contains_cstr(rendered, "skip outbound 169.254.0.0/16") == 1, "excl cidr link-local");

    # Custom table name
    m = mesh_envoy();
    mesh_set_table_name(m, "daimon_mesh");
    rendered = firewall_render(mesh_to_firewall(m));
    assert(str_contains_cstr(rendered, "table ip daimon_mesh") == 1, "custom table");

    # Validate good
    assert(is_ok(mesh_validate(mesh_envoy())) == 1, "good mesh ok");

    # Bad table name
    m = mesh_envoy();
    mesh_set_table_name(m, "bad;name");
    assert(is_err_result(mesh_validate(m)) == 1, "bad table rejected");

    # Bad cidr
    m = mesh_envoy();
    mesh_exclude_outbound_cidr(m, "evil;cidr");
    assert(is_err_result(mesh_validate(m)) == 1, "bad cidr rejected");

    # Firewall validates
    m = mesh_envoy();
    mesh_exclude_outbound_port(m, 9090);
    mesh_exclude_inbound_port(m, 15090);
    assert(is_ok(firewall_validate(mesh_to_firewall(m))) == 1, "firewall validates");

    # No exclusions
    m = mesh_envoy();
    mesh_clear_excl_out_cidrs(m);
    rendered = firewall_render(mesh_to_firewall(m));
    assert(str_contains_cstr(rendered, "meta skuid 1337") == 1, "still has uid skip");
    assert(str_contains_cstr(rendered, "redirect to :15001") == 1, "still redirects out");
    assert(str_contains_cstr(rendered, "redirect to :15006") == 1, "still redirects in");
    assert(str_contains_cstr(rendered, "skip outbound 127") == 0, "no localhost skip");

    return 0;
}

# ================================================================
# Bridge tests
# ================================================================

fn _test_bridge_config() {
    return bridge_config_new("br0", "172.17.0.0/16", "eth0");
}

fn test_bridge() {
    test_group("bridge");

    # Config validate
    assert(is_ok(bridge_config_validate(_test_bridge_config())) == 1, "good config ok");

    # Bad iface
    var cfg = bridge_config_new("evil;iface", "172.17.0.0/16", "eth0");
    assert(is_err_result(bridge_config_validate(cfg)) == 1, "bad iface rejected");

    # Custom prefix
    cfg = _test_bridge_config();
    bridge_set_table_prefix(cfg, "stiva");
    assert(streq(bridge_table_prefix(cfg), "stiva") == 1, "custom prefix");

    # PortMapping TCP
    var pm = pm_tcp(8080, "172.17.0.2", 80);
    assert_eq(pm_protocol(pm), PROTO_TCP, "pm tcp proto");
    assert(is_ok(pm_validate(pm)) == 1, "pm good validate");

    # PortMapping bad addr
    pm = pm_tcp(8080, "evil;addr", 80);
    assert(is_err_result(pm_validate(pm)) == 1, "pm bad addr rejected");

    # Add/remove port mappings
    var bf = bridge_firewall_new(_test_bridge_config());
    assert(vec_len(bf_port_mappings(bf)) == 0, "empty mappings");
    bf_add_port_mapping(bf, pm_tcp(8080, "172.17.0.2", 80));
    bf_add_port_mapping(bf, pm_tcp(8443, "172.17.0.2", 443));
    bf_add_port_mapping(bf, pm_udp(5353, "172.17.0.3", 53));
    assert(vec_len(bf_port_mappings(bf)) == 3, "three mappings");

    var removed = bf_remove_port_mapping(bf, 8080, PROTO_TCP);
    assert(is_some(removed) == 1, "remove returns Some");
    assert(vec_len(bf_port_mappings(bf)) == 2, "after removal");

    # Remove non-existent
    assert(is_none(bf_remove_port_mapping(bf, 9999, PROTO_TCP)) == 1, "remove missing None");

    # Duplicate rejected
    bf = bridge_firewall_new(_test_bridge_config());
    bf_add_port_mapping(bf, pm_tcp(8080, "172.17.0.2", 80));
    var res = bf_add_port_mapping(bf, pm_tcp(8080, "172.17.0.3", 90));
    assert(is_err_result(res) == 1, "duplicate rejected");
    # Different protocol same port: ok
    res = bf_add_port_mapping(bf, pm_udp(8080, "172.17.0.2", 80));
    assert(is_ok(res) == 1, "different proto same port ok");

    # Render no mappings no isolation
    bf = bridge_firewall_new(_test_bridge_config());
    var rendered = firewall_render(bf_to_firewall(bf));
    assert(str_contains_cstr(rendered, "table inet nein_filter") == 1, "filter table");
    assert(str_contains_cstr(rendered, "table ip nein_nat") == 1, "nat table");
    assert(str_contains_cstr(rendered, "bridge to outbound") == 1, "bridge outbound");
    assert(str_contains_cstr(rendered, "intra-bridge") == 1, "intra-bridge");
    assert(str_contains_cstr(rendered, "masquerade") == 1, "masquerade");
    assert(str_contains_cstr(rendered, "prerouting") == 0, "no prerouting");

    # Render with port mappings
    bf = bridge_firewall_new(_test_bridge_config());
    bf_add_port_mapping(bf, pm_tcp(8080, "172.17.0.2", 80));
    bf_add_port_mapping(bf, pm_udp(5353, "172.17.0.3", 53));
    rendered = firewall_render(bf_to_firewall(bf));
    assert(str_contains_cstr(rendered, "dnat to 172.17.0.2:80") == 1, "dnat 80");
    assert(str_contains_cstr(rendered, "dnat to 172.17.0.3:53") == 1, "dnat 53");
    assert(str_contains_cstr(rendered, "ip daddr 172.17.0.2") == 1, "daddr 172.17.0.2");
    assert(str_contains_cstr(rendered, "ip daddr 172.17.0.3") == 1, "daddr 172.17.0.3");

    # Render with isolation
    bf = bridge_firewall_new(_test_bridge_config());
    var front = vec_new(); vec_push(front, "172.17.1.0/24");
    bf_add_isolation_group(bf, isolation_group_new("frontend", front));
    var back = vec_new(); vec_push(back, "172.17.2.0/24");
    bf_add_isolation_group(bf, isolation_group_new("backend", back));
    rendered = firewall_render(bf_to_firewall(bf));
    assert(str_contains_cstr(rendered, "set iso_frontend") == 1, "iso set frontend");
    assert(str_contains_cstr(rendered, "set iso_backend") == 1, "iso set backend");
    assert(str_contains_cstr(rendered, "intra-group: frontend") == 1, "intra-group frontend");
    assert(str_contains_cstr(rendered, "intra-group: backend") == 1, "intra-group backend");
    assert(str_contains_cstr(rendered, "bridge to outbound") == 1, "bridge outbound w/ iso");
    assert(str_contains_cstr(rendered, "intra-bridge") == 0, "no intra-bridge with iso");

    # Validate full
    bf = bridge_firewall_new(_test_bridge_config());
    bf_add_port_mapping(bf, pm_tcp(8080, "172.17.0.2", 80));
    var web = vec_new(); vec_push(web, "172.17.1.0/24");
    bf_add_isolation_group(bf, isolation_group_new("web", web));
    assert(is_ok(bf_validate(bf)) == 1, "full bridge validates");

    # Bad group name
    bf = bridge_firewall_new(_test_bridge_config());
    var bad = vec_new(); vec_push(bad, "172.17.1.0/24");
    bf_add_isolation_group(bf, isolation_group_new("bad;name", bad));
    assert(is_err_result(bf_validate(bf)) == 1, "bad group name rejected");

    # Bad group cidr
    bf = bridge_firewall_new(_test_bridge_config());
    var badc = vec_new(); vec_push(badc, "not-a-cidr");
    bf_add_isolation_group(bf, isolation_group_new("web", badc));
    assert(is_err_result(bf_validate(bf)) == 1, "bad cidr rejected");

    # Firewall validates
    bf = bridge_firewall_new(_test_bridge_config());
    bf_add_port_mapping(bf, pm_tcp(8080, "172.17.0.2", 80));
    assert(is_ok(firewall_validate(bf_to_firewall(bf))) == 1, "generated firewall valid");

    # Custom prefix renders correctly
    cfg = _test_bridge_config();
    bridge_set_table_prefix(cfg, "stiva");
    bf = bridge_firewall_new(cfg);
    rendered = firewall_render(bf_to_firewall(bf));
    assert(str_contains_cstr(rendered, "table inet stiva_filter") == 1, "custom filter table");
    assert(str_contains_cstr(rendered, "table ip stiva_nat") == 1, "custom nat table");

    # After removal renders correctly
    bf = bridge_firewall_new(_test_bridge_config());
    bf_add_port_mapping(bf, pm_tcp(8080, "172.17.0.2", 80));
    bf_add_port_mapping(bf, pm_tcp(8443, "172.17.0.2", 443));
    bf_remove_port_mapping(bf, 8080, PROTO_TCP);
    rendered = firewall_render(bf_to_firewall(bf));
    assert(str_contains_cstr(rendered, "dnat to 172.17.0.2:80") == 0, "removed dnat gone");
    assert(str_contains_cstr(rendered, "dnat to 172.17.0.2:443") == 1, "kept dnat present");

    # Empty isolation group
    bf = bridge_firewall_new(_test_bridge_config());
    bf_add_isolation_group(bf, isolation_group_new("empty", vec_new()));
    rendered = firewall_render(bf_to_firewall(bf));
    assert(str_contains_cstr(rendered, "bridge to outbound") == 1, "outbound with empty");
    assert(str_contains_cstr(rendered, "intra-group") == 0, "no intra-group for empty");

    # Multi-cidr isolation: one set with both
    bf = bridge_firewall_new(_test_bridge_config());
    var multi = vec_new();
    vec_push(multi, "172.17.1.0/24");
    vec_push(multi, "172.17.2.0/24");
    bf_add_isolation_group(bf, isolation_group_new("web", multi));
    rendered = firewall_render(bf_to_firewall(bf));
    assert(str_contains_cstr(rendered, "set iso_web") == 1, "multi-cidr set");
    assert(str_contains_cstr(rendered, "172.17.1.0/24, 172.17.2.0/24") == 1, "both cidrs in set");
    assert(str_contains_cstr(rendered, "ip saddr @iso_web") == 1, "saddr lookup");
    assert(str_contains_cstr(rendered, "ip daddr @iso_web") == 1, "daddr lookup");

    # Isolation + port mappings combined
    bf = bridge_firewall_new(_test_bridge_config());
    bf_add_port_mapping(bf, pm_tcp(8080, "172.17.1.5", 80));
    var iso_web = vec_new(); vec_push(iso_web, "172.17.1.0/24");
    bf_add_isolation_group(bf, isolation_group_new("web", iso_web));
    rendered = firewall_render(bf_to_firewall(bf));
    assert(str_contains_cstr(rendered, "allow portmap -> 172.17.1.5:80") == 1, "portmap forward");
    assert(str_contains_cstr(rendered, "intra-group: web") == 1, "iso web with pm");
    assert(str_contains_cstr(rendered, "dnat to 172.17.1.5:80") == 1, "pm dnat");

    return 0;
}

# ================================================================
# Engine tests
# ================================================================

fn test_engine() {
    test_group("engine");

    # Empty engine
    var e = policy_engine_new();
    assert_eq(pe_agent_count(e), 0, "empty count");
    assert(str_len(firewall_render(pe_to_firewall(e))) == 0, "empty render");

    # Add/remove agent
    e = policy_engine_new();
    assert(is_none(pe_add_agent(e, agent_policy_new("agent-1", "10.100.0.2"))) == 1, "add returns None");
    assert_eq(pe_agent_count(e), 1, "count after add");
    assert(is_some(pe_get_agent(e, "agent-1")) == 1, "get after add");
    var removed = pe_remove_agent(e, "agent-1");
    assert(is_some(removed) == 1, "remove returns Some");
    assert_eq(pe_agent_count(e), 0, "count after remove");

    # Update agent: second add returns Some(prev)
    e = policy_engine_new();
    pe_add_agent(e, agent_policy_new("agent-1", "10.100.0.2"));
    var prev = pe_add_agent(e, agent_policy_new("agent-1", "10.100.0.3"));
    assert(is_some(prev) == 1, "update returns Some");
    var curr = pe_get_agent(e, "agent-1");
    assert(is_some(curr) == 1, "updated agent present");
    assert(streq(ap_agent_addr(unwrap(curr)), "10.100.0.3") == 1, "new addr");

    # Remove nonexistent
    assert(is_none(pe_remove_agent(e, "ghost")) == 1, "remove ghost None");

    # Single agent default deny
    e = policy_engine_new();
    pe_add_agent(e, agent_policy_new("agent-1", "10.100.0.2"));
    var rendered = firewall_render(pe_to_firewall(e));
    assert(str_contains_cstr(rendered, "table inet nein_agents") == 1, "engine table");
    assert(str_contains_cstr(rendered, "chain agent-1_in") == 1, "in chain");
    assert(str_contains_cstr(rendered, "chain agent-1_out") == 1, "out chain");
    assert(str_contains_cstr(rendered, "dispatch inbound to agent-1") == 1, "dispatch in");
    assert(str_contains_cstr(rendered, "dispatch outbound from agent-1") == 1, "dispatch out");
    assert(str_contains_cstr(rendered, "default deny inbound") == 1, "default deny in");
    assert(str_contains_cstr(rendered, "default deny outbound") == 1, "default deny out");
    assert(str_contains_cstr(rendered, "ct state { established, related }") == 1, "established by default");
    assert(str_contains_cstr(rendered, "iif \"lo\"") == 1, "loopback by default");

    # Agent with inbound ports
    e = policy_engine_new();
    var p = agent_policy_new("web", "10.100.1.2");
    ap_allow_inbound(p, ps_tcp(80));
    ap_allow_inbound(p, ps_tcp(443));
    pe_add_agent(e, p);
    rendered = firewall_render(pe_to_firewall(e));
    assert(str_contains_cstr(rendered, "web inbound tcp:80") == 1, "web tcp:80");
    assert(str_contains_cstr(rendered, "web inbound tcp:443") == 1, "web tcp:443");
    assert(str_contains_cstr(rendered, "dport 80") == 1, "dport 80");
    assert(str_contains_cstr(rendered, "dport 443") == 1, "dport 443");

    # Agent with outbound ports
    e = policy_engine_new();
    p = agent_policy_new("worker", "10.100.1.3");
    ap_allow_outbound(p, ps_tcp(443));
    ap_allow_outbound(p, ps_udp(53));
    pe_add_agent(e, p);
    rendered = firewall_render(pe_to_firewall(e));
    assert(str_contains_cstr(rendered, "worker outbound tcp:443") == 1, "worker tcp:443 out");
    assert(str_contains_cstr(rendered, "worker outbound udp:53") == 1, "worker udp:53 out");

    # QUIC port spec — protocol=UDP but label=quic
    e = policy_engine_new();
    p = agent_policy_new("quic_agent", "10.100.2.1");
    ap_allow_outbound(p, ps_quic(443));
    pe_add_agent(e, p);
    rendered = firewall_render(pe_to_firewall(e));
    assert(str_contains_cstr(rendered, "quic_agent outbound quic:443") == 1, "quic label");
    assert(str_contains_cstr(rendered, "udp dport 443") == 1, "quic renders as udp");

    # Outbound host restrictions: O(1) set lookup
    e = policy_engine_new();
    p = agent_policy_new("restricted", "10.100.3.1");
    ap_allow_outbound(p, ps_tcp(443));
    ap_allow_outbound_host(p, "10.0.0.0/8");
    ap_allow_outbound_host(p, "192.168.0.0/16");
    pe_add_agent(e, p);
    rendered = firewall_render(pe_to_firewall(e));
    assert(str_contains_cstr(rendered, "set restricted_hosts") == 1, "host set");
    assert(str_contains_cstr(rendered, "10.0.0.0/8, 192.168.0.0/16") == 1, "host cidrs");
    assert(str_contains_cstr(rendered, "ip daddr @restricted_hosts") == 1, "set lookup");
    assert(str_contains_cstr(rendered, "restricted outbound tcp:443 restricted") == 1, "restricted comment");

    # Validate good
    e = policy_engine_new();
    pe_add_agent(e, agent_policy_new("a", "10.0.0.1"));
    assert(is_ok(pe_validate(e)) == 1, "good engine ok");
    assert(is_ok(firewall_validate(pe_to_firewall(e))) == 1, "engine fw valid");

    # Validate bad agent id
    e = policy_engine_new();
    pe_add_agent(e, agent_policy_new("bad;id", "10.0.0.1"));
    assert(is_err_result(pe_validate(e)) == 1, "bad agent id rejected");

    # Validate bad addr
    e = policy_engine_new();
    pe_add_agent(e, agent_policy_new("a", "evil;addr"));
    assert(is_err_result(pe_validate(e)) == 1, "bad addr rejected");

    # Validate bad outbound host
    e = policy_engine_new();
    p = agent_policy_new("a", "10.0.0.1");
    ap_allow_outbound_host(p, "evil;host");
    pe_add_agent(e, p);
    assert(is_err_result(pe_validate(e)) == 1, "bad outbound host rejected");

    # Bad table name
    e = policy_engine_new();
    pe_set_table_name(e, "bad;table");
    assert(is_err_result(pe_validate(e)) == 1, "bad table name rejected");

    # Custom table name
    e = policy_engine_new();
    pe_set_table_name(e, "daimon_agents");
    pe_add_agent(e, agent_policy_new("a", "10.0.0.1"));
    rendered = firewall_render(pe_to_firewall(e));
    assert(str_contains_cstr(rendered, "table inet daimon_agents") == 1, "custom table");

    # Disable established/loopback
    e = policy_engine_new();
    p = agent_policy_new("strict", "10.0.0.1");
    ap_set_allow_established(p, 0);
    ap_set_allow_loopback(p, 0);
    pe_add_agent(e, p);
    rendered = firewall_render(pe_to_firewall(e));
    assert(str_contains_cstr(rendered, "ct state") == 0, "no established");
    assert(str_contains_cstr(rendered, "iif \"lo\"") == 0, "no loopback");

    # Multiple agents sorted
    e = policy_engine_new();
    pe_add_agent(e, agent_policy_new("zebra", "10.0.0.3"));
    pe_add_agent(e, agent_policy_new("alpha", "10.0.0.1"));
    pe_add_agent(e, agent_policy_new("mike", "10.0.0.2"));
    assert_eq(pe_agent_count(e), 3, "three agents");
    rendered = firewall_render(pe_to_firewall(e));
    # alpha should appear before mike should appear before zebra
    var alpha_pos = str_index_of_cstr(rendered, "chain alpha_in");
    var mike_pos = str_index_of_cstr(rendered, "chain mike_in");
    var zebra_pos = str_index_of_cstr(rendered, "chain zebra_in");
    assert(alpha_pos >= 0, "alpha present");
    assert(alpha_pos < mike_pos, "alpha before mike");
    assert(mike_pos < zebra_pos, "mike before zebra");

    return 0;
}

# ================================================================
# Config tests
# ================================================================

fn test_config() {
    test_group("config");

    # Family
    assert_eq(cfg_parse_family("inet"), FAMILY_INET, "family inet");
    assert_eq(cfg_parse_family("ip"), FAMILY_IP, "family ip");
    assert_eq(cfg_parse_family("ip6"), FAMILY_IP6, "family ip6");
    assert_eq(cfg_parse_family("arp"), FAMILY_ARP, "family arp");
    assert_eq(cfg_parse_family("bridge"), FAMILY_BRIDGE, "family bridge");
    assert_eq(cfg_parse_family("netdev"), FAMILY_NETDEV, "family netdev");
    assert(cfg_parse_family("unknown") < 0, "unknown family");
    assert(cfg_parse_family("") < 0, "empty family");

    # ChainType
    assert_eq(cfg_parse_chain_type("filter"), CHAIN_FILTER, "chain_type filter");
    assert_eq(cfg_parse_chain_type("nat"), CHAIN_NAT, "chain_type nat");
    assert_eq(cfg_parse_chain_type("route"), CHAIN_ROUTE, "chain_type route");
    assert(cfg_parse_chain_type("bogus") < 0, "unknown chain_type");

    # Hook
    assert_eq(cfg_parse_hook("prerouting"), HOOK_PREROUTING, "hook prerouting");
    assert_eq(cfg_parse_hook("input"), HOOK_INPUT, "hook input");
    assert_eq(cfg_parse_hook("forward"), HOOK_FORWARD, "hook forward");
    assert_eq(cfg_parse_hook("output"), HOOK_OUTPUT, "hook output");
    assert_eq(cfg_parse_hook("postrouting"), HOOK_POSTROUTING, "hook postrouting");
    assert_eq(cfg_parse_hook("ingress"), HOOK_INGRESS, "hook ingress");
    assert(cfg_parse_hook("other") < 0, "unknown hook");

    # Policy
    assert_eq(cfg_parse_policy("accept"), POLICY_ACCEPT, "policy accept");
    assert_eq(cfg_parse_policy("drop"), POLICY_DROP, "policy drop");
    assert(cfg_parse_policy("reject") < 0, "unknown policy");

    # Protocol
    assert_eq(cfg_parse_protocol("tcp"), PROTO_TCP, "proto tcp");
    assert_eq(cfg_parse_protocol("udp"), PROTO_UDP, "proto udp");
    assert_eq(cfg_parse_protocol("icmp"), PROTO_ICMP, "proto icmp");
    assert_eq(cfg_parse_protocol("icmpv6"), PROTO_ICMPV6, "proto icmpv6");
    assert(cfg_parse_protocol("sctp") < 0, "unknown proto");

    # RateUnit
    assert_eq(cfg_parse_rate_unit("second"), RATE_SECOND, "rate second");
    assert_eq(cfg_parse_rate_unit("minute"), RATE_MINUTE, "rate minute");
    assert_eq(cfg_parse_rate_unit("hour"), RATE_HOUR, "rate hour");
    assert_eq(cfg_parse_rate_unit("day"), RATE_DAY, "rate day");
    assert(cfg_parse_rate_unit("week") < 0, "unknown rate");

    # QuotaMode / QuotaUnit
    assert_eq(cfg_parse_quota_mode("over"), QUOTA_OVER, "quota over");
    assert_eq(cfg_parse_quota_mode("until"), QUOTA_UNTIL, "quota until");
    assert_eq(cfg_parse_quota_unit("bytes"), QUNIT_BYTES, "quota bytes");
    assert_eq(cfg_parse_quota_unit("kbytes"), QUNIT_KBYTES, "quota kbytes");
    assert_eq(cfg_parse_quota_unit("mbytes"), QUNIT_MBYTES, "quota mbytes");
    assert_eq(cfg_parse_quota_unit("gbytes"), QUNIT_GBYTES, "quota gbytes");

    # PktType
    assert_eq(cfg_parse_pkt_type("unicast"), PKT_UNICAST, "pkt unicast");
    assert_eq(cfg_parse_pkt_type("broadcast"), PKT_BROADCAST, "pkt broadcast");
    assert_eq(cfg_parse_pkt_type("multicast"), PKT_MULTICAST, "pkt multicast");

    # IPv6ExtHdr
    assert_eq(cfg_parse_ipv6_ext_hdr("hbh"), EXT_HOP_BY_HOP, "ext hbh");
    assert_eq(cfg_parse_ipv6_ext_hdr("rt"), EXT_ROUTING, "ext rt");
    assert_eq(cfg_parse_ipv6_ext_hdr("frag"), EXT_FRAGMENT, "ext frag");
    assert_eq(cfg_parse_ipv6_ext_hdr("dst"), EXT_DESTINATION, "ext dst");
    assert_eq(cfg_parse_ipv6_ext_hdr("mh"), EXT_MOBILITY, "ext mh");
    assert_eq(cfg_parse_ipv6_ext_hdr("auth"), EXT_AUTH, "ext auth");

    # CmpOp
    assert_eq(cfg_parse_cmp_op("=="), NFT_CMP_EQ, "cmp eq");
    assert_eq(cfg_parse_cmp_op("!="), NFT_CMP_NE, "cmp ne");
    assert_eq(cfg_parse_cmp_op("<"), NFT_CMP_LT, "cmp lt");
    assert_eq(cfg_parse_cmp_op(">"), NFT_CMP_GT, "cmp gt");
    assert_eq(cfg_parse_cmp_op("<="), NFT_CMP_LE, "cmp le");
    assert_eq(cfg_parse_cmp_op(">="), NFT_CMP_GE, "cmp ge");

    # LogLevel
    assert_eq(cfg_parse_log_level("emerg"), NFT_LOG_EMERG, "log emerg");
    assert_eq(cfg_parse_log_level("alert"), NFT_LOG_ALERT, "log alert");
    assert_eq(cfg_parse_log_level("crit"), NFT_LOG_CRIT, "log crit");
    assert_eq(cfg_parse_log_level("err"), NFT_LOG_ERR, "log err");
    assert_eq(cfg_parse_log_level("warn"), NFT_LOG_WARN, "log warn");
    assert_eq(cfg_parse_log_level("notice"), NFT_LOG_NOTICE, "log notice");
    assert_eq(cfg_parse_log_level("info"), NFT_LOG_INFO, "log info");
    assert_eq(cfg_parse_log_level("debug"), NFT_LOG_DEBUG, "log debug");

    # RejectReason
    assert_eq(cfg_parse_reject_reason("icmp-host-unreachable"), REJECT_ICMP_HOST_UNREACH, "reject icmp host");
    assert_eq(cfg_parse_reject_reason("icmp-port-unreachable"), REJECT_ICMP_PORT_UNREACH, "reject icmp port");
    assert_eq(cfg_parse_reject_reason("icmp-net-unreachable"), REJECT_ICMP_NET_UNREACH, "reject icmp net");
    assert_eq(cfg_parse_reject_reason("icmp-admin-prohibited"), REJECT_ICMP_ADMIN_PROHIB, "reject icmp admin");
    assert_eq(cfg_parse_reject_reason("icmpx-admin-prohibited"), REJECT_ICMPX_ADMIN_PROHIB, "reject icmpx admin");
    assert_eq(cfg_parse_reject_reason("tcp-reset"), REJECT_TCP_RESET, "reject tcp reset");
    assert(cfg_parse_reject_reason("bogus") < 0, "unknown reject reason");

    # SetType
    assert_eq(cfg_parse_set_type("ipv4_addr"), SET_IPV4_ADDR, "set ipv4");
    assert_eq(cfg_parse_set_type("ipv6_addr"), SET_IPV6_ADDR, "set ipv6");
    assert_eq(cfg_parse_set_type("inet_service"), SET_INET_SERVICE, "set inet_service");
    assert_eq(cfg_parse_set_type("inet_proto"), SET_INET_PROTO, "set inet_proto");
    assert_eq(cfg_parse_set_type("ifname"), SET_IFNAME, "set ifname");

    # SetFlag
    assert_eq(cfg_parse_set_flag("constant"), SETFLAG_CONSTANT, "setflag constant");
    assert_eq(cfg_parse_set_flag("interval"), SETFLAG_INTERVAL, "setflag interval");
    assert_eq(cfg_parse_set_flag("timeout"), SETFLAG_TIMEOUT, "setflag timeout");

    # Transport
    assert_eq(cfg_parse_transport("tcp"), TRANS_TCP, "trans tcp");
    assert_eq(cfg_parse_transport("udp"), TRANS_UDP, "trans udp");
    assert_eq(cfg_parse_transport("quic"), TRANS_QUIC, "trans quic");

    # cfg_result wrapper
    var r = cfg_result(FAMILY_INET);
    assert(is_ok(r) == 1, "cfg_result wraps Ok");
    assert_eq(payload(r), FAMILY_INET, "cfg_result payload");
    r = cfg_result(0 - 1);
    assert(is_err_result(r) == 1, "cfg_result wraps Err on -1");
    assert_eq(err_code(r), ERR_PARSE, "cfg_result Err has ERR_PARSE");

    return 0;
}

# ================================================================
# Netns tests
# ================================================================

fn test_netns() {
    test_group("netns");

    # Default build
    var nsf = namespace_firewall_new("test-agent");
    var fw = nsf_build(nsf);
    var rendered = firewall_render(fw);
    assert(str_contains_cstr(rendered, "table inet agnos_agent") == 1, "nsf table");
    assert(str_contains_cstr(rendered, "chain input") == 1, "nsf input chain");
    assert(str_contains_cstr(rendered, "chain output") == 1, "nsf output chain");
    assert(str_contains_cstr(rendered, "policy drop") == 1, "default inbound drop");
    assert(str_contains_cstr(rendered, "policy accept") == 1, "default outbound accept");
    assert(str_contains_cstr(rendered, "ct state { established, related }") == 1, "established");
    assert(str_contains_cstr(rendered, "iif \"lo\"") == 1, "loopback in");
    assert(str_contains_cstr(rendered, "oif \"lo\"") == 1, "loopback out");
    assert(str_contains_cstr(rendered, "dport 53") == 1, "dns");
    assert(str_contains_cstr(rendered, "test-agent dns") == 1, "dns comment");

    # Default validates
    assert(is_ok(firewall_validate(nsf_build(namespace_firewall_new("test-agent")))) == 1, "default nsf validates");

    # Inbound ports
    nsf = namespace_firewall_new("test-agent");
    nsf_allow_inbound(nsf, ps_tcp(8080));
    nsf_allow_inbound(nsf, ps_tcp(443));
    rendered = firewall_render(nsf_build(nsf));
    assert(str_contains_cstr(rendered, "dport 8080") == 1, "inbound 8080");
    assert(str_contains_cstr(rendered, "dport 443") == 1, "inbound 443");
    assert(str_contains_cstr(rendered, "test-agent inbound tcp:8080") == 1, "inbound tcp:8080 comment");
    assert(str_contains_cstr(rendered, "test-agent inbound tcp:443") == 1, "inbound tcp:443 comment");

    # Outbound ports
    nsf = namespace_firewall_new("test-agent");
    nsf_allow_outbound(nsf, ps_tcp(443));
    nsf_allow_outbound(nsf, ps_udp(123));
    rendered = firewall_render(nsf_build(nsf));
    assert(str_contains_cstr(rendered, "test-agent outbound tcp:443") == 1, "outbound tcp:443");
    assert(str_contains_cstr(rendered, "test-agent outbound udp:123") == 1, "outbound udp:123");

    # Outbound host restriction — one rule per (port, host)
    nsf = namespace_firewall_new("test-agent");
    nsf_allow_outbound(nsf, ps_tcp(443));
    nsf_allow_outbound_host(nsf, "1.2.3.0/24");
    nsf_allow_outbound_host(nsf, "4.5.6.0/24");
    rendered = firewall_render(nsf_build(nsf));
    assert(str_contains_cstr(rendered, "ip daddr 1.2.3.0/24") == 1, "daddr 1.2.3");
    assert(str_contains_cstr(rendered, "ip daddr 4.5.6.0/24") == 1, "daddr 4.5.6");
    assert(str_contains_cstr(rendered, "tcp:443 -> 1.2.3.0/24") == 1, "host comment 1");
    assert(str_contains_cstr(rendered, "tcp:443 -> 4.5.6.0/24") == 1, "host comment 2");

    # no_established / no_loopback / no_dns
    nsf = namespace_firewall_new("strict");
    nsf_no_established(nsf);
    nsf_no_loopback(nsf);
    nsf_no_dns(nsf);
    rendered = firewall_render(nsf_build(nsf));
    assert(str_contains_cstr(rendered, "ct state") == 0, "no established");
    assert(str_contains_cstr(rendered, "\"lo\"") == 0, "no loopback");
    assert(str_contains_cstr(rendered, "dport 53") == 0, "no dns");

    # Custom policies
    nsf = namespace_firewall_new("locked");
    nsf_set_inbound_policy(nsf, POLICY_DROP);
    nsf_set_outbound_policy(nsf, POLICY_DROP);
    rendered = firewall_render(nsf_build(nsf));
    # Both chains should have policy drop
    var dp_count = 0;
    var pos = 0;
    # Check both "policy drop" present (we know 2 should exist)
    assert(str_contains_cstr(rendered, "hook input priority 0; policy drop") == 1, "in drop");
    assert(str_contains_cstr(rendered, "hook output priority 0; policy drop") == 1, "out drop");

    return 0;
}

# ================================================================
# Inspect parse tests (pure function — no nft subprocess needed)
# ================================================================

# Build a Str from a cstr literal for _parse_ruleset
fn _cstr_to_str(c) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, c);
    return str_builder_build(sb);
}

fn test_inspect_parse() {
    test_group("inspect_parse");

    # Empty ruleset
    var tables = vec_new();
    var count = _parse_ruleset(_cstr_to_str(""), tables);
    assert_eq(count, 0, "empty ruleset: 0 rules");
    assert_eq(vec_len(tables), 0, "empty ruleset: 0 tables");

    # Single table, single chain, two rules
    var raw = "table inet filter {\n  chain input {\n    type filter hook input priority 0; policy drop;\n    ct state { established, related } accept\n    tcp dport 22 accept\n  }\n}\n";
    tables = vec_new();
    count = _parse_ruleset(_cstr_to_str(raw), tables);
    # "type" line is not counted; "ct state ..." and "tcp dport 22" are rules
    # policy line contains "type ... policy drop;" — starts with "type" so excluded
    assert_eq(count, 2, "two rules counted");
    assert_eq(vec_len(tables), 1, "one table");
    assert(streq(vec_get(tables, 0), "table inet filter") == 1, "table header captured");

    # Multiple tables
    raw = "table inet filter {\n  chain input {\n    tcp dport 22 accept\n  }\n}\ntable ip nat {\n  chain postrouting {\n    masquerade\n  }\n}\n";
    tables = vec_new();
    count = _parse_ruleset(_cstr_to_str(raw), tables);
    assert_eq(count, 2, "two tables: two rules");
    assert_eq(vec_len(tables), 2, "two tables");
    assert(streq(vec_get(tables, 0), "table inet filter") == 1, "first table");
    assert(streq(vec_get(tables, 1), "table ip nat") == 1, "second table");

    # Closing brace and chain/type lines don't count as rules
    raw = "table inet t {\n  chain c {\n    type filter hook input priority 0; policy drop;\n  }\n}\n";
    tables = vec_new();
    count = _parse_ruleset(_cstr_to_str(raw), tables);
    assert_eq(count, 0, "header-only ruleset: 0 rules");
    assert_eq(vec_len(tables), 1, "one table still");

    # FirewallStatus struct
    var s = firewall_status_new(vec_new(), 0, _cstr_to_str(""));
    assert(vec_len(status_tables(s)) == 0, "status tables empty");
    assert_eq(status_total_rules(s), 0, "status rules 0");

    return 0;
}

