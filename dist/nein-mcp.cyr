# ================================================================
# Verdict struct — { type, val1, val2, val3, val4 }
# Layout: [type:8][val1:8][val2:8][val3:8][val4:8] = 40 bytes
# ================================================================

fn verdict_new(vtype: i64, v1: i64, v2: i64, v3: i64, v4: i64): i64 {
    var v = alloc(40);
    store64(v, vtype);
    store64(v + 8, v1);
    store64(v + 16, v2);
    store64(v + 24, v3);
    store64(v + 32, v4);
    return v;
}

fn verdict_type(v: i64): i64 { return load64(v); }
fn verdict_val1(v: i64): i64 { return load64(v + 8); }
fn verdict_val2(v: i64): i64 { return load64(v + 16); }
fn verdict_val3(v: i64): i64 { return load64(v + 24); }
fn verdict_val4(v: i64): i64 { return load64(v + 32); }

# Verdict constructors
fn verdict_accept(): i64 { return verdict_new(VERDICT_ACCEPT, 0, 0, 0, 0); }
fn verdict_drop(): i64 { return verdict_new(VERDICT_DROP, 0, 0, 0, 0); }
fn verdict_reject(): i64 { return verdict_new(VERDICT_REJECT, 0, 0, 0, 0); }
fn verdict_reject_with(reason: i64): i64 { return verdict_new(VERDICT_REJECT_WITH, reason, 0, 0, 0); }
fn verdict_jump(chain: cstring): i64 { return verdict_new(VERDICT_JUMP, chain, 0, 0, 0); }
fn verdict_goto(chain: cstring): i64 { return verdict_new(VERDICT_GOTO, chain, 0, 0, 0); }
fn verdict_return(): i64 { return verdict_new(VERDICT_RETURN, 0, 0, 0, 0); }
fn verdict_log(prefix: cstring): i64 { return verdict_new(VERDICT_LOG, prefix, 0, 0, 0); }
fn verdict_counter(): i64 { return verdict_new(VERDICT_COUNTER, 0, 0, 0, 0); }
fn verdict_set_mark(val: i64): i64 { return verdict_new(VERDICT_SET_MARK, val, 0, 0, 0); }
fn verdict_set_ct_mark(val: i64): i64 { return verdict_new(VERDICT_SET_CT_MARK, val, 0, 0, 0); }
fn verdict_log_advanced(prefix: cstring, level: i64, group: i64, snaplen: i64): i64 {
    return verdict_new(VERDICT_LOG_ADVANCED, prefix, level, group, snaplen);
}
fn verdict_counter_named(name: cstring): i64 { return verdict_new(VERDICT_COUNTER_NAMED, name, 0, 0, 0); }

# ================================================================
# Rule struct — { verdict, matches (vec), comment }
# Layout: [verdict:8][matches:8][comment:8] = 24 bytes
# ================================================================

fn rule_new(verdict: i64): i64 {
    var r = alloc(24);
    store64(r, verdict);
    store64(r + 8, vec_new());
    store64(r + 16, 0);
    return r;
}

fn rule_verdict(r: i64): i64 { return load64(r); }
fn rule_matches(r: i64): i64 { return load64(r + 8); }
fn rule_comment(r: i64): i64 { return load64(r + 16); }

fn rule_add_match(r: i64, m: i64): i64 {
    vec_push(load64(r + 8), m);
    return r;
}

fn rule_set_comment(r: i64, c: cstring): i64 {
    store64(r + 16, c);
    return r;
}

# ================================================================
# Hex rendering helper (stdlib lacks _sb_add_hex)
# ================================================================

fn _sb_add_hex(sb, val) {
    if (val == 0) {
        str_builder_add_cstr(sb, "0");
        return 0;
    }
    var buf[20];
    var pos = 19;
    store8(&buf + pos, 0);
    var n = val;
    while (n > 0) {
        pos = pos - 1;
        var digit = n & 15;
        if (digit < 10) {
            store8(&buf + pos, 48 + digit);
        } else {
            store8(&buf + pos, 97 + digit - 10);
        }
        n = n >> 4;
    }
    str_builder_add_cstr(sb, &buf + pos);
    return 0;
}

# ================================================================
# Render — match to nftables string
# ================================================================

fn _render_match(sb, m) {
    var mt = match_type(m);
    var v1 = match_val1(m);
    var v2 = match_val2(m);
    var v3 = match_val3(m);

    if (mt == MATCH_SOURCE_ADDR) {
        str_builder_add_cstr(sb, "ip saddr ");
        str_builder_add_cstr(sb, v1);
    } elif (mt == MATCH_DEST_ADDR) {
        str_builder_add_cstr(sb, "ip daddr ");
        str_builder_add_cstr(sb, v1);
    } elif (mt == MATCH_SOURCE_ADDR6) {
        str_builder_add_cstr(sb, "ip6 saddr ");
        str_builder_add_cstr(sb, v1);
    } elif (mt == MATCH_DEST_ADDR6) {
        str_builder_add_cstr(sb, "ip6 daddr ");
        str_builder_add_cstr(sb, v1);
    } elif (mt == MATCH_PROTOCOL) {
        str_builder_add_cstr(sb, _proto_str(v1));
    } elif (mt == MATCH_DPORT) {
        str_builder_add_cstr(sb, "dport ");
        str_builder_add_int(sb, v1);
    } elif (mt == MATCH_SPORT) {
        str_builder_add_cstr(sb, "sport ");
        str_builder_add_int(sb, v1);
    } elif (mt == MATCH_DPORT_RANGE) {
        str_builder_add_cstr(sb, "dport ");
        str_builder_add_int(sb, v1);
        str_builder_add_cstr(sb, "-");
        str_builder_add_int(sb, v2);
    } elif (mt == MATCH_IIF) {
        str_builder_add_cstr(sb, "iif \"");
        str_builder_add_cstr(sb, v1);
        str_builder_add_cstr(sb, "\"");
    } elif (mt == MATCH_OIF) {
        str_builder_add_cstr(sb, "oif \"");
        str_builder_add_cstr(sb, v1);
        str_builder_add_cstr(sb, "\"");
    } elif (mt == MATCH_CT_STATE) {
        str_builder_add_cstr(sb, "ct state { ");
        str_builder_add_cstr(sb, v1);
        str_builder_add_cstr(sb, " }");
    } elif (mt == MATCH_LIMIT) {
        str_builder_add_cstr(sb, "limit rate ");
        str_builder_add_int(sb, v1);
        str_builder_add_cstr(sb, "/");
        str_builder_add_cstr(sb, _rate_unit_str(v2));
        str_builder_add_cstr(sb, " burst ");
        str_builder_add_int(sb, v3);
        str_builder_add_cstr(sb, " packets");
    } elif (mt == MATCH_SET_LOOKUP) {
        str_builder_add_cstr(sb, v1);
        str_builder_add_cstr(sb, " @");
        str_builder_add_cstr(sb, v2);
    } elif (mt == MATCH_CT_HELPER) {
        str_builder_add_cstr(sb, "ct helper \"");
        str_builder_add_cstr(sb, v1);
        str_builder_add_cstr(sb, "\"");
    } elif (mt == MATCH_TCP_FLAGS) {
        str_builder_add_cstr(sb, "tcp flags { ");
        str_builder_add_cstr(sb, v1);
        str_builder_add_cstr(sb, " }");
    } elif (mt == MATCH_ICMP_TYPE) {
        str_builder_add_cstr(sb, "icmp type ");
        str_builder_add_cstr(sb, v1);
    } elif (mt == MATCH_ICMPV6_TYPE) {
        str_builder_add_cstr(sb, "icmpv6 type ");
        str_builder_add_cstr(sb, v1);
    } elif (mt == MATCH_META_MARK) {
        str_builder_add_cstr(sb, "meta mark ");
        str_builder_add_int(sb, v1);
    } elif (mt == MATCH_QUOTA) {
        str_builder_add_cstr(sb, "quota ");
        str_builder_add_cstr(sb, _quota_mode_str(v1));
        str_builder_add_cstr(sb, " ");
        str_builder_add_int(sb, v2);
        str_builder_add_cstr(sb, " ");
        str_builder_add_cstr(sb, _quota_unit_str(v3));
    } elif (mt == MATCH_FLOW_OFFLOAD) {
        str_builder_add_cstr(sb, "flow offload @");
        str_builder_add_cstr(sb, v1);
    } elif (mt == MATCH_CT_TIMEOUT_SET) {
        str_builder_add_cstr(sb, "ct timeout set \"");
        str_builder_add_cstr(sb, v1);
        str_builder_add_cstr(sb, "\"");
    } elif (mt == MATCH_ICMP_TYPE_CODE) {
        str_builder_add_cstr(sb, "icmp type ");
        str_builder_add_cstr(sb, v1);
        str_builder_add_cstr(sb, " icmp code ");
        str_builder_add_int(sb, v2);
    } elif (mt == MATCH_ICMPV6_TYPE_CODE) {
        str_builder_add_cstr(sb, "icmpv6 type ");
        str_builder_add_cstr(sb, v1);
        str_builder_add_cstr(sb, " icmpv6 code ");
        str_builder_add_int(sb, v2);
    } elif (mt == MATCH_VLAN_ID) {
        str_builder_add_cstr(sb, "vlan id ");
        str_builder_add_int(sb, v1);
    } elif (mt == MATCH_DSCP) {
        str_builder_add_cstr(sb, "ip dscp ");
        str_builder_add_int(sb, v1);
    } elif (mt == MATCH_IPV6_EXT_HDR) {
        str_builder_add_cstr(sb, "exthdr ");
        str_builder_add_cstr(sb, _ipv6_ext_hdr_str(v1));
        str_builder_add_cstr(sb, " exists");
    } elif (mt == MATCH_FRAG_OFF) {
        str_builder_add_cstr(sb, "ip frag-off & 0x");
        _sb_add_hex(sb, v1);
        str_builder_add_cstr(sb, " ");
        str_builder_add_cstr(sb, _cmp_op_str(v2));
        str_builder_add_cstr(sb, " 0x");
        _sb_add_hex(sb, v3);
    } elif (mt == MATCH_PKT_TYPE) {
        str_builder_add_cstr(sb, "meta pkttype ");
        str_builder_add_cstr(sb, _pkt_type_str(v1));
    } elif (mt == MATCH_CONN_LIMIT) {
        str_builder_add_cstr(sb, "ct count over ");
        str_builder_add_int(sb, v1);
    } elif (mt == MATCH_RAW) {
        str_builder_add_cstr(sb, v1);
    }
    return 0;
}

fn _render_verdict(sb, v) {
    var vt = verdict_type(v);
    var v1 = verdict_val1(v);
    var v2 = verdict_val2(v);
    var v3 = verdict_val3(v);
    var v4 = verdict_val4(v);

    if (vt == VERDICT_ACCEPT) {
        str_builder_add_cstr(sb, "accept");
    } elif (vt == VERDICT_DROP) {
        str_builder_add_cstr(sb, "drop");
    } elif (vt == VERDICT_REJECT) {
        str_builder_add_cstr(sb, "reject");
    } elif (vt == VERDICT_REJECT_WITH) {
        str_builder_add_cstr(sb, "reject with ");
        str_builder_add_cstr(sb, _reject_reason_str(v1));
    } elif (vt == VERDICT_JUMP) {
        str_builder_add_cstr(sb, "jump ");
        str_builder_add_cstr(sb, v1);
    } elif (vt == VERDICT_GOTO) {
        str_builder_add_cstr(sb, "goto ");
        str_builder_add_cstr(sb, v1);
    } elif (vt == VERDICT_RETURN) {
        str_builder_add_cstr(sb, "return");
    } elif (vt == VERDICT_LOG) {
        str_builder_add_cstr(sb, "log");
        if (v1 != 0) {
            str_builder_add_cstr(sb, " prefix \"");
            str_builder_add_cstr(sb, v1);
            str_builder_add_cstr(sb, "\"");
        }
    } elif (vt == VERDICT_COUNTER) {
        str_builder_add_cstr(sb, "counter");
    } elif (vt == VERDICT_SET_MARK) {
        str_builder_add_cstr(sb, "meta mark set ");
        str_builder_add_int(sb, v1);
    } elif (vt == VERDICT_SET_CT_MARK) {
        str_builder_add_cstr(sb, "ct mark set ");
        str_builder_add_int(sb, v1);
    } elif (vt == VERDICT_LOG_ADVANCED) {
        str_builder_add_cstr(sb, "log");
        if (v1 != 0) {
            str_builder_add_cstr(sb, " prefix \"");
            str_builder_add_cstr(sb, v1);
            str_builder_add_cstr(sb, "\"");
        }
        if (v2 != 0) {
            str_builder_add_cstr(sb, " level ");
            str_builder_add_cstr(sb, _log_level_str(v2));
        }
        if (v3 != 0) {
            str_builder_add_cstr(sb, " group ");
            str_builder_add_int(sb, v3);
        }
        if (v4 != 0) {
            str_builder_add_cstr(sb, " snaplen ");
            str_builder_add_int(sb, v4);
        }
    } elif (vt == VERDICT_COUNTER_NAMED) {
        str_builder_add_cstr(sb, "counter name \"");
        str_builder_add_cstr(sb, v1);
        str_builder_add_cstr(sb, "\"");
    }
    return 0;
}

# Render a complete rule to nftables syntax string
fn rule_render(r: i64): Str {
    var sb = str_builder_new();
    var matches = rule_matches(r);
    var len = vec_len(matches);
    var i = 0;
    while (i < len) {
        if (i > 0) { str_builder_add_cstr(sb, " "); }
        _render_match(sb, vec_get(matches, i));
        i = i + 1;
    }

    if (len > 0) { str_builder_add_cstr(sb, " "); }
    _render_verdict(sb, rule_verdict(r));

    var comment = rule_comment(r);
    if (comment != 0) {
        str_builder_add_cstr(sb, " comment \"");
        str_builder_add_cstr(sb, comment);
        str_builder_add_cstr(sb, "\"");
    }

    return str_builder_build(sb);
}

# ================================================================
# Validate — check all string fields for injection
# ================================================================

fn rule_validate(r: i64): i64 {
    var matches = rule_matches(r);
    var len = vec_len(matches);
    var i = 0;
    var vr = 0;
    while (i < len) {
        var m = vec_get(matches, i);
        var mt = match_type(m);
        var v1 = match_val1(m);
        var v2 = match_val2(m);

        if (mt == MATCH_SOURCE_ADDR || mt == MATCH_DEST_ADDR ||
        mt == MATCH_SOURCE_ADDR6 || mt == MATCH_DEST_ADDR6) {
            vr = validate_addr(v1);
            if (is_err_result(vr) == 1) { return vr; }
        } elif (mt == MATCH_IIF || mt == MATCH_OIF) {
            vr = validate_iface(v1);
            if (is_err_result(vr) == 1) { return vr; }
        } elif (mt == MATCH_CT_HELPER || mt == MATCH_FLOW_OFFLOAD ||
        mt == MATCH_CT_TIMEOUT_SET) {
            vr = validate_identifier(v1);
            if (is_err_result(vr) == 1) { return vr; }
        } elif (mt == MATCH_SET_LOOKUP) {
            vr = validate_nft_element(v1);
            if (is_err_result(vr) == 1) { return vr; }
            vr = validate_identifier(v2);
            if (is_err_result(vr) == 1) { return vr; }
        } elif (mt == MATCH_ICMP_TYPE || mt == MATCH_ICMPV6_TYPE) {
            vr = validate_identifier(v1);
            if (is_err_result(vr) == 1) { return vr; }
        } elif (mt == MATCH_ICMP_TYPE_CODE || mt == MATCH_ICMPV6_TYPE_CODE) {
            vr = validate_identifier(v1);
            if (is_err_result(vr) == 1) { return vr; }
        } elif (mt == MATCH_TCP_FLAGS) {
            vr = validate_nft_element(v1);
            if (is_err_result(vr) == 1) { return vr; }
        } elif (mt == MATCH_DSCP) {
            if (v1 > 63) { return nein_err(ERR_INVALID_RULE); }
        } elif (mt == MATCH_VLAN_ID) {
            if (v1 > 4094) { return nein_err(ERR_INVALID_RULE); }
        } elif (mt == MATCH_DPORT_RANGE) {
            if (v1 > v2) { return nein_err(ERR_INVALID_RULE); }
        } elif (mt == MATCH_RAW) {
            # Deliberately not validated — caller's responsibility
        }

        i = i + 1;
    }

    # Validate verdict strings
    var v = rule_verdict(r);
    var vt = verdict_type(v);
    if (vt == VERDICT_JUMP || vt == VERDICT_GOTO) {
        vr = validate_identifier(verdict_val1(v));
        if (is_err_result(vr) == 1) { return vr; }
    } elif (vt == VERDICT_LOG) {
        if (verdict_val1(v) != 0) {
            vr = validate_log_prefix(verdict_val1(v));
            if (is_err_result(vr) == 1) { return vr; }
        }
    } elif (vt == VERDICT_LOG_ADVANCED) {
        if (verdict_val1(v) != 0) {
            vr = validate_log_prefix(verdict_val1(v));
            if (is_err_result(vr) == 1) { return vr; }
        }
    } elif (vt == VERDICT_COUNTER_NAMED) {
        vr = validate_identifier(verdict_val1(v));
        if (is_err_result(vr) == 1) { return vr; }
    }

    # Validate comment
    var comment = rule_comment(r);
    if (comment != 0) {
        vr = validate_comment(comment);
        if (is_err_result(vr) == 1) { return vr; }
    }

    return nein_ok();
}

# ================================================================
# Convenience functions
# ================================================================

fn allow_tcp(port: i64): i64 {
    var r = rule_new(verdict_accept());
    rule_add_match(r, match_protocol(PROTO_TCP));
    rule_add_match(r, match_dport(port));
    return r;
}

fn allow_udp(port: i64): i64 {
    var r = rule_new(verdict_accept());
    rule_add_match(r, match_protocol(PROTO_UDP));
    rule_add_match(r, match_dport(port));
    return r;
}

fn allow_established(): i64 {
    var r = rule_new(verdict_accept());
    rule_add_match(r, match_ct_state("established, related"));
    return r;
}

fn deny_source(cidr: cstring): i64 {
    var r = rule_new(verdict_drop());
    rule_add_match(r, match_source_addr(cidr));
    return r;
}

fn deny_source6(cidr: cstring): i64 {
    var r = rule_new(verdict_drop());
    rule_add_match(r, match_source_addr6(cidr));
    return r;
}

fn allow_service(source_cidr: cstring, protocol: i64, port: i64): i64 {
    var r = rule_new(verdict_accept());
    rule_add_match(r, match_source_addr(source_cidr));
    rule_add_match(r, match_protocol(protocol));
    rule_add_match(r, match_dport(port));
    return r;
}

fn rate_limit_tcp(port: i64, rate: i64, unit: i64): i64 {
    var r = rule_new(verdict_accept());
    rule_add_match(r, match_protocol(PROTO_TCP));
    rule_add_match(r, match_dport(port));
    rule_add_match(r, match_limit(rate, unit, rate));
    return r;
}

fn rate_limit_udp(port: i64, rate: i64, unit: i64): i64 {
    var r = rule_new(verdict_accept());
    rule_add_match(r, match_protocol(PROTO_UDP));
    rule_add_match(r, match_dport(port));
    rule_add_match(r, match_limit(rate, unit, rate));
    return r;
}

fn rate_limit_quic(port: i64, rate: i64, unit: i64): i64 {
    var r = rule_new(verdict_accept());
    rule_add_match(r, match_protocol(PROTO_UDP));
    rule_add_match(r, match_dport(port));
    rule_add_match(r, match_limit(rate, unit, rate * 2));
    rule_set_comment(r, "quic rate limit");
    return r;
}

# --- set.cyr ---

# nein set module — named sets and verdict maps

# ================================================================
# Enums
# ================================================================

enum SetTypeEnum {
    SET_IPV4_ADDR = 1;
    SET_IPV6_ADDR = 2;
    SET_INET_SERVICE = 3;
    SET_INET_PROTO = 4;
    SET_IFNAME = 5;
}

enum SetFlagEnum {
    SETFLAG_CONSTANT = 1;
    SETFLAG_INTERVAL = 2;
    SETFLAG_TIMEOUT = 3;
}

enum MapVerdictEnum {
    MAPV_ACCEPT = 1;
    MAPV_DROP = 2;
    MAPV_JUMP = 3;
}

fn _set_type_str(t: i64): cstring {
    if (t == SET_IPV4_ADDR) { return "ipv4_addr"; }
    if (t == SET_IPV6_ADDR) { return "ipv6_addr"; }
    if (t == SET_INET_SERVICE) { return "inet_service"; }
    if (t == SET_INET_PROTO) { return "inet_proto"; }
    if (t == SET_IFNAME) { return "ifname"; }
    return "ipv4_addr";
}

fn _set_flag_str(f: i64): cstring {
    if (f == SETFLAG_CONSTANT) { return "constant"; }
    if (f == SETFLAG_INTERVAL) { return "interval"; }
    if (f == SETFLAG_TIMEOUT) { return "timeout"; }
    return "constant";
}

# ================================================================
# NftSet — { name, set_type, flags(vec), elements(vec) }
# Layout: [name:8][set_type:8][flags:8][elements:8] = 32 bytes
# ================================================================

fn nft_set_new(name: cstring, stype: i64): i64 {
    var s = alloc(32);
    store64(s, name);
    store64(s + 8, stype);
    store64(s + 16, vec_new());
    store64(s + 24, vec_new());
    return s;
}

fn nft_set_name(s: i64): i64 { return load64(s); }
fn nft_set_type(s: i64): i64 { return load64(s + 8); }
fn nft_set_flags(s: i64): i64 { return load64(s + 16); }
fn nft_set_elements(s: i64): i64 { return load64(s + 24); }

fn nft_set_add_flag(s: i64, flag: i64): i64 {
    vec_push(load64(s + 16), flag);
    return s;
}

fn nft_set_add_element(s: i64, elem: cstring): i64 {
    vec_push(load64(s + 24), elem);
    return s;
}

fn nft_set_add_elements(s: i64, elems: i64): i64 {
    var elen = vec_len(elems);
    var i = 0;
    while (i < elen) {
        vec_push(load64(s + 24), vec_get(elems, i));
        i = i + 1;
    }
    return s;
}

fn nft_set_validate(s: i64): i64 {
    var vr = validate_identifier(nft_set_name(s));
    if (is_err_result(vr) == 1) { return vr; }
    var elems = nft_set_elements(s);
    var elen = vec_len(elems);
    var i = 0;
    while (i < elen) {
        vr = validate_nft_element(vec_get(elems, i));
        if (is_err_result(vr) == 1) { return vr; }
        i = i + 1;
    }
    return nein_ok();
}

fn nft_set_render(s: i64): Str {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "  set ");
    str_builder_add_cstr(sb, nft_set_name(s));
    str_builder_add_cstr(sb, " {\n");
    str_builder_add_cstr(sb, "    type ");
    str_builder_add_cstr(sb, _set_type_str(nft_set_type(s)));
    str_builder_add_cstr(sb, ";\n");

    var flags = nft_set_flags(s);
    var flen = vec_len(flags);
    if (flen > 0) {
        str_builder_add_cstr(sb, "    flags ");
        var i = 0;
        while (i < flen) {
            if (i > 0) { str_builder_add_cstr(sb, ", "); }
            str_builder_add_cstr(sb, _set_flag_str(vec_get(flags, i)));
            i = i + 1;
        }
        str_builder_add_cstr(sb, ";\n");
    }

    var elems = nft_set_elements(s);
    var elen = vec_len(elems);
    if (elen > 0) {
        str_builder_add_cstr(sb, "    elements = { ");
        var i = 0;
        while (i < elen) {
            if (i > 0) { str_builder_add_cstr(sb, ", "); }
            str_builder_add_cstr(sb, vec_get(elems, i));
            i = i + 1;
        }
        str_builder_add_cstr(sb, " };\n");
    }

    str_builder_add_cstr(sb, "  }\n");
    return str_builder_build(sb);
}

# ================================================================
# NftMap — { name, key_type, entries(vec of key/verdict pairs) }
# Entry: [key:8][verdict_type:8][verdict_val:8] = 24 bytes
# ================================================================

fn _map_entry_new(key: cstring, vtype: i64, vval: i64): i64 {
    var e = alloc(24);
    store64(e, key);
    store64(e + 8, vtype);
    store64(e + 16, vval);
    return e;
}

fn nft_map_new(name: cstring, ktype: i64): i64 {
    var m = alloc(24);
    store64(m, name);
    store64(m + 8, ktype);
    store64(m + 16, vec_new());
    return m;
}

fn nft_map_name(m: i64): i64 { return load64(m); }
fn nft_map_key_type(m: i64): i64 { return load64(m + 8); }
fn nft_map_entries(m: i64): i64 { return load64(m + 16); }

fn nft_map_add_entry(m: i64, key: cstring, vtype: i64, vval: i64): i64 {
    vec_push(load64(m + 16), _map_entry_new(key, vtype, vval));
    return m;
}

fn nft_map_validate(m: i64): i64 {
    var vr = validate_identifier(nft_map_name(m));
    if (is_err_result(vr) == 1) { return vr; }
    var entries = nft_map_entries(m);
    var elen = vec_len(entries);
    var i = 0;
    while (i < elen) {
        var e = vec_get(entries, i);
        vr = validate_nft_element(load64(e));
        if (is_err_result(vr) == 1) { return vr; }
        if (load64(e + 8) == MAPV_JUMP) {
            vr = validate_identifier(load64(e + 16));
            if (is_err_result(vr) == 1) { return vr; }
        }
        i = i + 1;
    }
    return nein_ok();
}

fn nft_map_render(m: i64): Str {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "  map ");
    str_builder_add_cstr(sb, nft_map_name(m));
    str_builder_add_cstr(sb, " {\n");
    str_builder_add_cstr(sb, "    type ");
    str_builder_add_cstr(sb, _set_type_str(nft_map_key_type(m)));
    str_builder_add_cstr(sb, " : verdict;\n");

    var entries = nft_map_entries(m);
    var elen = vec_len(entries);
    if (elen > 0) {
        str_builder_add_cstr(sb, "    elements = { ");
        var i = 0;
        while (i < elen) {
            if (i > 0) { str_builder_add_cstr(sb, ", "); }
            var e = vec_get(entries, i);
            str_builder_add_cstr(sb, load64(e));
            str_builder_add_cstr(sb, " : ");
            var vt = load64(e + 8);
            if (vt == MAPV_ACCEPT) { str_builder_add_cstr(sb, "accept"); }
            elif (vt == MAPV_DROP) { str_builder_add_cstr(sb, "drop"); }
            elif (vt == MAPV_JUMP) {
                str_builder_add_cstr(sb, "jump ");
                str_builder_add_cstr(sb, load64(e + 16));
            }
            i = i + 1;
        }
        str_builder_add_cstr(sb, " };\n");
    }

    str_builder_add_cstr(sb, "  }\n");
    return str_builder_build(sb);
}

# --- nat.cyr ---

# nein nat module — NAT rules (DNAT, SNAT, masquerade, redirect)
#
# NatRule as tagged union struct — 5 variants share same layout:
# { type, val1..val6 } — 56 bytes total.

enum NatType {
    NAT_DNAT = 1;
    NAT_SNAT = 2;
    NAT_MASQUERADE = 3;
    NAT_REDIRECT = 4;
    NAT_DNAT_RANGE = 5;
}

# NatRule layout (56 bytes):
#   [type:8][v1:8][v2:8][v3:8][v4:8][v5:8][v6:8]
#
# DNAT:           type=NAT_DNAT, v1=protocol, v2=dest_port, v3=to_addr, v4=to_port, v5=comment, v6=0
# SNAT:           type=NAT_SNAT, v1=source_cidr, v2=to_addr, v3=comment, v4=0, v5=0, v6=0
# MASQUERADE:     type=NAT_MASQUERADE, v1=source_cidr, v2=oif (0 if none), v3=comment, v4=0, v5=0, v6=0
# REDIRECT:       type=NAT_REDIRECT, v1=protocol, v2=dest_port, v3=to_port, v4=comment, v5=0, v6=0
# DNAT_RANGE:     type=NAT_DNAT_RANGE, v1=protocol, v2=dest_port_start, v3=dest_port_end,
#                 v4=to_addr, v5=to_port_start, v6=to_port_end (comment stored in v7 needs extra field)
#
# DNAT_RANGE needs 7 fields; we'll allocate 64 bytes for all for simplicity.

fn nat_new(ntype: i64, v1: i64, v2: i64, v3: i64, v4: i64, v5: i64, v6: i64): i64 {
    var n = alloc(64);
    store64(n, ntype);
    store64(n + 8, v1);
    store64(n + 16, v2);
    store64(n + 24, v3);
    store64(n + 32, v4);
    store64(n + 40, v5);
    store64(n + 48, v6);
    store64(n + 56, 0);
    return n;
}

fn nat_type(n: i64): i64 { return load64(n); }
fn nat_v1(n: i64): i64 { return load64(n + 8); }
fn nat_v2(n: i64): i64 { return load64(n + 16); }
fn nat_v3(n: i64): i64 { return load64(n + 24); }
fn nat_v4(n: i64): i64 { return load64(n + 32); }
fn nat_v5(n: i64): i64 { return load64(n + 40); }
fn nat_v6(n: i64): i64 { return load64(n + 48); }
fn nat_v7(n: i64): i64 { return load64(n + 56); }
fn nat_set_v7(n: i64, val: i64): i64 { store64(n + 56, val); return n; }

# --- Constructors ---

fn nat_dnat(protocol: i64, dest_port: i64, to_addr: cstring, to_port: i64, comment: cstring): i64 {
    return nat_new(NAT_DNAT, protocol, dest_port, to_addr, to_port, comment, 0);
}

fn nat_snat(source_cidr: cstring, to_addr: cstring, comment: cstring): i64 {
    return nat_new(NAT_SNAT, source_cidr, to_addr, comment, 0, 0, 0);
}

fn nat_masquerade(source_cidr: cstring, oif: cstring, comment: cstring): i64 {
    return nat_new(NAT_MASQUERADE, source_cidr, oif, comment, 0, 0, 0);
}

fn nat_redirect(protocol: i64, dest_port: i64, to_port: i64, comment: cstring): i64 {
    return nat_new(NAT_REDIRECT, protocol, dest_port, to_port, comment, 0, 0);
}

fn nat_dnat_range(protocol: i64, dest_port_start: i64, dest_port_end: i64,
to_addr: cstring, to_port_start: i64, to_port_end: i64,
comment: cstring): i64 {
    var n = nat_new(NAT_DNAT_RANGE, protocol, dest_port_start, dest_port_end, to_addr, to_port_start, to_port_end);
    nat_set_v7(n, comment);
    return n;
}

# --- Helper: check if an address contains ':' (IPv6) ---
fn _addr_has_colon(s: cstring): i64 {
    var len = strlen(s);
    var i = 0;
    while (i < len) {
        if (load8(s + i) == 58) { return 1; }   # ':'
        i = i + 1;
    }
    return 0;
}

# Emit an address, wrapping in brackets if IPv6
fn _sb_add_addr(sb: i64, addr: cstring): i64 {
    if (_addr_has_colon(addr) == 1) {
        str_builder_add_cstr(sb, "[");
        str_builder_add_cstr(sb, addr);
        str_builder_add_cstr(sb, "]");
    } else {
        str_builder_add_cstr(sb, addr);
    }
    return 0;
}

# --- Render ---

fn nat_render(n: i64): Str {
    var sb = str_builder_new();
    var nt = nat_type(n);

    if (nt == NAT_DNAT) {
        str_builder_add_cstr(sb, _proto_str(nat_v1(n)));
        str_builder_add_cstr(sb, " dport ");
        str_builder_add_int(sb, nat_v2(n));
        str_builder_add_cstr(sb, " dnat to ");
        _sb_add_addr(sb, nat_v3(n));
        str_builder_add_cstr(sb, ":");
        str_builder_add_int(sb, nat_v4(n));
        if (nat_v5(n) != 0) {
            str_builder_add_cstr(sb, " comment \"");
            str_builder_add_cstr(sb, nat_v5(n));
            str_builder_add_cstr(sb, "\"");
        }
    } elif (nt == NAT_SNAT) {
        str_builder_add_cstr(sb, "ip saddr ");
        str_builder_add_cstr(sb, nat_v1(n));
        str_builder_add_cstr(sb, " snat to ");
        str_builder_add_cstr(sb, nat_v2(n));
        if (nat_v3(n) != 0) {
            str_builder_add_cstr(sb, " comment \"");
            str_builder_add_cstr(sb, nat_v3(n));
            str_builder_add_cstr(sb, "\"");
        }
    } elif (nt == NAT_MASQUERADE) {
        str_builder_add_cstr(sb, "ip saddr ");
        str_builder_add_cstr(sb, nat_v1(n));
        if (nat_v2(n) != 0) {
            str_builder_add_cstr(sb, " oif \"");
            str_builder_add_cstr(sb, nat_v2(n));
            str_builder_add_cstr(sb, "\"");
        }
        str_builder_add_cstr(sb, " masquerade");
        if (nat_v3(n) != 0) {
            str_builder_add_cstr(sb, " comment \"");
            str_builder_add_cstr(sb, nat_v3(n));
            str_builder_add_cstr(sb, "\"");
        }
    } elif (nt == NAT_REDIRECT) {
        str_builder_add_cstr(sb, _proto_str(nat_v1(n)));
        str_builder_add_cstr(sb, " dport ");
        str_builder_add_int(sb, nat_v2(n));
        str_builder_add_cstr(sb, " redirect to :");
        str_builder_add_int(sb, nat_v3(n));
        if (nat_v4(n) != 0) {
            str_builder_add_cstr(sb, " comment \"");
            str_builder_add_cstr(sb, nat_v4(n));
            str_builder_add_cstr(sb, "\"");
        }
    } elif (nt == NAT_DNAT_RANGE) {
        str_builder_add_cstr(sb, _proto_str(nat_v1(n)));
        str_builder_add_cstr(sb, " dport ");
        str_builder_add_int(sb, nat_v2(n));
        str_builder_add_cstr(sb, "-");
        str_builder_add_int(sb, nat_v3(n));
        str_builder_add_cstr(sb, " dnat to ");
        _sb_add_addr(sb, nat_v4(n));
        str_builder_add_cstr(sb, ":");
        str_builder_add_int(sb, nat_v5(n));
        str_builder_add_cstr(sb, "-");
        str_builder_add_int(sb, nat_v6(n));
        if (nat_v7(n) != 0) {
            str_builder_add_cstr(sb, " comment \"");
            str_builder_add_cstr(sb, nat_v7(n));
            str_builder_add_cstr(sb, "\"");
        }
    }

    return str_builder_build(sb);
}

# --- Validate ---

fn nat_validate(n: i64): i64 {
    var nt = nat_type(n);
    var vr = 0;

    if (nt == NAT_DNAT) {
        vr = validate_addr(nat_v3(n));
        if (is_err_result(vr) == 1) { return vr; }
        if (nat_v5(n) != 0) {
            vr = validate_comment(nat_v5(n));
            if (is_err_result(vr) == 1) { return vr; }
        }
    } elif (nt == NAT_SNAT) {
        vr = validate_addr(nat_v1(n));
        if (is_err_result(vr) == 1) { return vr; }
        vr = validate_addr(nat_v2(n));
        if (is_err_result(vr) == 1) { return vr; }
        if (nat_v3(n) != 0) {
            vr = validate_comment(nat_v3(n));
            if (is_err_result(vr) == 1) { return vr; }
        }
    } elif (nt == NAT_MASQUERADE) {
        vr = validate_addr(nat_v1(n));
        if (is_err_result(vr) == 1) { return vr; }
        if (nat_v2(n) != 0) {
            vr = validate_iface(nat_v2(n));
            if (is_err_result(vr) == 1) { return vr; }
        }
        if (nat_v3(n) != 0) {
            vr = validate_comment(nat_v3(n));
            if (is_err_result(vr) == 1) { return vr; }
        }
    } elif (nt == NAT_REDIRECT) {
        if (nat_v4(n) != 0) {
            vr = validate_comment(nat_v4(n));
            if (is_err_result(vr) == 1) { return vr; }
        }
    } elif (nt == NAT_DNAT_RANGE) {
        vr = validate_addr(nat_v4(n));
        if (is_err_result(vr) == 1) { return vr; }
        var dps = nat_v2(n);
        var dpe = nat_v3(n);
        var tps = nat_v5(n);
        var tpe = nat_v6(n);
        if (dps > dpe) { return nein_err(ERR_INVALID_RULE); }
        if (tps > tpe) { return nein_err(ERR_INVALID_RULE); }
        if ((dpe - dps) != (tpe - tps)) { return nein_err(ERR_INVALID_RULE); }
        if (nat_v7(n) != 0) {
            vr = validate_comment(nat_v7(n));
            if (is_err_result(vr) == 1) { return vr; }
        }
    }

    return nein_ok();
}

# --- Convenience ---

fn port_forward(host_port: i64, container_addr: cstring, container_port: i64): i64 {
    return nat_dnat(PROTO_TCP, host_port, container_addr, container_port, "container port fwd");
}

fn port_range_forward(host_start: i64, host_end: i64, container_addr: cstring, container_start: i64): i64 {
    var range_size = host_end - host_start;
    var container_end = container_start + range_size;
    return nat_dnat_range(PROTO_TCP, host_start, host_end, container_addr,
    container_start, container_end, "container port range fwd");
}

fn container_masquerade(subnet: cstring, outbound_iface: cstring): i64 {
    return nat_masquerade(subnet, outbound_iface, "container outbound NAT");
}

# --- chain.cyr ---

# nein chain module — chain types, hooks, policies, and chain rendering

# ================================================================
# Enums
# ================================================================

enum ChainTypeEnum {
    CHAIN_FILTER = 1;
    CHAIN_NAT = 2;
    CHAIN_ROUTE = 3;
}

enum HookEnum {
    HOOK_PREROUTING = 1;
    HOOK_INPUT = 2;
    HOOK_FORWARD = 3;
    HOOK_OUTPUT = 4;
    HOOK_POSTROUTING = 5;
    HOOK_INGRESS = 6;
}

enum PolicyEnum {
    POLICY_ACCEPT = 1;
    POLICY_DROP = 2;
}

fn _chain_type_str(t: i64): cstring {
    if (t == CHAIN_FILTER) { return "filter"; }
    if (t == CHAIN_NAT) { return "nat"; }
    if (t == CHAIN_ROUTE) { return "route"; }
    return "filter";
}

fn _hook_str(h: i64): cstring {
    if (h == HOOK_PREROUTING) { return "prerouting"; }
    if (h == HOOK_INPUT) { return "input"; }
    if (h == HOOK_FORWARD) { return "forward"; }
    if (h == HOOK_OUTPUT) { return "output"; }
    if (h == HOOK_POSTROUTING) { return "postrouting"; }
    if (h == HOOK_INGRESS) { return "ingress"; }
    return "input";
}

fn _policy_str(p: i64): cstring {
    if (p == POLICY_ACCEPT) { return "accept"; }
    if (p == POLICY_DROP) { return "drop"; }
    return "accept";
}

# ================================================================
# ChainRule — tagged wrapper: { type, inner }
# Layout: [type:8][inner:8] = 16 bytes
# type: CR_RULE=1 (standard rule) or CR_NAT=2 (NAT rule)
# ================================================================

enum ChainRuleType {
    CR_RULE = 1;
    CR_NAT = 2;
}

fn chain_rule_new(ctype: i64, inner: i64): i64 {
    var cr = alloc(16);
    store64(cr, ctype);
    store64(cr + 8, inner);
    return cr;
}

fn chain_rule_render(cr: i64): Str {
    var ct = load64(cr);
    var inner = load64(cr + 8);
    if (ct == CR_NAT) { return nat_render(inner); }
    return rule_render(inner);
}

fn chain_rule_validate(cr: i64): i64 {
    var ct = load64(cr);
    var inner = load64(cr + 8);
    if (ct == CR_NAT) { return nat_validate(inner); }
    return rule_validate(inner);
}

# ================================================================
# Chain — { name, chain_type, hook, priority, policy, rules(vec) }
# Layout: [name:8][chain_type:8][hook:8][priority:8][policy:8][rules:8] = 48 bytes
# chain_type/hook/policy = 0 means "not set" (regular chain)
# ================================================================

fn chain_base(name: cstring, ctype: i64, hook: i64, priority: i64, policy: i64): i64 {
    var c = alloc(48);
    store64(c, name);
    store64(c + 8, ctype);
    store64(c + 16, hook);
    store64(c + 24, priority);
    store64(c + 32, policy);
    store64(c + 40, vec_new());
    return c;
}

fn chain_regular(name: cstring): i64 {
    var c = alloc(48);
    store64(c, name);
    store64(c + 8, 0);
    store64(c + 16, 0);
    store64(c + 24, 0);
    store64(c + 32, 0);
    store64(c + 40, vec_new());
    return c;
}

fn chain_name(c: i64): i64 { return load64(c); }
fn chain_type_val(c: i64): i64 { return load64(c + 8); }
fn chain_hook(c: i64): i64 { return load64(c + 16); }
fn chain_priority(c: i64): i64 { return load64(c + 24); }
fn chain_policy(c: i64): i64 { return load64(c + 32); }
fn chain_rules(c: i64): i64 { return load64(c + 40); }

fn chain_add_rule(c: i64, rule: i64): i64 {
    vec_push(load64(c + 40), chain_rule_new(CR_RULE, rule));
    return c;
}

fn chain_add_nat_rule(c: i64, natrule: i64): i64 {
    vec_push(load64(c + 40), chain_rule_new(CR_NAT, natrule));
    return c;
}

fn chain_render(c: i64): Str {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "  chain ");
    str_builder_add_cstr(sb, chain_name(c));
    str_builder_add_cstr(sb, " {\n");

    # Base chain header
    if (chain_type_val(c) != 0) {
        str_builder_add_cstr(sb, "    type ");
        str_builder_add_cstr(sb, _chain_type_str(chain_type_val(c)));
        str_builder_add_cstr(sb, " hook ");
        str_builder_add_cstr(sb, _hook_str(chain_hook(c)));
        str_builder_add_cstr(sb, " priority ");
        str_builder_add_int(sb, chain_priority(c));
        str_builder_add_cstr(sb, "; policy ");
        str_builder_add_cstr(sb, _policy_str(chain_policy(c)));
        str_builder_add_cstr(sb, ";\n");
    }

    # Rules
    var rules = chain_rules(c);
    var rlen = vec_len(rules);
    var i = 0;
    while (i < rlen) {
        str_builder_add_cstr(sb, "    ");
        var rendered = chain_rule_render(vec_get(rules, i));
        str_builder_add_cstr(sb, str_data(rendered));
        str_builder_add_cstr(sb, "\n");
        i = i + 1;
    }

    str_builder_add_cstr(sb, "  }\n");
    return str_builder_build(sb);
}

# --- table.cyr ---

# nein table module — tables, families, defines, flowtables, ct timeouts

# ================================================================
# Family enum
# ================================================================

enum FamilyEnum {
    FAMILY_INET = 1;
    FAMILY_IP = 2;
    FAMILY_IP6 = 3;
    FAMILY_ARP = 4;
    FAMILY_BRIDGE = 5;
    FAMILY_NETDEV = 6;
}

fn _family_str(f: i64): cstring {
    if (f == FAMILY_INET) { return "inet"; }
    if (f == FAMILY_IP) { return "ip"; }
    if (f == FAMILY_IP6) { return "ip6"; }
    if (f == FAMILY_ARP) { return "arp"; }
    if (f == FAMILY_BRIDGE) { return "bridge"; }
    if (f == FAMILY_NETDEV) { return "netdev"; }
    return "inet";
}

# ================================================================
# Define — { name, value }
# Layout: [name:8][value:8] = 16 bytes
# ================================================================

fn define_new(name: cstring, value: cstring): i64 {
    var d = alloc(16);
    store64(d, name);
    store64(d + 8, value);
    return d;
}

fn define_name(d: i64): i64 { return load64(d); }
fn define_value(d: i64): i64 { return load64(d + 8); }

fn define_validate(d: i64): i64 {
    var vr = validate_identifier(define_name(d));
    if (is_err_result(vr) == 1) { return vr; }
    vr = validate_nft_element(define_value(d));
    if (is_err_result(vr) == 1) { return vr; }
    return nein_ok();
}

fn define_render(d: i64): Str {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "  define $");
    str_builder_add_cstr(sb, define_name(d));
    str_builder_add_cstr(sb, " = ");
    str_builder_add_cstr(sb, define_value(d));
    str_builder_add_cstr(sb, ";\n");
    return str_builder_build(sb);
}

# ================================================================
# Flowtable — { name, hook, priority, devices(vec) }
# Layout: [name:8][hook:8][priority:8][devices:8] = 32 bytes
# ================================================================

fn flowtable_new(name: cstring, priority: i64, devices: i64): i64 {
    var ft = alloc(32);
    store64(ft, name);
    store64(ft + 8, HOOK_INGRESS);
    store64(ft + 16, priority);
    store64(ft + 24, devices);
    return ft;
}

fn flowtable_name(ft: i64): i64 { return load64(ft); }
fn flowtable_hook(ft: i64): i64 { return load64(ft + 8); }
fn flowtable_priority(ft: i64): i64 { return load64(ft + 16); }
fn flowtable_devices(ft: i64): i64 { return load64(ft + 24); }

fn flowtable_validate(ft: i64): i64 {
    var vr = validate_identifier(flowtable_name(ft));
    if (is_err_result(vr) == 1) { return vr; }
    if (flowtable_hook(ft) != HOOK_INGRESS) {
        return nein_err(ERR_INVALID_RULE);
    }
    var devs = flowtable_devices(ft);
    var dlen = vec_len(devs);
    if (dlen == 0) { return nein_err(ERR_INVALID_RULE); }
    var i = 0;
    while (i < dlen) {
        vr = validate_iface(vec_get(devs, i));
        if (is_err_result(vr) == 1) { return vr; }
        i = i + 1;
    }
    return nein_ok();
}

fn flowtable_render(ft: i64): Str {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "  flowtable ");
    str_builder_add_cstr(sb, flowtable_name(ft));
    str_builder_add_cstr(sb, " {\n");
    str_builder_add_cstr(sb, "    hook ");
    str_builder_add_cstr(sb, _hook_str(flowtable_hook(ft)));
    str_builder_add_cstr(sb, " priority ");
    str_builder_add_int(sb, flowtable_priority(ft));
    str_builder_add_cstr(sb, ";\n");

    var devs = flowtable_devices(ft);
    var dlen = vec_len(devs);
    if (dlen > 0) {
        str_builder_add_cstr(sb, "    devices = { ");
        var i = 0;
        while (i < dlen) {
            if (i > 0) { str_builder_add_cstr(sb, ", "); }
            str_builder_add_cstr(sb, vec_get(devs, i));
            i = i + 1;
        }
        str_builder_add_cstr(sb, " };\n");
    }

    str_builder_add_cstr(sb, "  }\n");
    return str_builder_build(sb);
}

# ================================================================
# CtTimeout — { name, protocol, l3proto, policy(vec of state/secs pairs) }
# Layout: [name:8][protocol:8][l3proto:8][policy:8] = 32 bytes
# Policy entries: [state_name:8][seconds:8] = 16 bytes each
# ================================================================

fn ct_timeout_new(name: cstring, protocol: i64): i64 {
    var ct = alloc(32);
    store64(ct, name);
    store64(ct + 8, protocol);
    store64(ct + 16, 0);
    store64(ct + 24, vec_new());
    return ct;
}

fn ct_timeout_name(ct: i64): i64 { return load64(ct); }
fn ct_timeout_protocol(ct: i64): i64 { return load64(ct + 8); }
fn ct_timeout_l3proto(ct: i64): i64 { return load64(ct + 16); }
fn ct_timeout_policy(ct: i64): i64 { return load64(ct + 24); }

fn ct_timeout_set_l3proto(ct: i64, family: i64): i64 {
    store64(ct + 16, family);
    return ct;
}

fn ct_timeout_add_timeout(ct: i64, state: cstring, seconds: i64): i64 {
    var e = alloc(16);
    store64(e, state);
    store64(e + 8, seconds);
    vec_push(load64(ct + 24), e);
    return ct;
}

fn ct_timeout_validate(ct: i64): i64 {
    var vr = validate_identifier(ct_timeout_name(ct));
    if (is_err_result(vr) == 1) { return vr; }
    var proto = ct_timeout_protocol(ct);
    if (proto != PROTO_TCP && proto != PROTO_UDP) {
        return nein_err(ERR_INVALID_RULE);
    }
    var l3 = ct_timeout_l3proto(ct);
    if (l3 != 0 && l3 != FAMILY_IP && l3 != FAMILY_IP6) {
        return nein_err(ERR_INVALID_RULE);
    }
    var pol = ct_timeout_policy(ct);
    var plen = vec_len(pol);
    var i = 0;
    while (i < plen) {
        var e = vec_get(pol, i);
        vr = validate_identifier(load64(e));
        if (is_err_result(vr) == 1) { return vr; }
        i = i + 1;
    }
    return nein_ok();
}

fn ct_timeout_render(ct: i64): Str {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "  ct timeout ");
    str_builder_add_cstr(sb, ct_timeout_name(ct));
    str_builder_add_cstr(sb, " {\n");
    str_builder_add_cstr(sb, "    protocol ");
    str_builder_add_cstr(sb, _proto_str(ct_timeout_protocol(ct)));
    str_builder_add_cstr(sb, ";\n");

    var l3 = ct_timeout_l3proto(ct);
    if (l3 != 0) {
        str_builder_add_cstr(sb, "    l3proto ");
        str_builder_add_cstr(sb, _family_str(l3));
        str_builder_add_cstr(sb, ";\n");
    }

    var pol = ct_timeout_policy(ct);
    var plen = vec_len(pol);
    if (plen > 0) {
        str_builder_add_cstr(sb, "    policy = { ");
        var i = 0;
        while (i < plen) {
            if (i > 0) { str_builder_add_cstr(sb, ", "); }
            var e = vec_get(pol, i);
            str_builder_add_cstr(sb, load64(e));
            str_builder_add_cstr(sb, ": ");
            str_builder_add_int(sb, load64(e + 8));
            i = i + 1;
        }
        str_builder_add_cstr(sb, " };\n");
    }

    str_builder_add_cstr(sb, "  }\n");
    return str_builder_build(sb);
}

# ================================================================
# Table — { name, family, defines, flowtables, ct_timeouts, sets, maps, chains }
# Layout: [name:8][family:8][defines:8][flowtables:8][ct_timeouts:8]
#         [sets:8][maps:8][chains:8] = 64 bytes
# ================================================================

fn table_new(name: cstring, family: i64): i64 {
    var t = alloc(64);
    store64(t, name);
    store64(t + 8, family);
    store64(t + 16, vec_new());
    store64(t + 24, vec_new());
    store64(t + 32, vec_new());
    store64(t + 40, vec_new());
    store64(t + 48, vec_new());
    store64(t + 56, vec_new());
    return t;
}

fn table_name(t: i64): i64 { return load64(t); }
fn table_family(t: i64): i64 { return load64(t + 8); }
fn table_defines(t: i64): i64 { return load64(t + 16); }
fn table_flowtables(t: i64): i64 { return load64(t + 24); }
fn table_ct_timeouts(t: i64): i64 { return load64(t + 32); }
fn table_sets(t: i64): i64 { return load64(t + 40); }
fn table_maps(t: i64): i64 { return load64(t + 48); }
fn table_chains(t: i64): i64 { return load64(t + 56); }

fn table_add_define(t: i64, d: i64): i64 { vec_push(load64(t + 16), d); return t; }
fn table_add_flowtable(t: i64, ft: i64): i64 { vec_push(load64(t + 24), ft); return t; }
fn table_add_ct_timeout(t: i64, ct: i64): i64 { vec_push(load64(t + 32), ct); return t; }
fn table_add_set(t: i64, s: i64): i64 { vec_push(load64(t + 40), s); return t; }
fn table_add_map(t: i64, m: i64): i64 { vec_push(load64(t + 48), m); return t; }
fn table_add_chain(t: i64, c: i64): i64 { vec_push(load64(t + 56), c); return t; }

fn table_render(t: i64): Str {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "table ");
    str_builder_add_cstr(sb, _family_str(table_family(t)));
    str_builder_add_cstr(sb, " ");
    str_builder_add_cstr(sb, table_name(t));
    str_builder_add_cstr(sb, " {\n");

    # Render order: defines -> flowtables -> ct_timeouts -> sets -> maps -> chains
    var v = 0;
    var vlen = 0;
    var i = 0;

    v = table_defines(t);
    vlen = vec_len(v);
    i = 0;
    while (i < vlen) {
        var rendered = define_render(vec_get(v, i));
        str_builder_add_cstr(sb, str_data(rendered));
        i = i + 1;
    }

    v = table_flowtables(t);
    vlen = vec_len(v);
    i = 0;
    while (i < vlen) {
        var rendered = flowtable_render(vec_get(v, i));
        str_builder_add_cstr(sb, str_data(rendered));
        i = i + 1;
    }

    v = table_ct_timeouts(t);
    vlen = vec_len(v);
    i = 0;
    while (i < vlen) {
        var rendered = ct_timeout_render(vec_get(v, i));
        str_builder_add_cstr(sb, str_data(rendered));
        i = i + 1;
    }

    v = table_sets(t);
    vlen = vec_len(v);
    i = 0;
    while (i < vlen) {
        var rendered = nft_set_render(vec_get(v, i));
        str_builder_add_cstr(sb, str_data(rendered));
        i = i + 1;
    }

    v = table_maps(t);
    vlen = vec_len(v);
    i = 0;
    while (i < vlen) {
        var rendered = nft_map_render(vec_get(v, i));
        str_builder_add_cstr(sb, str_data(rendered));
        i = i + 1;
    }

    v = table_chains(t);
    vlen = vec_len(v);
    i = 0;
    while (i < vlen) {
        var rendered = chain_render(vec_get(v, i));
        str_builder_add_cstr(sb, str_data(rendered));
        i = i + 1;
    }

    str_builder_add_cstr(sb, "}\n");
    return str_builder_build(sb);
}

# --- firewall.cyr ---

# nein firewall module — top-level Firewall manager
#
# Firewall struct — { tables(vec), dry_run }
# Layout: [tables:8][dry_run:8] = 16 bytes

fn firewall_new(): i64 {
    var fw = alloc(16);
    store64(fw, vec_new());
    store64(fw + 8, 0);
    return fw;
}

fn firewall_tables(fw: i64): i64 { return load64(fw); }
fn firewall_dry_run(fw: i64): i64 { return load64(fw + 8); }

fn firewall_set_dry_run(fw: i64, enabled: i64): i64 {
    store64(fw + 8, enabled);
    return fw;
}

fn firewall_add_table(fw: i64, t: i64): i64 {
    vec_push(load64(fw), t);
    return fw;
}

# --- Render: concatenate all tables with trailing newlines ---
fn firewall_render(fw: i64): Str {
    var sb = str_builder_new();
    var tables = firewall_tables(fw);
    var tlen = vec_len(tables);
    var i = 0;
    while (i < tlen) {
        var rendered = table_render(vec_get(tables, i));
        str_builder_add_cstr(sb, str_data(rendered));
        str_builder_add_cstr(sb, "\n");
        i = i + 1;
    }
    return str_builder_build(sb);
}

# --- Validate all tables, chains, and contents ---
fn firewall_validate(fw: i64): i64 {
    var tables = firewall_tables(fw);
    var tlen = vec_len(tables);
    var i = 0;
    var j = 0;
    var vec2 = 0;
    var vlen = 0;
    var vr = 0;

    while (i < tlen) {
        var t = vec_get(tables, i);

        vr = validate_identifier(table_name(t));
        if (is_err_result(vr) == 1) { return vr; }

        # Defines
        vec2 = table_defines(t);
        vlen = vec_len(vec2);
        j = 0;
        while (j < vlen) {
            vr = define_validate(vec_get(vec2, j));
            if (is_err_result(vr) == 1) { return vr; }
            j = j + 1;
        }

        # Flowtables
        vec2 = table_flowtables(t);
        vlen = vec_len(vec2);
        j = 0;
        while (j < vlen) {
            vr = flowtable_validate(vec_get(vec2, j));
            if (is_err_result(vr) == 1) { return vr; }
            j = j + 1;
        }

        # CT timeouts
        vec2 = table_ct_timeouts(t);
        vlen = vec_len(vec2);
        j = 0;
        while (j < vlen) {
            vr = ct_timeout_validate(vec_get(vec2, j));
            if (is_err_result(vr) == 1) { return vr; }
            j = j + 1;
        }

        # Sets
        vec2 = table_sets(t);
        vlen = vec_len(vec2);
        j = 0;
        while (j < vlen) {
            vr = nft_set_validate(vec_get(vec2, j));
            if (is_err_result(vr) == 1) { return vr; }
            j = j + 1;
        }

        # Maps
        vec2 = table_maps(t);
        vlen = vec_len(vec2);
        j = 0;
        while (j < vlen) {
            vr = nft_map_validate(vec_get(vec2, j));
            if (is_err_result(vr) == 1) { return vr; }
            j = j + 1;
        }

        # Chains
        vec2 = table_chains(t);
        vlen = vec_len(vec2);
        j = 0;
        while (j < vlen) {
            var chain = vec_get(vec2, j);
            vr = validate_identifier(chain_name(chain));
            if (is_err_result(vr) == 1) { return vr; }
            var rules = chain_rules(chain);
            var rlen = vec_len(rules);
            var k = 0;
            while (k < rlen) {
                vr = chain_rule_validate(vec_get(rules, k));
                if (is_err_result(vr) == 1) { return vr; }
                k = k + 1;
            }
            j = j + 1;
        }

        i = i + 1;
    }

    return nein_ok();
}

# --- builder.cyr ---

# nein builder module — pre-built firewall configurations

# --- Build a basic host firewall (allow established, lo, SSH, drop rest) ---
fn basic_host_firewall(): i64 {
    var fw = firewall_new();
    var table = table_new("filter", FAMILY_INET);

    var input = chain_base("input", CHAIN_FILTER, HOOK_INPUT, 0, POLICY_DROP);
    chain_add_rule(input, allow_established());

    # rule: iif lo accept
    var lo_rule = rule_new(verdict_accept());
    rule_add_match(lo_rule, match_iif("lo"));
    chain_add_rule(input, lo_rule);

    # SSH with comment
    var ssh_rule = allow_tcp(22);
    rule_set_comment(ssh_rule, "SSH");
    chain_add_rule(input, ssh_rule);

    # output chain (permissive)
    var output = chain_base("output", CHAIN_FILTER, HOOK_OUTPUT, 0, POLICY_ACCEPT);

    table_add_chain(table, input);
    table_add_chain(table, output);
    firewall_add_table(fw, table);
    return fw;
}

# --- Build container bridge networking rules ---
fn container_bridge(bridge_name: cstring, subnet: cstring, outbound_iface: cstring): i64 {
    var fw = firewall_new();

    # filter table: forward chain
    var filter = table_new("filter", FAMILY_INET);
    var forward = chain_base("forward", CHAIN_FILTER, HOOK_FORWARD, 0, POLICY_DROP);

    chain_add_rule(forward, allow_established());

    # container -> internet
    var r1 = rule_new(verdict_accept());
    rule_add_match(r1, match_iif(bridge_name));
    rule_add_match(r1, match_oif(outbound_iface));
    rule_set_comment(r1, "container to internet");
    chain_add_rule(forward, r1);

    # container -> container
    var r2 = rule_new(verdict_accept());
    rule_add_match(r2, match_iif(bridge_name));
    rule_add_match(r2, match_oif(bridge_name));
    rule_set_comment(r2, "container to container");
    chain_add_rule(forward, r2);

    table_add_chain(filter, forward);
    firewall_add_table(fw, filter);

    # nat table: postrouting masquerade
    var nat_table = table_new("nat", FAMILY_IP);
    var postrouting = chain_base("postrouting", CHAIN_NAT, HOOK_POSTROUTING, 100, POLICY_ACCEPT);
    chain_add_nat_rule(postrouting, container_masquerade(subnet, outbound_iface));
    table_add_chain(nat_table, postrouting);
    firewall_add_table(fw, nat_table);

    return fw;
}

# --- Build agent-to-agent service policy rules ---
# ports_vec: vec of { protocol, port } pair structs (16 bytes each)
fn _port_pair_new(protocol: i64, port: i64): i64 {
    var p = alloc(16);
    store64(p, protocol);
    store64(p + 8, port);
    return p;
}

fn service_policy(agent_source: cstring, ports_vec: i64): i64 {
    var fw = firewall_new();
    var table = table_new("agnos_policy", FAMILY_INET);
    var chain = chain_regular("agent_access");

    var plen = vec_len(ports_vec);
    var i = 0;
    while (i < plen) {
        var pair = vec_get(ports_vec, i);
        chain_add_rule(chain, allow_service(agent_source, load64(pair), load64(pair + 8)));
        i = i + 1;
    }

    table_add_chain(table, chain);
    firewall_add_table(fw, table);
    return fw;
}

# --- policy.cyr ---

# nein policy module — network policies (K8s-style)

enum PolicyActionEnum {
    PACT_ALLOW = 1;
    PACT_DENY = 2;
}

# ================================================================
# PolicyPort — { protocol, port }
# Layout: [protocol:8][port:8] = 16 bytes
# ================================================================

fn policy_port_new(protocol: i64, port: i64): i64 {
    var p = alloc(16);
    store64(p, protocol);
    store64(p + 8, port);
    return p;
}

fn policy_port_protocol(p: i64): i64 { return load64(p); }
fn policy_port_port(p: i64): i64 { return load64(p + 8); }

# ================================================================
# PolicyRule — { peer(str), ports(vec of PolicyPort) }
# Layout: [peer:8][ports:8] = 16 bytes
# ================================================================

fn policy_rule_new(peer: cstring): i64 {
    var pr = alloc(16);
    store64(pr, peer);
    store64(pr + 8, vec_new());
    return pr;
}

fn policy_rule_peer(pr: i64): i64 { return load64(pr); }
fn policy_rule_ports(pr: i64): i64 { return load64(pr + 8); }

fn policy_rule_add_port(pr: i64, protocol: i64, port: i64): i64 {
    vec_push(load64(pr + 8), policy_port_new(protocol, port));
    return pr;
}

# ================================================================
# NetworkPolicy — { name, target, ingress(vec), egress(vec), default_action }
# Layout: [name:8][target:8][ingress:8][egress:8][default_action:8] = 40 bytes
# ================================================================

fn nein_network_policy_new(name: cstring, target: cstring, default_action: i64): i64 {
    var np = alloc(40);
    store64(np, name);
    store64(np + 8, target);
    store64(np + 16, vec_new());
    store64(np + 24, vec_new());
    store64(np + 32, default_action);
    return np;
}

fn policy_name(np: i64): i64 { return load64(np); }
fn policy_target(np: i64): i64 { return load64(np + 8); }
fn policy_ingress(np: i64): i64 { return load64(np + 16); }
fn policy_egress(np: i64): i64 { return load64(np + 24); }
fn policy_default_action(np: i64): i64 { return load64(np + 32); }

fn policy_add_ingress(np: i64, pr: i64): i64 {
    vec_push(load64(np + 16), pr);
    return np;
}

fn policy_add_egress(np: i64, pr: i64): i64 {
    vec_push(load64(np + 24), pr);
    return np;
}

# ================================================================
# Validate
# ================================================================

fn _validate_policy_rules(rules: i64): i64 {
    var rlen = vec_len(rules);
    var i = 0;
    var vr = 0;
    while (i < rlen) {
        var pr = vec_get(rules, i);
        var peer = policy_rule_peer(pr);
        # "any" peer is allowed without validation
        if (streq(peer, "any") == 0) {
            vr = validate_addr(peer);
            if (is_err_result(vr) == 1) { return vr; }
        }
        i = i + 1;
    }
    return nein_ok();
}

fn policy_validate(np: i64): i64 {
    var vr = validate_identifier(policy_name(np));
    if (is_err_result(vr) == 1) { return vr; }

    vr = _validate_policy_rules(policy_ingress(np));
    if (is_err_result(vr) == 1) { return vr; }

    vr = _validate_policy_rules(policy_egress(np));
    if (is_err_result(vr) == 1) { return vr; }

    return nein_ok();
}

# ================================================================
# Convert policy to rules
# ================================================================

# Build the comment string "policy:NAME direction from/to PEER"
fn _policy_comment(name: cstring, direction: cstring, preposition: cstring, peer: cstring): cstring {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "policy:");
    str_builder_add_cstr(sb, name);
    str_builder_add_cstr(sb, " ");
    str_builder_add_cstr(sb, direction);
    str_builder_add_cstr(sb, " ");
    str_builder_add_cstr(sb, preposition);
    str_builder_add_cstr(sb, " ");
    str_builder_add_cstr(sb, peer);
    var s = str_builder_build(sb);
    # Need null-terminated cstr for rule_set_comment
    var out = alloc(str_len(s) + 1);
    memcpy(out, str_data(s), str_len(s));
    store8(out + str_len(s), 0);
    return out;
}

fn policy_to_rules(np: i64): i64 {
    var rules = vec_new();
    var name = policy_name(np);

    # Ingress: accept on dport with optional source addr
    var ing = policy_ingress(np);
    var ilen = vec_len(ing);
    var i = 0;
    while (i < ilen) {
        var pr = vec_get(ing, i);
        var peer = policy_rule_peer(pr);
        var ports = policy_rule_ports(pr);
        var plen = vec_len(ports);
        var j = 0;
        while (j < plen) {
            var pp = vec_get(ports, j);
            var r = rule_new(verdict_accept());
            rule_add_match(r, match_protocol(policy_port_protocol(pp)));
            rule_add_match(r, match_dport(policy_port_port(pp)));
            if (streq(peer, "any") == 0) {
                rule_add_match(r, match_source_addr(peer));
            }
            rule_set_comment(r, _policy_comment(name, "ingress", "from", peer));
            vec_push(rules, r);
            j = j + 1;
        }
        i = i + 1;
    }

    # Egress: accept on dport with optional dest addr
    var eg = policy_egress(np);
    var elen = vec_len(eg);
    i = 0;
    while (i < elen) {
        var pr = vec_get(eg, i);
        var peer = policy_rule_peer(pr);
        var ports = policy_rule_ports(pr);
        var plen = vec_len(ports);
        var j = 0;
        while (j < plen) {
            var pp = vec_get(ports, j);
            var r = rule_new(verdict_accept());
            rule_add_match(r, match_protocol(policy_port_protocol(pp)));
            rule_add_match(r, match_dport(policy_port_port(pp)));
            if (streq(peer, "any") == 0) {
                rule_add_match(r, match_dest_addr(peer));
            }
            rule_set_comment(r, _policy_comment(name, "egress", "to", peer));
            vec_push(rules, r);
            j = j + 1;
        }
        i = i + 1;
    }

    return rules;
}

# ================================================================
# Convenience: agent-to-agent policy
# ================================================================

fn agent_to_agent(name: cstring, source: cstring, dest: cstring, protocol: i64, port: i64): i64 {
    var np = nein_network_policy_new(name, dest, PACT_DENY);
    var pr = policy_rule_new(source);
    policy_rule_add_port(pr, protocol, port);
    policy_add_ingress(np, pr);
    return np;
}

# --- geoip.cyr ---

# nein geoip module — country-based traffic blocking via nftables sets

# ================================================================
# CountryBlock — { code, cidrs_v4(vec), cidrs_v6(vec) }
# Layout: [code:8][v4:8][v6:8] = 24 bytes
# ================================================================

# Uppercase a C string (in-place on a new copy)
fn _upper_copy(s: cstring): cstring {
    var len = strlen(s);
    var out = alloc(len + 1);
    var i = 0;
    while (i < len) {
        var c = load8(s + i);
        if (c >= 97 && c <= 122) { c = c - 32; }
        store8(out + i, c);
        i = i + 1;
    }
    store8(out + len, 0);
    return out;
}

fn country_block_v4(code: cstring, cidrs: i64): i64 {
    var cb = alloc(24);
    store64(cb, _upper_copy(code));
    store64(cb + 8, cidrs);
    store64(cb + 16, vec_new());
    return cb;
}

fn country_block_dual(code: cstring, cidrs_v4: i64, cidrs_v6: i64): i64 {
    var cb = alloc(24);
    store64(cb, _upper_copy(code));
    store64(cb + 8, cidrs_v4);
    store64(cb + 16, cidrs_v6);
    return cb;
}

fn country_code(cb: i64): i64 { return load64(cb); }
fn country_cidrs_v4(cb: i64): i64 { return load64(cb + 8); }
fn country_cidrs_v6(cb: i64): i64 { return load64(cb + 16); }

# ================================================================
# GeoIpBlocklist — { countries(vec), table_name, hook }
# Layout: [countries:8][table_name:8][hook:8] = 24 bytes
# ================================================================

fn geoip_new(): i64 {
    var bl = alloc(24);
    store64(bl, vec_new());
    store64(bl + 8, "nein_geoip");
    store64(bl + 16, HOOK_INPUT);
    return bl;
}

fn geoip_countries(bl: i64): i64 { return load64(bl); }
fn geoip_table_name(bl: i64): i64 { return load64(bl + 8); }
fn geoip_hook(bl: i64): i64 { return load64(bl + 16); }

fn geoip_set_table_name(bl: i64, name: cstring): i64 { store64(bl + 8, name); return bl; }
fn geoip_set_hook(bl: i64, hook: i64): i64 { store64(bl + 16, hook); return bl; }

fn geoip_block_country(bl: i64, cb: i64): i64 {
    vec_push(load64(bl), cb);
    return bl;
}

# ================================================================
# Validate
# ================================================================

# Check country code: exactly 2 ASCII uppercase letters
fn _is_valid_country_code(code: cstring): i64 {
    if (strlen(code) != 2) { return 0; }
    var c0 = load8(code);
    var c1 = load8(code + 1);
    if (c0 < 65 || c0 > 90) { return 0; }
    if (c1 < 65 || c1 > 90) { return 0; }
    return 1;
}

fn _validate_cidr_list(cidrs: i64): i64 {
    var clen = vec_len(cidrs);
    var i = 0;
    var vr = 0;
    while (i < clen) {
        vr = validate_addr(vec_get(cidrs, i));
        if (is_err_result(vr) == 1) { return vr; }
        i = i + 1;
    }
    return nein_ok();
}

fn geoip_validate(bl: i64): i64 {
    var vr = validate_identifier(geoip_table_name(bl));
    if (is_err_result(vr) == 1) { return vr; }

    var countries = geoip_countries(bl);
    var clen = vec_len(countries);
    var i = 0;
    while (i < clen) {
        var cb = vec_get(countries, i);
        if (_is_valid_country_code(country_code(cb)) == 0) {
            return nein_err(ERR_INVALID_RULE);
        }
        vr = _validate_cidr_list(country_cidrs_v4(cb));
        if (is_err_result(vr) == 1) { return vr; }
        vr = _validate_cidr_list(country_cidrs_v6(cb));
        if (is_err_result(vr) == 1) { return vr; }
        i = i + 1;
    }

    return nein_ok();
}

# ================================================================
# Build firewall
# ================================================================

# Lowercase copy
fn _lower_copy(s: cstring): cstring {
    var len = strlen(s);
    var out = alloc(len + 1);
    var i = 0;
    while (i < len) {
        var c = load8(s + i);
        if (c >= 65 && c <= 90) { c = c + 32; }
        store8(out + i, c);
        i = i + 1;
    }
    store8(out + len, 0);
    return out;
}

# Concat "geo_" + lowercase(code)
fn _geo_set_name(code: cstring): cstring {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "geo_");
    str_builder_add_cstr(sb, _lower_copy(code));
    var s = str_builder_build(sb);
    var out = alloc(str_len(s) + 1);
    memcpy(out, str_data(s), str_len(s));
    store8(out + str_len(s), 0);
    return out;
}

# Concat "table_name" + optional suffix
fn _table_name_with_suffix(base: cstring, suffix: cstring): cstring {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, base);
    str_builder_add_cstr(sb, suffix);
    var s = str_builder_build(sb);
    var out = alloc(str_len(s) + 1);
    memcpy(out, str_data(s), str_len(s));
    store8(out + str_len(s), 0);
    return out;
}

# Concat "geoblock CODE"
fn _geoblock_comment(code: cstring): cstring {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "geoblock ");
    str_builder_add_cstr(sb, code);
    var s = str_builder_build(sb);
    var out = alloc(str_len(s) + 1);
    memcpy(out, str_data(s), str_len(s));
    store8(out + str_len(s), 0);
    return out;
}

# Check if any country has non-empty cidrs in the given family
fn _any_has_cidrs(countries: i64, v6: i64): i64 {
    var clen = vec_len(countries);
    var i = 0;
    while (i < clen) {
        var cb = vec_get(countries, i);
        var cidrs = country_cidrs_v4(cb);
        if (v6 == 1) { cidrs = country_cidrs_v6(cb); }
        if (vec_len(cidrs) > 0) { return 1; }
        i = i + 1;
    }
    return 0;
}

fn _build_table(bl: i64, family: i64, v6: i64): i64 {
    var suffix = "";
    if (v6 == 1) { suffix = "_v6"; }
    var tname = _table_name_with_suffix(geoip_table_name(bl), suffix);
    var table = table_new(tname, family);

    var chain = chain_base("geoblock", CHAIN_FILTER, geoip_hook(bl), 0 - 10, POLICY_ACCEPT);

    var countries = geoip_countries(bl);
    var clen = vec_len(countries);
    var i = 0;
    while (i < clen) {
        var cb = vec_get(countries, i);
        var cidrs = country_cidrs_v4(cb);
        var stype = SET_IPV4_ADDR;
        var field = "ip saddr";
        if (v6 == 1) {
            cidrs = country_cidrs_v6(cb);
            stype = SET_IPV6_ADDR;
            field = "ip6 saddr";
        }
        var cidrs_len = vec_len(cidrs);
        if (cidrs_len > 0) {
            var set_name = _geo_set_name(country_code(cb));
            var set = nft_set_new(set_name, stype);
            nft_set_add_flag(set, SETFLAG_INTERVAL);
            var j = 0;
            while (j < cidrs_len) {
                nft_set_add_element(set, vec_get(cidrs, j));
                j = j + 1;
            }
            table_add_set(table, set);

            var r = rule_new(verdict_drop());
            rule_add_match(r, match_set_lookup(field, set_name));
            rule_set_comment(r, _geoblock_comment(country_code(cb)));
            chain_add_rule(chain, r);
        }
        i = i + 1;
    }

    table_add_chain(table, chain);
    return table;
}

fn geoip_to_firewall(bl: i64): i64 {
    var fw = firewall_new();
    var countries = geoip_countries(bl);
    if (vec_len(countries) == 0) { return fw; }

    if (_any_has_cidrs(countries, 0) == 1) {
        firewall_add_table(fw, _build_table(bl, FAMILY_IP, 0));
    }
    if (_any_has_cidrs(countries, 1) == 1) {
        firewall_add_table(fw, _build_table(bl, FAMILY_IP6, 1));
    }

    return fw;
}

# --- mesh.cyr ---

# nein mesh module — service mesh sidecar proxy rules

# ================================================================
# SidecarConfig — { inbound_port, outbound_port, proxy_uid,
#   excl_out_cidrs(vec), excl_out_ports(vec), excl_in_ports(vec), table_name }
# Layout: 7 fields * 8 = 56 bytes
# ================================================================

fn mesh_envoy(): i64 {
    var m = alloc(56);
    store64(m, 15006);                           # inbound_port
    store64(m + 8, 15001);                       # outbound_port
    store64(m + 16, 1337);                       # proxy_uid
    store64(m + 24, vec_new());                  # exclude_outbound_cidrs
    store64(m + 32, vec_new());                  # exclude_outbound_ports
    store64(m + 40, vec_new());                  # exclude_inbound_ports
    store64(m + 48, "nein_mesh");                # table_name
    vec_push(load64(m + 24), "127.0.0.0/8");
    return m;
}

fn mesh_inbound_port(m: i64): i64 { return load64(m); }
fn mesh_outbound_port(m: i64): i64 { return load64(m + 8); }
fn mesh_proxy_uid(m: i64): i64 { return load64(m + 16); }
fn mesh_excl_out_cidrs(m: i64): i64 { return load64(m + 24); }
fn mesh_excl_out_ports(m: i64): i64 { return load64(m + 32); }
fn mesh_excl_in_ports(m: i64): i64 { return load64(m + 40); }
fn mesh_table_name(m: i64): i64 { return load64(m + 48); }

fn mesh_set_inbound_port(m: i64, p: i64): i64 { store64(m, p); return m; }
fn mesh_set_outbound_port(m: i64, p: i64): i64 { store64(m + 8, p); return m; }
fn mesh_set_proxy_uid(m: i64, uid: i64): i64 { store64(m + 16, uid); return m; }
fn mesh_set_table_name(m: i64, name: cstring): i64 { store64(m + 48, name); return m; }

fn mesh_exclude_outbound_cidr(m: i64, cidr: cstring): i64 { vec_push(load64(m + 24), cidr); return m; }
fn mesh_exclude_outbound_port(m: i64, port: i64): i64 { vec_push(load64(m + 32), port); return m; }
fn mesh_exclude_inbound_port(m: i64, port: i64): i64 { vec_push(load64(m + 40), port); return m; }

fn mesh_clear_excl_out_cidrs(m: i64): i64 {
    store64(m + 24, vec_new());
    return m;
}

# ================================================================
# Validate
# ================================================================

fn mesh_validate(m: i64): i64 {
    var vr = validate_identifier(mesh_table_name(m));
    if (is_err_result(vr) == 1) { return vr; }
    var cidrs = mesh_excl_out_cidrs(m);
    var clen = vec_len(cidrs);
    var i = 0;
    while (i < clen) {
        vr = validate_addr(vec_get(cidrs, i));
        if (is_err_result(vr) == 1) { return vr; }
        i = i + 1;
    }
    return nein_ok();
}

# ================================================================
# Render helpers — build comment strings
# ================================================================

fn _mesh_cstr_concat(a: cstring, b: cstring): cstring {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, a);
    str_builder_add_cstr(sb, b);
    var s = str_builder_build(sb);
    var out = alloc(str_len(s) + 1);
    memcpy(out, str_data(s), str_len(s));
    store8(out + str_len(s), 0);
    return out;
}

fn _mesh_cstr_concat3(a: cstring, b: cstring, c: cstring): cstring {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, a);
    str_builder_add_cstr(sb, b);
    str_builder_add_cstr(sb, c);
    var s = str_builder_build(sb);
    var out = alloc(str_len(s) + 1);
    memcpy(out, str_data(s), str_len(s));
    store8(out + str_len(s), 0);
    return out;
}

# Build "meta skuid N" raw match string
fn _raw_meta_skuid(uid: i64): cstring {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "meta skuid ");
    str_builder_add_int(sb, uid);
    var s = str_builder_build(sb);
    var out = alloc(str_len(s) + 1);
    memcpy(out, str_data(s), str_len(s));
    store8(out + str_len(s), 0);
    return out;
}

# Build "tcp dport != PORT redirect to :PORT" raw match string
fn _raw_redirect(port: i64): cstring {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "tcp dport != ");
    str_builder_add_int(sb, port);
    str_builder_add_cstr(sb, " redirect to :");
    str_builder_add_int(sb, port);
    var s = str_builder_build(sb);
    var out = alloc(str_len(s) + 1);
    memcpy(out, str_data(s), str_len(s));
    store8(out + str_len(s), 0);
    return out;
}

# Build "skip outbound port N" or "skip inbound port N"
fn _skip_port_comment(direction: cstring, port: i64): cstring {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "skip ");
    str_builder_add_cstr(sb, direction);
    str_builder_add_cstr(sb, " port ");
    str_builder_add_int(sb, port);
    var s = str_builder_build(sb);
    var out = alloc(str_len(s) + 1);
    memcpy(out, str_data(s), str_len(s));
    store8(out + str_len(s), 0);
    return out;
}

# ================================================================
# Build chains
# ================================================================

fn _mesh_outbound_chain(m: i64): i64 {
    var c = chain_base("mesh_outbound", CHAIN_NAT, HOOK_OUTPUT, 0 - 100, POLICY_ACCEPT);

    # Skip proxy's own traffic
    var r = rule_new(verdict_return());
    rule_add_match(r, match_raw(_raw_meta_skuid(mesh_proxy_uid(m))));
    rule_set_comment(r, "skip proxy traffic");
    chain_add_rule(c, r);

    # Skip excluded CIDRs
    var cidrs = mesh_excl_out_cidrs(m);
    var clen = vec_len(cidrs);
    var i = 0;
    while (i < clen) {
        var cidr = vec_get(cidrs, i);
        r = rule_new(verdict_return());
        rule_add_match(r, match_dest_addr(cidr));
        rule_set_comment(r, _mesh_cstr_concat("skip outbound ", cidr));
        chain_add_rule(c, r);
        i = i + 1;
    }

    # Skip excluded ports
    var ports = mesh_excl_out_ports(m);
    var plen = vec_len(ports);
    i = 0;
    while (i < plen) {
        var port = vec_get(ports, i);
        r = rule_new(verdict_return());
        rule_add_match(r, match_protocol(PROTO_TCP));
        rule_add_match(r, match_dport(port));
        rule_set_comment(r, _skip_port_comment("outbound", port));
        chain_add_rule(c, r);
        i = i + 1;
    }

    # Redirect outbound TCP to proxy
    r = rule_new(verdict_accept());
    rule_add_match(r, match_raw(_raw_redirect(mesh_outbound_port(m))));
    rule_set_comment(r, "redirect outbound to proxy");
    chain_add_rule(c, r);

    return c;
}

fn _mesh_inbound_chain(m: i64): i64 {
    var c = chain_base("mesh_inbound", CHAIN_NAT, HOOK_PREROUTING, 0 - 100, POLICY_ACCEPT);

    var ports = mesh_excl_in_ports(m);
    var plen = vec_len(ports);
    var i = 0;
    while (i < plen) {
        var port = vec_get(ports, i);
        var r = rule_new(verdict_return());
        rule_add_match(r, match_protocol(PROTO_TCP));
        rule_add_match(r, match_dport(port));
        rule_set_comment(r, _skip_port_comment("inbound", port));
        chain_add_rule(c, r);
        i = i + 1;
    }

    var r = rule_new(verdict_accept());
    rule_add_match(r, match_raw(_raw_redirect(mesh_inbound_port(m))));
    rule_set_comment(r, "redirect inbound to proxy");
    chain_add_rule(c, r);

    return c;
}

fn mesh_to_firewall(m: i64): i64 {
    var fw = firewall_new();
    var t = table_new(mesh_table_name(m), FAMILY_IP);
    table_add_chain(t, _mesh_outbound_chain(m));
    table_add_chain(t, _mesh_inbound_chain(m));
    firewall_add_table(fw, t);
    return fw;
}

# --- bridge.cyr ---

# nein bridge module — container bridge firewall management

# ================================================================
# BridgeConfig — { bridge_name, subnet, outbound_iface, table_prefix }
# Layout: 4 fields * 8 = 32 bytes
# ================================================================

fn bridge_config_new(bridge_name: cstring, subnet: cstring, outbound_iface: cstring): i64 {
    var cfg = alloc(32);
    store64(cfg, bridge_name);
    store64(cfg + 8, subnet);
    store64(cfg + 16, outbound_iface);
    store64(cfg + 24, "nein");
    return cfg;
}

fn bridge_name(cfg: i64): i64 { return load64(cfg); }
fn bridge_subnet(cfg: i64): i64 { return load64(cfg + 8); }
fn bridge_outbound_iface(cfg: i64): i64 { return load64(cfg + 16); }
fn bridge_table_prefix(cfg: i64): i64 { return load64(cfg + 24); }

fn bridge_set_table_prefix(cfg: i64, prefix: cstring): i64 {
    store64(cfg + 24, prefix);
    return cfg;
}

fn bridge_config_validate(cfg: i64): i64 {
    var vr = validate_iface(bridge_name(cfg));
    if (is_err_result(vr) == 1) { return vr; }
    vr = validate_addr(bridge_subnet(cfg));
    if (is_err_result(vr) == 1) { return vr; }
    vr = validate_iface(bridge_outbound_iface(cfg));
    if (is_err_result(vr) == 1) { return vr; }
    vr = validate_identifier(bridge_table_prefix(cfg));
    if (is_err_result(vr) == 1) { return vr; }
    return nein_ok();
}

# ================================================================
# PortMapping — { host_port, container_addr, container_port, protocol }
# Layout: 4 * 8 = 32 bytes
# ================================================================

fn port_mapping_new(host_port: i64, container_addr: cstring, container_port: i64, protocol: i64): i64 {
    var pm = alloc(32);
    store64(pm, host_port);
    store64(pm + 8, container_addr);
    store64(pm + 16, container_port);
    store64(pm + 24, protocol);
    return pm;
}

fn pm_tcp(host_port: i64, container_addr: cstring, container_port: i64): i64 {
    return port_mapping_new(host_port, container_addr, container_port, PROTO_TCP);
}

fn pm_udp(host_port: i64, container_addr: cstring, container_port: i64): i64 {
    return port_mapping_new(host_port, container_addr, container_port, PROTO_UDP);
}

fn pm_host_port(pm: i64): i64 { return load64(pm); }
fn pm_container_addr(pm: i64): i64 { return load64(pm + 8); }
fn pm_container_port(pm: i64): i64 { return load64(pm + 16); }
fn pm_protocol(pm: i64): i64 { return load64(pm + 24); }

fn pm_validate(pm: i64): i64 {
    return validate_addr(pm_container_addr(pm));
}

# Build "portmap PROTO:HPORT -> ADDR:CPORT"
fn _pm_comment(pm: i64): cstring {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "portmap ");
    str_builder_add_cstr(sb, _proto_str(pm_protocol(pm)));
    str_builder_add_cstr(sb, ":");
    str_builder_add_int(sb, pm_host_port(pm));
    str_builder_add_cstr(sb, " -> ");
    str_builder_add_cstr(sb, pm_container_addr(pm));
    str_builder_add_cstr(sb, ":");
    str_builder_add_int(sb, pm_container_port(pm));
    var s = str_builder_build(sb);
    var out = alloc(str_len(s) + 1);
    memcpy(out, str_data(s), str_len(s));
    store8(out + str_len(s), 0);
    return out;
}

# Build "allow portmap -> ADDR:CPORT"
fn _pm_forward_comment(pm: i64): cstring {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "allow portmap -> ");
    str_builder_add_cstr(sb, pm_container_addr(pm));
    str_builder_add_cstr(sb, ":");
    str_builder_add_int(sb, pm_container_port(pm));
    var s = str_builder_build(sb);
    var out = alloc(str_len(s) + 1);
    memcpy(out, str_data(s), str_len(s));
    store8(out + str_len(s), 0);
    return out;
}

fn _pm_to_nat_rule(pm: i64): i64 {
    return nat_dnat(pm_protocol(pm), pm_host_port(pm), pm_container_addr(pm),
    pm_container_port(pm), _pm_comment(pm));
}

fn _pm_to_forward_rule(pm: i64): i64 {
    var r = rule_new(verdict_accept());
    rule_add_match(r, match_dest_addr(pm_container_addr(pm)));
    rule_add_match(r, match_protocol(pm_protocol(pm)));
    rule_add_match(r, match_dport(pm_container_port(pm)));
    rule_set_comment(r, _pm_forward_comment(pm));
    return r;
}

# ================================================================
# IsolationGroup — { name, cidrs(vec) }
# Layout: [name:8][cidrs:8] = 16 bytes
# ================================================================

fn isolation_group_new(name: cstring, cidrs: i64): i64 {
    var g = alloc(16);
    store64(g, name);
    store64(g + 8, cidrs);
    return g;
}

fn iso_name(g: i64): i64 { return load64(g); }
fn iso_cidrs(g: i64): i64 { return load64(g + 8); }

fn iso_validate(g: i64): i64 {
    var vr = validate_identifier(iso_name(g));
    if (is_err_result(vr) == 1) { return vr; }
    var cidrs = iso_cidrs(g);
    var clen = vec_len(cidrs);
    var i = 0;
    while (i < clen) {
        vr = validate_addr(vec_get(cidrs, i));
        if (is_err_result(vr) == 1) { return vr; }
        i = i + 1;
    }
    return nein_ok();
}

# ================================================================
# BridgeFirewall — { config, port_mappings(vec), isolation_groups(vec) }
# Layout: [config:8][pms:8][groups:8] = 24 bytes
# ================================================================

fn bridge_firewall_new(cfg: i64): i64 {
    var bf = alloc(24);
    store64(bf, cfg);
    store64(bf + 8, vec_new());
    store64(bf + 16, vec_new());
    return bf;
}

fn bf_config(bf: i64): i64 { return load64(bf); }
fn bf_port_mappings(bf: i64): i64 { return load64(bf + 8); }
fn bf_isolation_groups(bf: i64): i64 { return load64(bf + 16); }

# Returns the index of the new mapping, or Err on duplicate
fn bf_add_port_mapping(bf: i64, pm: i64): i64 {
    var pms = load64(bf + 8);
    var plen = vec_len(pms);
    var i = 0;
    while (i < plen) {
        var existing = vec_get(pms, i);
        if (pm_host_port(existing) == pm_host_port(pm)) {
            if (pm_protocol(existing) == pm_protocol(pm)) {
                return nein_err(ERR_INVALID_RULE);
            }
        }
        i = i + 1;
    }
    vec_push(pms, pm);
    return Ok(plen);
}

# Remove by host port + protocol; returns Some(pm) or None()
fn bf_remove_port_mapping(bf: i64, host_port: i64, protocol: i64): i64 {
    var pms = load64(bf + 8);
    var plen = vec_len(pms);
    var i = 0;
    while (i < plen) {
        var existing = vec_get(pms, i);
        if (pm_host_port(existing) == host_port) {
            if (pm_protocol(existing) == protocol) {
                # Rebuild vec without index i
                var new_pms = vec_new();
                var j = 0;
                while (j < plen) {
                    if (j != i) { vec_push(new_pms, vec_get(pms, j)); }
                    j = j + 1;
                }
                store64(bf + 8, new_pms);
                return Some(existing);
            }
        }
        i = i + 1;
    }
    return None();
}

fn bf_add_isolation_group(bf: i64, g: i64): i64 {
    vec_push(load64(bf + 16), g);
    return bf;
}

fn bf_validate(bf: i64): i64 {
    var vr = bridge_config_validate(bf_config(bf));
    if (is_err_result(vr) == 1) { return vr; }

    var pms = bf_port_mappings(bf);
    var plen = vec_len(pms);
    var i = 0;
    while (i < plen) {
        vr = pm_validate(vec_get(pms, i));
        if (is_err_result(vr) == 1) { return vr; }
        i = i + 1;
    }

    var groups = bf_isolation_groups(bf);
    var glen = vec_len(groups);
    i = 0;
    while (i < glen) {
        vr = iso_validate(vec_get(groups, i));
        if (is_err_result(vr) == 1) { return vr; }
        i = i + 1;
    }

    return nein_ok();
}

# --- Build helpers ---

# "PREFIX_SUFFIX" table name
fn _bf_table_name(prefix: cstring, suffix: cstring): cstring {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, prefix);
    str_builder_add_cstr(sb, suffix);
    var s = str_builder_build(sb);
    var out = alloc(str_len(s) + 1);
    memcpy(out, str_data(s), str_len(s));
    store8(out + str_len(s), 0);
    return out;
}

# "iso_NAME" set name
fn _iso_set_name(name: cstring): cstring {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "iso_");
    str_builder_add_cstr(sb, name);
    var s = str_builder_build(sb);
    var out = alloc(str_len(s) + 1);
    memcpy(out, str_data(s), str_len(s));
    store8(out + str_len(s), 0);
    return out;
}

# "intra-group: NAME"
fn _iso_comment(name: cstring): cstring {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "intra-group: ");
    str_builder_add_cstr(sb, name);
    var s = str_builder_build(sb);
    var out = alloc(str_len(s) + 1);
    memcpy(out, str_data(s), str_len(s));
    store8(out + str_len(s), 0);
    return out;
}

fn _bf_build_filter(bf: i64): i64 {
    var cfg = bf_config(bf);
    var t = table_new(_bf_table_name(bridge_table_prefix(cfg), "_filter"), FAMILY_INET);

    var forward = chain_base("forward", CHAIN_FILTER, HOOK_FORWARD, 0, POLICY_DROP);

    # Allow established/related
    chain_add_rule(forward, allow_established());

    # Port mapping forward allows
    var pms = bf_port_mappings(bf);
    var plen = vec_len(pms);
    var i = 0;
    while (i < plen) {
        chain_add_rule(forward, _pm_to_forward_rule(vec_get(pms, i)));
        i = i + 1;
    }

    var groups = bf_isolation_groups(bf);
    var glen = vec_len(groups);

    if (glen == 0) {
        # No isolation: allow all bridge traffic
        var r1 = rule_new(verdict_accept());
        rule_add_match(r1, match_iif(bridge_name(cfg)));
        rule_add_match(r1, match_oif(bridge_outbound_iface(cfg)));
        rule_set_comment(r1, "bridge to outbound");
        chain_add_rule(forward, r1);

        var r2 = rule_new(verdict_accept());
        rule_add_match(r2, match_iif(bridge_name(cfg)));
        rule_add_match(r2, match_oif(bridge_name(cfg)));
        rule_set_comment(r2, "intra-bridge");
        chain_add_rule(forward, r2);
    } else {
        # With isolation: bridge -> outbound for all groups, then per-group set lookups
        var rb = rule_new(verdict_accept());
        rule_add_match(rb, match_iif(bridge_name(cfg)));
        rule_add_match(rb, match_oif(bridge_outbound_iface(cfg)));
        rule_set_comment(rb, "bridge to outbound");
        chain_add_rule(forward, rb);

        i = 0;
        while (i < glen) {
            var g = vec_get(groups, i);
            var cidrs = iso_cidrs(g);
            var clen = vec_len(cidrs);
            if (clen > 0) {
                var sname = _iso_set_name(iso_name(g));
                var set = nft_set_new(sname, SET_IPV4_ADDR);
                nft_set_add_flag(set, SETFLAG_INTERVAL);
                var j = 0;
                while (j < clen) {
                    nft_set_add_element(set, vec_get(cidrs, j));
                    j = j + 1;
                }
                table_add_set(t, set);

                var r = rule_new(verdict_accept());
                rule_add_match(r, match_set_lookup("ip saddr", sname));
                rule_add_match(r, match_set_lookup("ip daddr", sname));
                rule_set_comment(r, _iso_comment(iso_name(g)));
                chain_add_rule(forward, r);
            }
            i = i + 1;
        }
    }

    table_add_chain(t, forward);
    return t;
}

fn _bf_build_nat(bf: i64): i64 {
    var cfg = bf_config(bf);
    var t = table_new(_bf_table_name(bridge_table_prefix(cfg), "_nat"), FAMILY_IP);

    var pms = bf_port_mappings(bf);
    var plen = vec_len(pms);

    # Prerouting only if there are port mappings
    if (plen > 0) {
        var prerouting = chain_base("prerouting", CHAIN_NAT, HOOK_PREROUTING, 0 - 100, POLICY_ACCEPT);
        var i = 0;
        while (i < plen) {
            chain_add_nat_rule(prerouting, _pm_to_nat_rule(vec_get(pms, i)));
            i = i + 1;
        }
        table_add_chain(t, prerouting);
    }

    # Postrouting: masquerade
    var postrouting = chain_base("postrouting", CHAIN_NAT, HOOK_POSTROUTING, 100, POLICY_ACCEPT);
    chain_add_nat_rule(postrouting, container_masquerade(bridge_subnet(cfg), bridge_outbound_iface(cfg)));
    table_add_chain(t, postrouting);

    return t;
}

fn bf_to_firewall(bf: i64): i64 {
    var fw = firewall_new();
    firewall_add_table(fw, _bf_build_filter(bf));
    firewall_add_table(fw, _bf_build_nat(bf));
    return fw;
}

# --- engine.cyr ---

# nein engine module — multi-agent policy engine
#
# Manages network policies across multiple agents, generating a coherent
# nftables firewall from all active policies.

# ================================================================
# Transport enum — distinguishes TCP, UDP, and QUIC (QUIC maps to UDP protocol)
# ================================================================

enum TransportEnum {
    TRANS_TCP = 1;
    TRANS_UDP = 2;
    TRANS_QUIC = 3;
}

fn transport_protocol(t: i64): i64 {
    if (t == TRANS_TCP) { return PROTO_TCP; }
    return PROTO_UDP;
}

fn transport_label(t: i64): cstring {
    if (t == TRANS_TCP) { return "tcp"; }
    if (t == TRANS_UDP) { return "udp"; }
    if (t == TRANS_QUIC) { return "quic"; }
    return "tcp";
}

# ================================================================
# PortSpec — { protocol, port, transport }
# Layout: [protocol:8][port:8][transport:8] = 24 bytes
# ================================================================

fn port_spec_new(protocol: i64, port: i64, transport: i64): i64 {
    var ps = alloc(24);
    store64(ps, protocol);
    store64(ps + 8, port);
    store64(ps + 16, transport);
    return ps;
}

fn ps_tcp(port: i64): i64 { return port_spec_new(PROTO_TCP, port, TRANS_TCP); }
fn ps_udp(port: i64): i64 { return port_spec_new(PROTO_UDP, port, TRANS_UDP); }
fn ps_quic(port: i64): i64 { return port_spec_new(PROTO_UDP, port, TRANS_QUIC); }

fn ps_protocol(ps: i64): i64 { return load64(ps); }
fn ps_port(ps: i64): i64 { return load64(ps + 8); }
fn ps_transport(ps: i64): i64 { return load64(ps + 16); }

# ================================================================
# AgentPolicy — { agent_id, agent_addr, allowed_inbound(vec),
#   allowed_outbound(vec), allowed_outbound_hosts(vec),
#   allow_established, allow_loopback }
# Layout: 7 fields * 8 = 56 bytes
# ================================================================

fn agent_policy_new(agent_id: cstring, agent_addr: cstring): i64 {
    var ap = alloc(56);
    store64(ap, agent_id);
    store64(ap + 8, agent_addr);
    store64(ap + 16, vec_new());
    store64(ap + 24, vec_new());
    store64(ap + 32, vec_new());
    store64(ap + 40, 1);       # allow_established default true
    store64(ap + 48, 1);       # allow_loopback default true
    return ap;
}

fn ap_agent_id(ap: i64): i64 { return load64(ap); }
fn ap_agent_addr(ap: i64): i64 { return load64(ap + 8); }
fn ap_allowed_inbound(ap: i64): i64 { return load64(ap + 16); }
fn ap_allowed_outbound(ap: i64): i64 { return load64(ap + 24); }
fn ap_allowed_outbound_hosts(ap: i64): i64 { return load64(ap + 32); }
fn ap_allow_established(ap: i64): i64 { return load64(ap + 40); }
fn ap_allow_loopback(ap: i64): i64 { return load64(ap + 48); }

fn ap_allow_inbound(ap: i64, ps: i64): i64 { vec_push(load64(ap + 16), ps); return ap; }
fn ap_allow_outbound(ap: i64, ps: i64): i64 { vec_push(load64(ap + 24), ps); return ap; }
fn ap_allow_outbound_host(ap: i64, cidr: cstring): i64 { vec_push(load64(ap + 32), cidr); return ap; }
fn ap_set_allow_established(ap: i64, flag: i64): i64 { store64(ap + 40, flag); return ap; }
fn ap_set_allow_loopback(ap: i64, flag: i64): i64 { store64(ap + 48, flag); return ap; }

fn ap_validate(ap: i64): i64 {
    var vr = validate_identifier(ap_agent_id(ap));
    if (is_err_result(vr) == 1) { return vr; }
    vr = validate_addr(ap_agent_addr(ap));
    if (is_err_result(vr) == 1) { return vr; }
    var hosts = ap_allowed_outbound_hosts(ap);
    var hlen = vec_len(hosts);
    var i = 0;
    while (i < hlen) {
        vr = validate_addr(vec_get(hosts, i));
        if (is_err_result(vr) == 1) { return vr; }
        i = i + 1;
    }
    return nein_ok();
}

# ================================================================
# Comment builders for engine rules
# ================================================================

fn _cstr_from_sb(sb: i64): cstring {
    var s = str_builder_build(sb);
    var out = alloc(str_len(s) + 1);
    memcpy(out, str_data(s), str_len(s));
    store8(out + str_len(s), 0);
    return out;
}

# "AGENT_ID loopback"
fn _loopback_comment(agent_id: cstring): cstring {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, agent_id);
    str_builder_add_cstr(sb, " loopback");
    return _cstr_from_sb(sb);
}

# "AGENT_ID loopback out"
fn _loopback_out_comment(agent_id: cstring): cstring {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, agent_id);
    str_builder_add_cstr(sb, " loopback out");
    return _cstr_from_sb(sb);
}

# "AGENT_ID DIR LABEL:PORT"
fn _port_comment(agent_id: cstring, direction: cstring, label: cstring, port: i64): cstring {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, agent_id);
    str_builder_add_cstr(sb, " ");
    str_builder_add_cstr(sb, direction);
    str_builder_add_cstr(sb, " ");
    str_builder_add_cstr(sb, label);
    str_builder_add_cstr(sb, ":");
    str_builder_add_int(sb, port);
    return _cstr_from_sb(sb);
}

# "AGENT_ID outbound LABEL:PORT restricted"
fn _port_restricted_comment(agent_id: cstring, label: cstring, port: i64): cstring {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, agent_id);
    str_builder_add_cstr(sb, " outbound ");
    str_builder_add_cstr(sb, label);
    str_builder_add_cstr(sb, ":");
    str_builder_add_int(sb, port);
    str_builder_add_cstr(sb, " restricted");
    return _cstr_from_sb(sb);
}

# "AGENT_ID default deny DIR"
fn _default_deny_comment(agent_id: cstring, direction: cstring): cstring {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, agent_id);
    str_builder_add_cstr(sb, " default deny ");
    str_builder_add_cstr(sb, direction);
    return _cstr_from_sb(sb);
}

# "dispatch DIR to/from AGENT_ID"
fn _dispatch_comment(direction: cstring, preposition: cstring, agent_id: cstring): cstring {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "dispatch ");
    str_builder_add_cstr(sb, direction);
    str_builder_add_cstr(sb, " ");
    str_builder_add_cstr(sb, preposition);
    str_builder_add_cstr(sb, " ");
    str_builder_add_cstr(sb, agent_id);
    return _cstr_from_sb(sb);
}

# "AGENT_ID_in" or "AGENT_ID_out"
fn _chain_name(agent_id: cstring, suffix: cstring): cstring {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, agent_id);
    str_builder_add_cstr(sb, suffix);
    return _cstr_from_sb(sb);
}

# "AGENT_ID_hosts" — set name for host restrictions
fn _host_set_name(agent_id: cstring): cstring {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, agent_id);
    str_builder_add_cstr(sb, "_hosts");
    return _cstr_from_sb(sb);
}

# ================================================================
# Build rules for an agent
# ================================================================

fn _ap_build_inbound_rules(ap: i64): i64 {
    var rules = vec_new();
    var agent_id = ap_agent_id(ap);

    if (ap_allow_established(ap) == 1) {
        vec_push(rules, allow_established());
    }

    if (ap_allow_loopback(ap) == 1) {
        var r = rule_new(verdict_accept());
        rule_add_match(r, match_iif("lo"));
        rule_set_comment(r, _loopback_comment(agent_id));
        vec_push(rules, r);
    }

    var specs = ap_allowed_inbound(ap);
    var slen = vec_len(specs);
    var i = 0;
    while (i < slen) {
        var ps = vec_get(specs, i);
        var r = rule_new(verdict_accept());
        rule_add_match(r, match_protocol(ps_protocol(ps)));
        rule_add_match(r, match_dport(ps_port(ps)));
        rule_set_comment(r, _port_comment(agent_id, "inbound", transport_label(ps_transport(ps)), ps_port(ps)));
        vec_push(rules, r);
        i = i + 1;
    }

    return rules;
}

# Returns [rules_vec, host_set_or_0]
# Stored as 16 bytes: [rules:8][set:8]
fn _ap_build_outbound_rules(ap: i64): i64 {
    var result = alloc(16);
    var rules = vec_new();
    var agent_id = ap_agent_id(ap);

    if (ap_allow_established(ap) == 1) {
        vec_push(rules, allow_established());
    }

    if (ap_allow_loopback(ap) == 1) {
        var r = rule_new(verdict_accept());
        rule_add_match(r, match_oif("lo"));
        rule_set_comment(r, _loopback_out_comment(agent_id));
        vec_push(rules, r);
    }

    # Build host restriction set if there are any
    var host_set = 0;
    var hosts = ap_allowed_outbound_hosts(ap);
    var hlen = vec_len(hosts);
    if (hlen > 0) {
        var set_name = _host_set_name(agent_id);
        host_set = nft_set_new(set_name, SET_IPV4_ADDR);
        nft_set_add_flag(host_set, SETFLAG_INTERVAL);
        var i = 0;
        while (i < hlen) {
            nft_set_add_element(host_set, vec_get(hosts, i));
            i = i + 1;
        }
    }

    var specs = ap_allowed_outbound(ap);
    var slen = vec_len(specs);
    var i = 0;
    while (i < slen) {
        var ps = vec_get(specs, i);
        var r = rule_new(verdict_accept());
        rule_add_match(r, match_protocol(ps_protocol(ps)));
        rule_add_match(r, match_dport(ps_port(ps)));
        if (host_set != 0) {
            rule_add_match(r, match_set_lookup("ip daddr", nft_set_name(host_set)));
            rule_set_comment(r, _port_restricted_comment(agent_id, transport_label(ps_transport(ps)), ps_port(ps)));
        } else {
            rule_set_comment(r, _port_comment(agent_id, "outbound", transport_label(ps_transport(ps)), ps_port(ps)));
        }
        vec_push(rules, r);
        i = i + 1;
    }

    store64(result, rules);
    store64(result + 8, host_set);
    return result;
}

# ================================================================
# PolicyEngine — { agents(vec of AgentPolicy, ordered by agent_id),
#   table_name }
# Layout: [agents:8][table_name:8] = 16 bytes
# ================================================================

fn policy_engine_new(): i64 {
    var pe = alloc(16);
    store64(pe, vec_new());
    store64(pe + 8, "nein_agents");
    return pe;
}

fn pe_agents(pe: i64): i64 { return load64(pe); }
fn pe_table_name(pe: i64): i64 { return load64(pe + 8); }

fn pe_set_table_name(pe: i64, name: cstring): i64 {
    store64(pe + 8, name);
    return pe;
}

fn pe_agent_count(pe: i64): i64 { return vec_len(load64(pe)); }

# Find agent index by id (returns 0-based index or -1)
fn _pe_find_index(pe: i64, agent_id: cstring): i64 {
    var agents = load64(pe);
    var alen = vec_len(agents);
    var i = 0;
    while (i < alen) {
        if (streq(ap_agent_id(vec_get(agents, i)), agent_id) == 1) { return i; }
        i = i + 1;
    }
    return 0 - 1;
}

# Byte-wise C-string comparison: returns -1, 0, or 1
fn _strcmp_cstr(a: cstring, b: cstring): i64 {
    var i = 0;
    while (1) {
        var ca = load8(a + i);
        var cb = load8(b + i);
        if (ca != cb) {
            if (ca < cb) { return 0 - 1; }
            return 1;
        }
        if (ca == 0) { return 0; }
        i = i + 1;
    }
    return 0;
}

# Insert while maintaining sorted-by-agent_id order
fn _pe_insert_sorted(pe: i64, policy: i64): i64 {
    var agents = load64(pe);
    var alen = vec_len(agents);
    var new_agents = vec_new();
    var aid = ap_agent_id(policy);
    var inserted = 0;
    var i = 0;
    while (i < alen) {
        var existing = vec_get(agents, i);
        if (inserted == 0) {
            if (_strcmp_cstr(ap_agent_id(existing), aid) > 0) {
                vec_push(new_agents, policy);
                inserted = 1;
            }
        }
        vec_push(new_agents, existing);
        i = i + 1;
    }
    if (inserted == 0) { vec_push(new_agents, policy); }
    store64(pe, new_agents);
    return 0;
}

# Add or update an agent. Returns Some(prev_policy) on update, None on new.
fn pe_add_agent(pe: i64, policy: i64): i64 {
    var idx = _pe_find_index(pe, ap_agent_id(policy));
    if (idx >= 0) {
        var agents = load64(pe);
        var prev = vec_get(agents, idx);
        # Replace in place: rebuild vec with policy substituted
        var new_agents = vec_new();
        var alen = vec_len(agents);
        var i = 0;
        while (i < alen) {
            if (i == idx) { vec_push(new_agents, policy); }
            else { vec_push(new_agents, vec_get(agents, i)); }
            i = i + 1;
        }
        store64(pe, new_agents);
        return Some(prev);
    }
    _pe_insert_sorted(pe, policy);
    return None();
}

fn pe_remove_agent(pe: i64, agent_id: cstring): i64 {
    var idx = _pe_find_index(pe, agent_id);
    if (idx < 0) { return None(); }
    var agents = load64(pe);
    var removed = vec_get(agents, idx);
    var new_agents = vec_new();
    var alen = vec_len(agents);
    var i = 0;
    while (i < alen) {
        if (i != idx) { vec_push(new_agents, vec_get(agents, i)); }
        i = i + 1;
    }
    store64(pe, new_agents);
    return Some(removed);
}

fn pe_get_agent(pe: i64, agent_id: cstring): i64 {
    var idx = _pe_find_index(pe, agent_id);
    if (idx < 0) { return None(); }
    return Some(vec_get(load64(pe), idx));
}

fn pe_validate(pe: i64): i64 {
    var vr = validate_identifier(pe_table_name(pe));
    if (is_err_result(vr) == 1) { return vr; }
    var agents = pe_agents(pe);
    var alen = vec_len(agents);
    var i = 0;
    while (i < alen) {
        vr = ap_validate(vec_get(agents, i));
        if (is_err_result(vr) == 1) { return vr; }
        i = i + 1;
    }
    return nein_ok();
}

# ================================================================
# Build the full firewall
# ================================================================

fn pe_to_firewall(pe: i64): i64 {
    var fw = firewall_new();
    var agents = pe_agents(pe);
    var alen = vec_len(agents);
    if (alen == 0) { return fw; }

    var t = table_new(pe_table_name(pe), FAMILY_INET);

    var input = chain_base("input", CHAIN_FILTER, HOOK_INPUT, 0, POLICY_DROP);
    var output = chain_base("output", CHAIN_FILTER, HOOK_OUTPUT, 0, POLICY_DROP);

    var i = 0;
    while (i < alen) {
        var policy = vec_get(agents, i);
        var agent_id = ap_agent_id(policy);
        var agent_addr = ap_agent_addr(policy);

        # Dispatch inbound
        var in_name = _chain_name(agent_id, "_in");
        var out_name = _chain_name(agent_id, "_out");

        var disp_in = rule_new(verdict_jump(in_name));
        rule_add_match(disp_in, match_dest_addr(agent_addr));
        rule_set_comment(disp_in, _dispatch_comment("inbound", "to", agent_id));
        chain_add_rule(input, disp_in);

        var disp_out = rule_new(verdict_jump(out_name));
        rule_add_match(disp_out, match_source_addr(agent_addr));
        rule_set_comment(disp_out, _dispatch_comment("outbound", "from", agent_id));
        chain_add_rule(output, disp_out);

        # Per-agent inbound chain
        var in_chain = chain_regular(in_name);
        var in_rules = _ap_build_inbound_rules(policy);
        var irlen = vec_len(in_rules);
        var j = 0;
        while (j < irlen) {
            chain_add_rule(in_chain, vec_get(in_rules, j));
            j = j + 1;
        }
        var deny_in = rule_new(verdict_drop());
        rule_set_comment(deny_in, _default_deny_comment(agent_id, "inbound"));
        chain_add_rule(in_chain, deny_in);
        table_add_chain(t, in_chain);

        # Per-agent outbound chain
        var out_chain = chain_regular(out_name);
        var out_result = _ap_build_outbound_rules(policy);
        var host_set = load64(out_result + 8);
        if (host_set != 0) {
            table_add_set(t, host_set);
        }
        var out_rules = load64(out_result);
        var orlen = vec_len(out_rules);
        j = 0;
        while (j < orlen) {
            chain_add_rule(out_chain, vec_get(out_rules, j));
            j = j + 1;
        }
        var deny_out = rule_new(verdict_drop());
        rule_set_comment(deny_out, _default_deny_comment(agent_id, "outbound"));
        chain_add_rule(out_chain, deny_out);
        table_add_chain(t, out_chain);

        i = i + 1;
    }

    table_add_chain(t, input);
    table_add_chain(t, output);
    firewall_add_table(fw, t);
    return fw;
}

# --- config.cyr ---

# nein config module — string to enum dispatch helpers
#
# Parse string values from config sources (TOML/JSON/CLI) into nein enum
# constants. Returns the enum value on success or -1 on error.
# Consumers (sutra, CLI tools) layer TOML/JSON/etc. on top.
#
# The scope here is intentionally narrow: the enum dispatch layer.
# Full TOML struct parsing awaits sutra's port.

# -1 is the sentinel for "unknown value". All nein enum constants start at 1.
fn _cfg_unknown(): i64 { return 0 - 1; }

# --- Family ---
fn cfg_parse_family(s: cstring): i64 {
    if (streq(s, "inet") == 1) { return FAMILY_INET; }
    if (streq(s, "ip") == 1) { return FAMILY_IP; }
    if (streq(s, "ip6") == 1) { return FAMILY_IP6; }
    if (streq(s, "arp") == 1) { return FAMILY_ARP; }
    if (streq(s, "bridge") == 1) { return FAMILY_BRIDGE; }
    if (streq(s, "netdev") == 1) { return FAMILY_NETDEV; }
    return _cfg_unknown();
}

# --- ChainType ---
fn cfg_parse_chain_type(s: cstring): i64 {
    if (streq(s, "filter") == 1) { return CHAIN_FILTER; }
    if (streq(s, "nat") == 1) { return CHAIN_NAT; }
    if (streq(s, "route") == 1) { return CHAIN_ROUTE; }
    return _cfg_unknown();
}

# --- Hook ---
fn cfg_parse_hook(s: cstring): i64 {
    if (streq(s, "prerouting") == 1) { return HOOK_PREROUTING; }
    if (streq(s, "input") == 1) { return HOOK_INPUT; }
    if (streq(s, "forward") == 1) { return HOOK_FORWARD; }
    if (streq(s, "output") == 1) { return HOOK_OUTPUT; }
    if (streq(s, "postrouting") == 1) { return HOOK_POSTROUTING; }
    if (streq(s, "ingress") == 1) { return HOOK_INGRESS; }
    return _cfg_unknown();
}

# --- Policy ---
fn cfg_parse_policy(s: cstring): i64 {
    if (streq(s, "accept") == 1) { return POLICY_ACCEPT; }
    if (streq(s, "drop") == 1) { return POLICY_DROP; }
    return _cfg_unknown();
}

# --- Protocol ---
fn cfg_parse_protocol(s: cstring): i64 {
    if (streq(s, "tcp") == 1) { return PROTO_TCP; }
    if (streq(s, "udp") == 1) { return PROTO_UDP; }
    if (streq(s, "icmp") == 1) { return PROTO_ICMP; }
    if (streq(s, "icmpv6") == 1) { return PROTO_ICMPV6; }
    return _cfg_unknown();
}

# --- RateUnit ---
fn cfg_parse_rate_unit(s: cstring): i64 {
    if (streq(s, "second") == 1) { return RATE_SECOND; }
    if (streq(s, "minute") == 1) { return RATE_MINUTE; }
    if (streq(s, "hour") == 1) { return RATE_HOUR; }
    if (streq(s, "day") == 1) { return RATE_DAY; }
    return _cfg_unknown();
}

# --- QuotaMode ---
fn cfg_parse_quota_mode(s: cstring): i64 {
    if (streq(s, "over") == 1) { return QUOTA_OVER; }
    if (streq(s, "until") == 1) { return QUOTA_UNTIL; }
    return _cfg_unknown();
}

# --- QuotaUnit ---
fn cfg_parse_quota_unit(s: cstring): i64 {
    if (streq(s, "bytes") == 1) { return QUNIT_BYTES; }
    if (streq(s, "kbytes") == 1) { return QUNIT_KBYTES; }
    if (streq(s, "mbytes") == 1) { return QUNIT_MBYTES; }
    if (streq(s, "gbytes") == 1) { return QUNIT_GBYTES; }
    return _cfg_unknown();
}

# --- PktType ---
fn cfg_parse_pkt_type(s: cstring): i64 {
    if (streq(s, "unicast") == 1) { return PKT_UNICAST; }
    if (streq(s, "broadcast") == 1) { return PKT_BROADCAST; }
    if (streq(s, "multicast") == 1) { return PKT_MULTICAST; }
    return _cfg_unknown();
}

# --- Ipv6ExtHdr ---
fn cfg_parse_ipv6_ext_hdr(s: cstring): i64 {
    if (streq(s, "hbh") == 1) { return EXT_HOP_BY_HOP; }
    if (streq(s, "rt") == 1) { return EXT_ROUTING; }
    if (streq(s, "frag") == 1) { return EXT_FRAGMENT; }
    if (streq(s, "dst") == 1) { return EXT_DESTINATION; }
    if (streq(s, "mh") == 1) { return EXT_MOBILITY; }
    if (streq(s, "auth") == 1) { return EXT_AUTH; }
    return _cfg_unknown();
}

# --- CmpOp ---
fn cfg_parse_cmp_op(s: cstring): i64 {
    if (streq(s, "==") == 1) { return NFT_CMP_EQ; }
    if (streq(s, "!=") == 1) { return NFT_CMP_NE; }
    if (streq(s, "<") == 1) { return NFT_CMP_LT; }
    if (streq(s, ">") == 1) { return NFT_CMP_GT; }
    if (streq(s, "<=") == 1) { return NFT_CMP_LE; }
    if (streq(s, ">=") == 1) { return NFT_CMP_GE; }
    return _cfg_unknown();
}

# --- LogLevel ---
fn cfg_parse_log_level(s: cstring): i64 {
    if (streq(s, "emerg") == 1) { return NFT_LOG_EMERG; }
    if (streq(s, "alert") == 1) { return NFT_LOG_ALERT; }
    if (streq(s, "crit") == 1) { return NFT_LOG_CRIT; }
    if (streq(s, "err") == 1) { return NFT_LOG_ERR; }
    if (streq(s, "warn") == 1) { return NFT_LOG_WARN; }
    if (streq(s, "notice") == 1) { return NFT_LOG_NOTICE; }
    if (streq(s, "info") == 1) { return NFT_LOG_INFO; }
    if (streq(s, "debug") == 1) { return NFT_LOG_DEBUG; }
    return _cfg_unknown();
}

# --- RejectReason ---
fn cfg_parse_reject_reason(s: cstring): i64 {
    if (streq(s, "icmp-host-unreachable") == 1) { return REJECT_ICMP_HOST_UNREACH; }
    if (streq(s, "icmp-port-unreachable") == 1) { return REJECT_ICMP_PORT_UNREACH; }
    if (streq(s, "icmp-net-unreachable") == 1) { return REJECT_ICMP_NET_UNREACH; }
    if (streq(s, "icmp-admin-prohibited") == 1) { return REJECT_ICMP_ADMIN_PROHIB; }
    if (streq(s, "icmpx-admin-prohibited") == 1) { return REJECT_ICMPX_ADMIN_PROHIB; }
    if (streq(s, "tcp-reset") == 1) { return REJECT_TCP_RESET; }
    return _cfg_unknown();
}

# --- SetType ---
fn cfg_parse_set_type(s: cstring): i64 {
    if (streq(s, "ipv4_addr") == 1) { return SET_IPV4_ADDR; }
    if (streq(s, "ipv6_addr") == 1) { return SET_IPV6_ADDR; }
    if (streq(s, "inet_service") == 1) { return SET_INET_SERVICE; }
    if (streq(s, "inet_proto") == 1) { return SET_INET_PROTO; }
    if (streq(s, "ifname") == 1) { return SET_IFNAME; }
    return _cfg_unknown();
}

# --- SetFlag ---
fn cfg_parse_set_flag(s: cstring): i64 {
    if (streq(s, "constant") == 1) { return SETFLAG_CONSTANT; }
    if (streq(s, "interval") == 1) { return SETFLAG_INTERVAL; }
    if (streq(s, "timeout") == 1) { return SETFLAG_TIMEOUT; }
    return _cfg_unknown();
}

# --- Transport (engine) ---
fn cfg_parse_transport(s: cstring): i64 {
    if (streq(s, "tcp") == 1) { return TRANS_TCP; }
    if (streq(s, "udp") == 1) { return TRANS_UDP; }
    if (streq(s, "quic") == 1) { return TRANS_QUIC; }
    return _cfg_unknown();
}

# --- Helper: wrap result as Result<int, NEIN_ERR_PARSE> ---
# Useful when a parse function wants consistent error handling
fn cfg_result(v: i64): i64 {
    if (v < 0) { return nein_err(NEIN_ERR_PARSE); }
    return Ok(v);
}

# --- netns.cyr ---

# nein netns module — network namespace firewall builder
#
# Builds a Firewall tailored for agent network namespaces (input/output
# chains, established tracking, loopback, optional DNS). The actual
# apply-to-namespace side is provided by agnosys's netns.cyr:
# `netns_apply_nftables_ruleset(handle, ruleset)` — consumers vendor
# agnosys's netns module directly and pass `firewall_render(fw)` into it.
#
# This module stays lean (builder only) so the core nein library doesn't
# transitively drag in agnosys's full netns implementation.

# ================================================================
# NamespaceFirewall — builder state
# Layout:
#   [agent_name:8][inbound:8][outbound:8][outbound_hosts:8]
#   [allow_established:8][allow_loopback:8][allow_dns:8]
#   [inbound_policy:8][outbound_policy:8]
# = 9 * 8 = 72 bytes
# ================================================================

fn namespace_firewall_new(agent_name: cstring): i64 {
    var nsf = alloc(72);
    store64(nsf, agent_name);
    store64(nsf + 8, vec_new());      # allowed_inbound
    store64(nsf + 16, vec_new());     # allowed_outbound
    store64(nsf + 24, vec_new());     # allowed_outbound_hosts
    store64(nsf + 32, 1);             # allow_established (default on)
    store64(nsf + 40, 1);             # allow_loopback (default on)
    store64(nsf + 48, 1);             # allow_dns (default on)
    store64(nsf + 56, POLICY_DROP);   # inbound_policy (default drop)
    store64(nsf + 64, POLICY_ACCEPT); # outbound_policy (default accept)
    return nsf;
}

fn nsf_agent_name(nsf: i64): i64 { return load64(nsf); }
fn nsf_inbound(nsf: i64): i64 { return load64(nsf + 8); }
fn nsf_outbound(nsf: i64): i64 { return load64(nsf + 16); }
fn nsf_outbound_hosts(nsf: i64): i64 { return load64(nsf + 24); }
fn nsf_allow_established(nsf: i64): i64 { return load64(nsf + 32); }
fn nsf_allow_loopback(nsf: i64): i64 { return load64(nsf + 40); }
fn nsf_allow_dns(nsf: i64): i64 { return load64(nsf + 48); }
fn nsf_inbound_policy(nsf: i64): i64 { return load64(nsf + 56); }
fn nsf_outbound_policy(nsf: i64): i64 { return load64(nsf + 64); }

fn nsf_allow_inbound(nsf: i64, ps: i64): i64 { vec_push(load64(nsf + 8), ps); return nsf; }
fn nsf_allow_outbound(nsf: i64, ps: i64): i64 { vec_push(load64(nsf + 16), ps); return nsf; }
fn nsf_allow_outbound_host(nsf: i64, cidr: cstring): i64 { vec_push(load64(nsf + 24), cidr); return nsf; }
fn nsf_set_inbound_policy(nsf: i64, p: i64): i64 { store64(nsf + 56, p); return nsf; }
fn nsf_set_outbound_policy(nsf: i64, p: i64): i64 { store64(nsf + 64, p); return nsf; }
fn nsf_no_established(nsf: i64): i64 { store64(nsf + 32, 0); return nsf; }
fn nsf_no_loopback(nsf: i64): i64 { store64(nsf + 40, 0); return nsf; }
fn nsf_no_dns(nsf: i64): i64 { store64(nsf + 48, 0); return nsf; }

# ================================================================
# Comment builders
# ================================================================

fn _nsf_cstr_from_sb(sb: i64): cstring {
    var s = str_builder_build(sb);
    var out = alloc(str_len(s) + 1);
    memcpy(out, str_data(s), str_len(s));
    store8(out + str_len(s), 0);
    return out;
}

# "AGENT loopback"
fn _nsf_loopback_comment(agent_name: cstring): cstring {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, agent_name);
    str_builder_add_cstr(sb, " loopback");
    return _nsf_cstr_from_sb(sb);
}

# "AGENT loopback out"
fn _nsf_loopback_out_comment(agent_name: cstring): cstring {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, agent_name);
    str_builder_add_cstr(sb, " loopback out");
    return _nsf_cstr_from_sb(sb);
}

# "AGENT dns"
fn _nsf_dns_comment(agent_name: cstring): cstring {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, agent_name);
    str_builder_add_cstr(sb, " dns");
    return _nsf_cstr_from_sb(sb);
}

# "AGENT DIR PROTO:PORT"
fn _nsf_port_comment(agent_name: cstring, direction: cstring, protocol: i64, port: i64): cstring {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, agent_name);
    str_builder_add_cstr(sb, " ");
    str_builder_add_cstr(sb, direction);
    str_builder_add_cstr(sb, " ");
    str_builder_add_cstr(sb, _proto_str(protocol));
    str_builder_add_cstr(sb, ":");
    str_builder_add_int(sb, port);
    return _nsf_cstr_from_sb(sb);
}

# "AGENT outbound PROTO:PORT -> HOST"
fn _nsf_outbound_host_comment(agent_name: cstring, protocol: i64, port: i64, host: cstring): cstring {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, agent_name);
    str_builder_add_cstr(sb, " outbound ");
    str_builder_add_cstr(sb, _proto_str(protocol));
    str_builder_add_cstr(sb, ":");
    str_builder_add_int(sb, port);
    str_builder_add_cstr(sb, " -> ");
    str_builder_add_cstr(sb, host);
    return _nsf_cstr_from_sb(sb);
}

# ================================================================
# Build the Firewall
# ================================================================

fn nsf_build(nsf: i64): i64 {
    var fw = firewall_new();
    var t = table_new("agnos_agent", FAMILY_INET);
    var agent_name = nsf_agent_name(nsf);

    # Input chain
    var input = chain_base("input", CHAIN_FILTER, HOOK_INPUT, 0, nsf_inbound_policy(nsf));

    if (nsf_allow_established(nsf) == 1) {
        chain_add_rule(input, allow_established());
    }
    if (nsf_allow_loopback(nsf) == 1) {
        var r = rule_new(verdict_accept());
        rule_add_match(r, match_iif("lo"));
        rule_set_comment(r, _nsf_loopback_comment(agent_name));
        chain_add_rule(input, r);
    }

    var in_specs = nsf_inbound(nsf);
    var ilen = vec_len(in_specs);
    var i = 0;
    while (i < ilen) {
        var ps = vec_get(in_specs, i);
        var r = rule_new(verdict_accept());
        rule_add_match(r, match_protocol(ps_protocol(ps)));
        rule_add_match(r, match_dport(ps_port(ps)));
        rule_set_comment(r, _nsf_port_comment(agent_name, "inbound", ps_protocol(ps), ps_port(ps)));
        chain_add_rule(input, r);
        i = i + 1;
    }

    # Output chain
    var output = chain_base("output", CHAIN_FILTER, HOOK_OUTPUT, 0, nsf_outbound_policy(nsf));

    if (nsf_allow_established(nsf) == 1) {
        chain_add_rule(output, allow_established());
    }
    if (nsf_allow_loopback(nsf) == 1) {
        var r = rule_new(verdict_accept());
        rule_add_match(r, match_oif("lo"));
        rule_set_comment(r, _nsf_loopback_out_comment(agent_name));
        chain_add_rule(output, r);
    }
    if (nsf_allow_dns(nsf) == 1) {
        var r = rule_new(verdict_accept());
        rule_add_match(r, match_protocol(PROTO_UDP));
        rule_add_match(r, match_dport(53));
        rule_set_comment(r, _nsf_dns_comment(agent_name));
        chain_add_rule(output, r);
    }

    var out_specs = nsf_outbound(nsf);
    var olen = vec_len(out_specs);
    var hosts = nsf_outbound_hosts(nsf);
    var hlen = vec_len(hosts);
    i = 0;
    while (i < olen) {
        var ps = vec_get(out_specs, i);
        if (hlen > 0) {
            # One rule per (port, host) pair
            var j = 0;
            while (j < hlen) {
                var host = vec_get(hosts, j);
                var r = rule_new(verdict_accept());
                rule_add_match(r, match_protocol(ps_protocol(ps)));
                rule_add_match(r, match_dport(ps_port(ps)));
                rule_add_match(r, match_dest_addr(host));
                rule_set_comment(r, _nsf_outbound_host_comment(agent_name, ps_protocol(ps), ps_port(ps), host));
                chain_add_rule(output, r);
                j = j + 1;
            }
        } else {
            var r = rule_new(verdict_accept());
            rule_add_match(r, match_protocol(ps_protocol(ps)));
            rule_add_match(r, match_dport(ps_port(ps)));
            rule_set_comment(r, _nsf_port_comment(agent_name, "outbound", ps_protocol(ps), ps_port(ps)));
            chain_add_rule(output, r);
        }
        i = i + 1;
    }

    table_add_chain(t, input);
    table_add_chain(t, output);
    firewall_add_table(fw, t);
    return fw;
}

# --- apply.cyr ---

# nein apply module — execute nftables rules via the nft command
#
# Uses fork+pipe+execve to spawn `nft -f -` with the ruleset piped on stdin.
# Synchronous — subprocess I/O is short-lived and doesn't need async.
# stderr is captured via a second pipe for error reporting.

# ================================================================
# nft binary path — pinned, configurable, no PATH consultation
# ================================================================
#
# v1.4.0 hardening (threat-model T-3): the nft subprocess is always
# launched via an *absolute* path. No PATH lookup. The default is
# /usr/sbin/nft; callers running on systems with nft elsewhere
# (Alpine, Void, embedded distros) override via `nein_set_nft_path`.
#
# Pre-v1.4.0 behavior tried /usr/sbin/nft → /sbin/nft → /usr/bin/nft
# in order, which was a soft form of PATH consultation (an attacker
# who controlled /usr/sbin/ could plant a malicious binary before the
# real one). v1.4.0 forces a single explicit path so the operator
# either trusts /usr/sbin/nft exactly, or sets the path explicitly.

# Stored as a global-data cstring slot. alloc_init() sets the default;
# callers can override at runtime via nein_set_nft_path.
var _nein_nft_path = "/usr/sbin/nft";

fn nein_nft_path(): cstring { return _nein_nft_path; }

# Override the absolute path to nft. Must start with '/'. Returns
# Ok(0) on accept, Err(ERR_INVALID_RULE) on reject.
fn nein_set_nft_path(path: cstring): i64 {
    if (path == 0) { return nein_err(ERR_INVALID_RULE); }
    if (load8(path) != 47) { return nein_err(ERR_INVALID_RULE); }   # '/'
    if (strlen(path) > 256) { return nein_err(ERR_INVALID_RULE); }
    _nein_nft_path = path;
    return nein_ok();
}

# ================================================================
# Low-level: spawn nft with stdin from buffer, capture stderr
# Returns Ok(0) on exit 0, Err(ERR_NFT_FAILED) on non-zero or failure.
# ================================================================

fn _run_nft_stdin(input_buf, input_len) {
    var pipe_in[16];
    var pipe_err[16];

    var sk_span_name = "nein.apply.run_nft_stdin";
    sakshi_span_enter(sk_span_name, strlen(sk_span_name));

    if (sys_pipe(&pipe_in) < 0) {
        var sk_pipe_err = "nein.apply: sys_pipe(stdin) failed";
        sakshi_error(sk_pipe_err, strlen(sk_pipe_err));
        sakshi_span_exit();
        return nein_err(ERR_NFT_FAILED);
    }
    if (sys_pipe(&pipe_err) < 0) {
        sys_close(load32(&pipe_in));
        sys_close(load32(&pipe_in + 4));
        var sk_pipe_err2 = "nein.apply: sys_pipe(stderr) failed";
        sakshi_error(sk_pipe_err2, strlen(sk_pipe_err2));
        sakshi_span_exit();
        return nein_err(ERR_NFT_FAILED);
    }

    var in_rfd = load32(&pipe_in);
    var in_wfd = load32(&pipe_in + 4);
    var err_rfd = load32(&pipe_err);
    var err_wfd = load32(&pipe_err + 4);

    var pid = sys_fork();
    if (pid < 0) {
        sys_close(in_rfd); sys_close(in_wfd);
        sys_close(err_rfd); sys_close(err_wfd);
        var sk_fork_err = "nein.apply: sys_fork failed";
        sakshi_error(sk_fork_err, strlen(sk_fork_err));
        sakshi_span_exit();
        return nein_err(ERR_NFT_FAILED);
    }

    if (pid == 0) {
        # Child: replace stdin with read end, stderr with err_wfd, exec nft -f -
        sys_dup2(in_rfd, 0);
        sys_dup2(err_wfd, 2);
        sys_close(in_rfd); sys_close(in_wfd);
        sys_close(err_rfd); sys_close(err_wfd);

        # argv: ["nft", "-f", "-", 0]
        var argv = alloc(32);
        store64(argv, "nft");
        store64(argv + 8, "-f");
        store64(argv + 16, "-");
        store64(argv + 24, 0);
        # Single pinned absolute path — no PATH consultation (T-3).
        sys_execve(_nein_nft_path, argv, 0);
        sys_exit(127);
    }

    # Parent: close unused ends
    sys_close(in_rfd);
    sys_close(err_wfd);

    # Write ruleset to nft's stdin
    var written = 0;
    while (written < input_len) {
        var n = sys_write(in_wfd, input_buf + written, input_len - written);
        if (n <= 0) { break; }
        written = written + n;
    }
    sys_close(in_wfd);

    # Drain stderr (ignored unless we need it for diagnostics)
    var errbuf[4096];
    while (sys_read(err_rfd, &errbuf, 4096) > 0) { }
    sys_close(err_rfd);

    # Wait for child
    var status = 0;
    sys_waitpid(pid, &status, 0);

    if (WIFEXITED(status) == 1) {
        if (WEXITSTATUS(status) == 127) {
            var sk_perm = "nein.apply: nft exit=127 (no executable found)";
            sakshi_error(sk_perm, strlen(sk_perm));
            sakshi_span_exit();
            return nein_err(NEIN_ERR_PERMISSION_DENIED);
        }
        if (WEXITSTATUS(status) != 0) {
            var sk_nft = "nein.apply: nft exit nonzero";
            sakshi_warn(sk_nft, strlen(sk_nft));
            sakshi_span_exit();
            return nein_err(ERR_NFT_FAILED);
        }
        var sk_ok = "nein.apply: nft exit=0";
        sakshi_info(sk_ok, strlen(sk_ok));
        sakshi_span_exit();
        return nein_ok();
    }
    var sk_unk = "nein.apply: nft did not exit cleanly";
    sakshi_error(sk_unk, strlen(sk_unk));
    sakshi_span_exit();
    return nein_err(ERR_NFT_FAILED);
}

# ================================================================
# Low-level: spawn nft with args, capture stdout into a Str
# Returns Ok(stdout_str) on success, Err on failure.
# ================================================================

fn _run_nft_capture(argv, nft_path) {
    var sk_span_name = "nein.apply.run_nft_capture";
    sakshi_span_enter(sk_span_name, strlen(sk_span_name));

    var pipe_out[16];
    if (sys_pipe(&pipe_out) < 0) {
        var sk_pe = "nein.apply: sys_pipe(capture) failed";
        sakshi_error(sk_pe, strlen(sk_pe));
        sakshi_span_exit();
        return nein_err(ERR_NFT_FAILED);
    }

    var out_rfd = load32(&pipe_out);
    var out_wfd = load32(&pipe_out + 4);

    var pid = sys_fork();
    if (pid < 0) {
        sys_close(out_rfd); sys_close(out_wfd);
        var sk_fe = "nein.apply: sys_fork(capture) failed";
        sakshi_error(sk_fe, strlen(sk_fe));
        sakshi_span_exit();
        return nein_err(ERR_NFT_FAILED);
    }

    if (pid == 0) {
        sys_dup2(out_wfd, 1);
        sys_close(out_rfd); sys_close(out_wfd);
        # Single pinned absolute path — no PATH consultation (T-3).
        sys_execve(_nein_nft_path, argv, 0);
        sys_exit(127);
    }

    sys_close(out_wfd);

    # Accumulate stdout into a str_builder
    var sb = str_builder_new();
    var buf[4096];
    var n = sys_read(out_rfd, &buf, 4096);
    while (n > 0) {
        # str_builder_add takes a Str; we have raw bytes. Use byte-at-a-time.
        var i = 0;
        while (i < n) {
            str_builder_add_byte(sb, load8(&buf + i));
            i = i + 1;
        }
        n = sys_read(out_rfd, &buf, 4096);
    }
    sys_close(out_rfd);

    var status = 0;
    sys_waitpid(pid, &status, 0);

    if (WIFEXITED(status) == 1) {
        if (WEXITSTATUS(status) == 127) {
            var sk_p = "nein.apply: nft capture exit=127";
            sakshi_error(sk_p, strlen(sk_p));
            sakshi_span_exit();
            return nein_err(NEIN_ERR_PERMISSION_DENIED);
        }
        if (WEXITSTATUS(status) != 0) {
            var sk_n = "nein.apply: nft capture exit nonzero";
            sakshi_warn(sk_n, strlen(sk_n));
            sakshi_span_exit();
            return nein_err(ERR_NFT_FAILED);
        }
        var sk_o = "nein.apply: nft capture exit=0";
        sakshi_info(sk_o, strlen(sk_o));
        sakshi_span_exit();
        return Ok(str_builder_build(sb));
    }
    var sk_u = "nein.apply: nft capture did not exit cleanly";
    sakshi_error(sk_u, strlen(sk_u));
    sakshi_span_exit();
    return nein_err(ERR_NFT_FAILED);
}

# ================================================================
# Build a small nft command string + deliver it over stdin
# ================================================================

fn _nft_cmd(cmd_cstr) {
    return _run_nft_stdin(cmd_cstr, strlen(cmd_cstr));
}

# ================================================================
# Public: batch operations
# ================================================================

# Apply a ruleset (Str or cstr). For Str, caller should use apply_ruleset_str.
fn apply_ruleset_cstr(ruleset_cstr: cstring): i64 {
    return _run_nft_stdin(ruleset_cstr, strlen(ruleset_cstr));
}

fn apply_ruleset_str(ruleset_str: Str): i64 {
    return _run_nft_stdin(str_data(ruleset_str), str_len(ruleset_str));
}

fn apply_firewall(fw: i64): i64 {
    var vr = firewall_validate(fw);
    if (is_err_result(vr) == 1) { return vr; }
    var ruleset = firewall_render(fw);
    return apply_ruleset_str(ruleset);
}

fn flush_ruleset(): i64 {
    return _nft_cmd("flush ruleset\n");
}

# ================================================================
# Public: table/chain operations
# ================================================================

fn _build_nft_line(verb, family, table, chain_or_null) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, verb);
    str_builder_add_cstr(sb, " ");
    str_builder_add_cstr(sb, family);
    str_builder_add_cstr(sb, " ");
    str_builder_add_cstr(sb, table);
    if (chain_or_null != 0) {
        str_builder_add_cstr(sb, " ");
        str_builder_add_cstr(sb, chain_or_null);
    }
    str_builder_add_cstr(sb, "\n");
    var s = str_builder_build(sb);
    var out = alloc(str_len(s) + 1);
    memcpy(out, str_data(s), str_len(s));
    store8(out + str_len(s), 0);
    return out;
}

fn flush_table(family: cstring, table: cstring): i64 {
    var vr = validate_family(family);
    if (is_err_result(vr) == 1) { return vr; }
    vr = validate_identifier(table);
    if (is_err_result(vr) == 1) { return vr; }
    return _nft_cmd(_build_nft_line("flush table", family, table, 0));
}

fn delete_table(family: cstring, table: cstring): i64 {
    var vr = validate_family(family);
    if (is_err_result(vr) == 1) { return vr; }
    vr = validate_identifier(table);
    if (is_err_result(vr) == 1) { return vr; }
    return _nft_cmd(_build_nft_line("delete table", family, table, 0));
}

fn flush_chain(family: cstring, table: cstring, chain: cstring): i64 {
    var vr = validate_family(family);
    if (is_err_result(vr) == 1) { return vr; }
    vr = validate_identifier(table);
    if (is_err_result(vr) == 1) { return vr; }
    vr = validate_identifier(chain);
    if (is_err_result(vr) == 1) { return vr; }
    return _nft_cmd(_build_nft_line("flush chain", family, table, chain));
}

fn delete_chain(family: cstring, table: cstring, chain: cstring): i64 {
    var vr = validate_family(family);
    if (is_err_result(vr) == 1) { return vr; }
    vr = validate_identifier(table);
    if (is_err_result(vr) == 1) { return vr; }
    vr = validate_identifier(chain);
    if (is_err_result(vr) == 1) { return vr; }
    return _nft_cmd(_build_nft_line("delete chain", family, table, chain));
}

# ================================================================
# Public: incremental rule operations
# ================================================================

# Helper: build "add rule FAM TAB CHN RULE\n" variants
fn _build_rule_line(verb_prefix, family, table, chain, rule, suffix_prefix, suffix_val) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, verb_prefix);
    str_builder_add_cstr(sb, " ");
    str_builder_add_cstr(sb, family);
    str_builder_add_cstr(sb, " ");
    str_builder_add_cstr(sb, table);
    str_builder_add_cstr(sb, " ");
    str_builder_add_cstr(sb, chain);
    if (suffix_prefix != 0) {
        str_builder_add_cstr(sb, " ");
        str_builder_add_cstr(sb, suffix_prefix);
        str_builder_add_cstr(sb, " ");
        str_builder_add_int(sb, suffix_val);
    }
    str_builder_add_cstr(sb, " ");
    str_builder_add_cstr(sb, rule);
    str_builder_add_cstr(sb, "\n");
    var s = str_builder_build(sb);
    var out = alloc(str_len(s) + 1);
    memcpy(out, str_data(s), str_len(s));
    store8(out + str_len(s), 0);
    return out;
}

fn _validate_rule_args(family, table, chain, rule) {
    var vr = validate_family(family);
    if (is_err_result(vr) == 1) { return vr; }
    vr = validate_identifier(table);
    if (is_err_result(vr) == 1) { return vr; }
    vr = validate_identifier(chain);
    if (is_err_result(vr) == 1) { return vr; }
    vr = validate_nft_element(rule);
    if (is_err_result(vr) == 1) { return vr; }
    return nein_ok();
}

# add rule FAM TAB CHN RULE
fn add_rule_live(family: cstring, table: cstring, chain: cstring, rule: cstring): i64 {
    var vr = _validate_rule_args(family, table, chain, rule);
    if (is_err_result(vr) == 1) { return vr; }
    return _nft_cmd(_build_rule_line("add rule", family, table, chain, rule, 0, 0));
}

# insert rule FAM TAB CHN RULE (prepends)
fn insert_rule_live(family: cstring, table: cstring, chain: cstring, rule: cstring): i64 {
    var vr = _validate_rule_args(family, table, chain, rule);
    if (is_err_result(vr) == 1) { return vr; }
    return _nft_cmd(_build_rule_line("insert rule", family, table, chain, rule, 0, 0));
}

# add rule FAM TAB CHN position POS RULE
fn add_rule_after_live(family: cstring, table: cstring, chain: cstring, position_handle: i64, rule: cstring): i64 {
    var vr = _validate_rule_args(family, table, chain, rule);
    if (is_err_result(vr) == 1) { return vr; }
    return _nft_cmd(_build_rule_line("add rule", family, table, chain, rule, "position", position_handle));
}

# replace rule FAM TAB CHN handle H RULE
fn replace_rule_live(family: cstring, table: cstring, chain: cstring, handle: i64, new_rule: cstring): i64 {
    var vr = _validate_rule_args(family, table, chain, new_rule);
    if (is_err_result(vr) == 1) { return vr; }
    return _nft_cmd(_build_rule_line("replace rule", family, table, chain, new_rule, "handle", handle));
}

# delete rule FAM TAB CHN handle H
fn delete_rule_live(family: cstring, table: cstring, chain: cstring, handle: i64): i64 {
    var vr = validate_family(family);
    if (is_err_result(vr) == 1) { return vr; }
    vr = validate_identifier(table);
    if (is_err_result(vr) == 1) { return vr; }
    vr = validate_identifier(chain);
    if (is_err_result(vr) == 1) { return vr; }

    var sb = str_builder_new();
    str_builder_add_cstr(sb, "delete rule ");
    str_builder_add_cstr(sb, family);
    str_builder_add_cstr(sb, " ");
    str_builder_add_cstr(sb, table);
    str_builder_add_cstr(sb, " ");
    str_builder_add_cstr(sb, chain);
    str_builder_add_cstr(sb, " handle ");
    str_builder_add_int(sb, handle);
    str_builder_add_cstr(sb, "\n");
    var s = str_builder_build(sb);
    var cstr = alloc(str_len(s) + 1);
    memcpy(cstr, str_data(s), str_len(s));
    store8(cstr + str_len(s), 0);
    return _nft_cmd(cstr);
}

# ================================================================
# Public: list / inspect
# ================================================================

fn list_ruleset(): i64 {
    var argv = alloc(32);
    store64(argv, "nft");
    store64(argv + 8, "list");
    store64(argv + 16, "ruleset");
    store64(argv + 24, 0);
    return _run_nft_capture(argv, 0);
}

fn list_ruleset_with_handles(): i64 {
    var argv = alloc(40);
    store64(argv, "nft");
    store64(argv + 8, "-a");
    store64(argv + 16, "list");
    store64(argv + 24, "ruleset");
    store64(argv + 32, 0);
    return _run_nft_capture(argv, 0);
}

# --- inspect.cyr ---

# nein inspect module — query current firewall state
#
# Wraps apply::list_ruleset and parses the output into a FirewallStatus.

# ================================================================
# FirewallStatus — { table_names(vec of cstr), total_rules, raw_ruleset(Str) }
# Layout: [tables:8][total_rules:8][raw:8] = 24 bytes
# ================================================================

fn firewall_status_new(tables: i64, total_rules: i64, raw: Str): i64 {
    var s = alloc(24);
    store64(s, tables);
    store64(s + 8, total_rules);
    store64(s + 16, raw);
    return s;
}

fn status_tables(s: i64): i64 { return load64(s); }
fn status_total_rules(s: i64): i64 { return load64(s + 8); }
fn status_raw_ruleset(s: i64): i64 { return load64(s + 16); }

# ================================================================
# Parse a raw ruleset into tables + rule count
# ================================================================

# Check if a cstr starts with a prefix
fn _cstr_starts_with(s: cstring, prefix: cstring): i64 {
    var plen = strlen(prefix);
    if (strlen(s) < plen) { return 0; }
    var i = 0;
    while (i < plen) {
        if (load8(s + i) != load8(prefix + i)) { return 0; }
        i = i + 1;
    }
    return 1;
}

# Trim leading/trailing whitespace; returns a fresh cstr
fn _trim_line(s: i64, len: i64): cstring {
    var start = 0;
    while (start < len) {
        var c = load8(s + start);
        if (c != 32 && c != 9) { break; }   # not space, not tab
        start = start + 1;
    }
    var end = len;
    while (end > start) {
        var c = load8(s + end - 1);
        if (c != 32 && c != 9 && c != 13) { break; }
        end = end - 1;
    }
    var out_len = end - start;
    var out = alloc(out_len + 1);
    memcpy(out, s + start, out_len);
    store8(out + out_len, 0);
    return out;
}

# Strip trailing " {" if present
fn _strip_open_brace(s: cstring): cstring {
    var len = strlen(s);
    if (len >= 2) {
        if (load8(s + len - 1) == 123) {   # '{'
            if (load8(s + len - 2) == 32) {   # ' '
                var out = alloc(len - 1);
                memcpy(out, s, len - 2);
                store8(out + len - 2, 0);
                return out;
            }
        }
    }
    return s;
}

# Block-nesting context — only lines inside a `chain` block count as
# rules. v1.4.0 hardening: previously every non-table/non-chain/non-type
# line was counted as a rule, which mis-counted contents of `set`,
# `map`, `flowtable`, `ct timeout` blocks (e.g. `flags interval;`,
# `elements = { … };`) as rules. The block-stack tracker keeps a
# string for the innermost open block kind: "chain", "set", "map",
# "flowtable", "ct_timeout", or 0 (top-level / table).
#
# A line counts as a rule iff:
#   - block_kind == "chain"
#   - the line is not a `chain` opener, `type ` header, `policy `
#     declaration, `}` close, comment (#), or blank
enum BlockKind {
    BLOCK_NONE = 0;
    BLOCK_TABLE = 1;
    BLOCK_CHAIN = 2;
    BLOCK_SET = 3;
    BLOCK_MAP = 4;
    BLOCK_FLOWTABLE = 5;
    BLOCK_CT_TIMEOUT = 6;
}

# Classify the opening line of a block. Returns BLOCK_NONE if the line
# doesn't open a block.
fn _classify_block_open(trimmed: cstring): i64 {
    if (_cstr_starts_with(trimmed, "table ") == 1) { return BLOCK_TABLE; }
    if (_cstr_starts_with(trimmed, "chain ") == 1) { return BLOCK_CHAIN; }
    if (_cstr_starts_with(trimmed, "set ") == 1) { return BLOCK_SET; }
    if (_cstr_starts_with(trimmed, "map ") == 1) { return BLOCK_MAP; }
    if (_cstr_starts_with(trimmed, "flowtable ") == 1) { return BLOCK_FLOWTABLE; }
    if (_cstr_starts_with(trimmed, "ct timeout ") == 1) { return BLOCK_CT_TIMEOUT; }
    return BLOCK_NONE;
}

# Parse the raw ruleset Str, populating:
#   tables_vec: pushed with each "table FAM NAME" line
#   Returns rule count — counted only inside `chain` blocks; lines
#   inside set/map/flowtable/ct_timeout bodies are NOT rules.
#
# Block-stack depth is bounded by nesting in real nft output
# (table → chain/set/map → optional inner). 16 slots is comfortable —
# and `var buf[N]` is N BYTES, so 16 i64 slots need 128 bytes.
fn _parse_ruleset(raw_str: Str, tables_vec: i64): i64 {
    var data = str_data(raw_str);
    var len = str_len(raw_str);
    var rule_count = 0;
    var line_start = 0;
    var i = 0;

    var block_stack[128];
    var bs_depth = 0;
    store64(&block_stack, BLOCK_NONE);

    while (i <= len) {
        var at_end = 0;
        if (i == len) { at_end = 1; }
        var c = 0;
        if (at_end == 0) { c = load8(data + i); }
        if (at_end == 1 || c == 10) {   # LF
            var line_len = i - line_start;
            if (line_len > 0 || at_end == 0) {
                var trimmed = _trim_line(data + line_start, line_len);
                var tlen = strlen(trimmed);
                if (tlen > 0) {
                    var current_block = load64(&block_stack + bs_depth * 8);

                    if (_cstr_starts_with(trimmed, "table ") == 1) {
                        vec_push(tables_vec, _strip_open_brace(trimmed));
                        if (bs_depth < 15) {
                            bs_depth = bs_depth + 1;
                            store64(&block_stack + bs_depth * 8, BLOCK_TABLE);
                        }
                    } elif (streq(trimmed, "}") == 1) {
                        # Block close. Pop the stack if we have anything.
                        if (bs_depth > 0) { bs_depth = bs_depth - 1; }
                    } elif (_classify_block_open(trimmed) != BLOCK_NONE) {
                        # Open inner block.
                        var kind = _classify_block_open(trimmed);
                        if (bs_depth < 15) {
                            bs_depth = bs_depth + 1;
                            store64(&block_stack + bs_depth * 8, kind);
                        }
                    } elif (current_block == BLOCK_CHAIN) {
                        # Inside a chain: count only real rule lines.
                        # Skip the `type … hook … priority …; policy …;` header
                        # and any `# handle N` annotations.
                        if (_cstr_starts_with(trimmed, "type ") == 1) {
                            # not a rule
                        } elif (_cstr_starts_with(trimmed, "policy ") == 1) {
                            # not a rule
                        } elif (load8(trimmed) == 35) {   # '#'
                            # comment / handle annotation
                        } else {
                            rule_count = rule_count + 1;
                        }
                    }
                    # Otherwise: inside set/map/flowtable/ct_timeout/table —
                    # nothing to count.
                }
            }
            line_start = i + 1;
        }
        i = i + 1;
    }
    return rule_count;
}

# ================================================================
# Public API
# ================================================================

# status() — query live firewall state.
# Returns Ok(FirewallStatus) or Err on nft failure.
fn status(): i64 {
    var res = list_ruleset();
    if (is_err_result(res) == 1) { return res; }
    var raw = payload(res);

    var tables = vec_new();
    var count = _parse_ruleset(raw, tables);

    return Ok(firewall_status_new(tables, count, raw));
}

# --- diff.cyr ---

# nein diff module — live-rule diff + idempotent apply
#
# Compute the minimal set of nft operations that converge the live
# kernel ruleset onto a target firewall plan. Pairs with sutra's
# idempotent-apply playbook semantics: a sutra run can render its
# firewall, compute the diff against the live state, and apply only
# the deltas — no full re-apply if nothing changed.
#
# v1.5.0 scope:
#   - Rule-level diff: add rules in target but not live; delete rules
#     in live but not target (matched by handle).
#   - Table-level / chain-level create/delete are NOT computed —
#     tables and chains are assumed to exist with the right shapes.
#     A future revision can extend.
#
# Matching strategy: rule bodies are compared as byte-equal cstrings.
# Target rules go through `rule_render` (Str → cstring). Live rules
# come from the inspect parser with their `# handle N` suffix stripped.
# Exact match means "same rule"; any drift in whitespace or operand
# ordering produces a delete+add pair, which is conservative but
# always correct (nft accepts duplicate adds and rejects invalid
# deletes, both of which are surfaced as ERR_NFT_FAILED).

# ================================================================
# LiveRule struct — { family, table, chain, body, handle }
# Layout: [family:8][table:8][chain:8][body:8][handle:8] = 40 bytes
# All four name fields are cstrings; handle is i64.
# ================================================================

fn _live_rule_new(family: cstring, table: cstring, chain: cstring,
body: cstring, handle: i64): i64 {
    var lr = alloc(40);
    store64(lr, family);
    store64(lr + 8, table);
    store64(lr + 16, chain);
    store64(lr + 24, body);
    store64(lr + 32, handle);
    return lr;
}

fn live_rule_family(lr: i64): cstring { return load64(lr); }
fn live_rule_table(lr: i64): cstring { return load64(lr + 8); }
fn live_rule_chain(lr: i64): cstring { return load64(lr + 16); }
fn live_rule_body(lr: i64): cstring { return load64(lr + 24); }
fn live_rule_handle(lr: i64): i64 { return load64(lr + 32); }

# ================================================================
# Live ruleset parser — extracts LiveRule tuples from `nft list ruleset -a`
# ================================================================

# Parse the "FAMILY NAME" suffix of a `table FAMILY NAME { # handle N`
# header. Sets *family_out and *table_out to fresh cstrings. Returns
# the position past the parsed names (or 0 on parse failure).
fn _parse_table_header(line: cstring): i64 {
    # Skip "table "
    var p = line + 6;
    var family_start = p;
    while (load8(p) != 32 && load8(p) != 0) { p = p + 1; }   # ' '
    if (load8(p) == 0) { return 0; }
    var family_len = p - family_start;
    var family = alloc(family_len + 1);
    memcpy(family, family_start, family_len);
    store8(family + family_len, 0);

    p = p + 1;   # skip space
    var name_start = p;
    while (load8(p) != 32 && load8(p) != 123 && load8(p) != 0) { p = p + 1; }
    var name_len = p - name_start;
    var name = alloc(name_len + 1);
    memcpy(name, name_start, name_len);
    store8(name + name_len, 0);

    # Store both in a 16-byte alloc — caller pulls family + name out.
    var out = alloc(16);
    store64(out, family);
    store64(out + 8, name);
    return out;
}

# Parse "chain NAME { # handle N" — extracts the chain name.
fn _parse_chain_header(line: cstring): cstring {
    var p = line + 6;   # skip "chain "
    var start = p;
    while (load8(p) != 32 && load8(p) != 123 && load8(p) != 0) { p = p + 1; }
    var len = p - start;
    var name = alloc(len + 1);
    memcpy(name, start, len);
    store8(name + len, 0);
    return name;
}

# Strip a `# handle N` suffix from a rule line. Returns (body_cstr, handle).
# A 16-byte alloc holds [body:8][handle:8]; handle is 0 if no handle present.
fn _strip_handle_suffix(trimmed: cstring): i64 {
    var len = strlen(trimmed);
    # Search for " # handle " from the end.
    var marker = " # handle ";
    var mlen = strlen(marker);
    if (len < mlen) {
        # No handle — body is the whole line.
        var body0 = alloc(len + 1);
        memcpy(body0, trimmed, len);
        store8(body0 + len, 0);
        var out0 = alloc(16);
        store64(out0, body0);
        store64(out0 + 8, 0);
        return out0;
    }
    # Walk backwards to find the marker
    var i = len - mlen;
    var found = 0 - 1;
    while (i >= 0) {
        var ok = 1;
        var j = 0;
        while (j < mlen) {
            if (load8(trimmed + i + j) != load8(marker + j)) { ok = 0; break; }
            j = j + 1;
        }
        if (ok == 1) { found = i; break; }
        i = i - 1;
    }

    if (found < 0) {
        # No handle marker — body is the whole line.
        var body1 = alloc(len + 1);
        memcpy(body1, trimmed, len);
        store8(body1 + len, 0);
        var out1 = alloc(16);
        store64(out1, body1);
        store64(out1 + 8, 0);
        return out1;
    }

    # Body is [0, found); handle is the integer starting at found+mlen.
    var body = alloc(found + 1);
    memcpy(body, trimmed, found);
    store8(body + found, 0);

    var hp = trimmed + found + mlen;
    var handle = 0;
    while (load8(hp) >= 48 && load8(hp) <= 57) {
        handle = handle * 10 + (load8(hp) - 48);
        hp = hp + 1;
    }

    var out = alloc(16);
    store64(out, body);
    store64(out + 8, handle);
    return out;
}

# Parse the live ruleset into a Vec of LiveRule tuples.
# Uses the same block-nesting tracker as _parse_ruleset (v1.4.0).
fn diff_parse_live(raw_str: Str): i64 {
    var data = str_data(raw_str);
    var len = str_len(raw_str);
    var rules = vec_new();
    var line_start = 0;
    var i = 0;

    var current_family = 0;
    var current_table = 0;
    var current_chain = 0;

    var diff_bstack[128];
    var bs_depth = 0;
    store64(&diff_bstack, BLOCK_NONE);

    while (i <= len) {
        var at_end = 0;
        if (i == len) { at_end = 1; }
        var c = 0;
        if (at_end == 0) { c = load8(data + i); }
        if (at_end == 1 || c == 10) {
            var line_len = i - line_start;
            if (line_len > 0 || at_end == 0) {
                var trimmed = _trim_line(data + line_start, line_len);
                var tlen = strlen(trimmed);
                if (tlen > 0) {
                    var current_block = load64(&diff_bstack + bs_depth * 8);

                    if (_cstr_starts_with(trimmed, "table ") == 1) {
                        var th = _parse_table_header(trimmed);
                        if (th != 0) {
                            current_family = load64(th);
                            current_table = load64(th + 8);
                        }
                        if (bs_depth < 15) {
                            bs_depth = bs_depth + 1;
                            store64(&diff_bstack + bs_depth * 8, BLOCK_TABLE);
                        }
                    } elif (streq(trimmed, "}") == 1) {
                        if (bs_depth > 0) { bs_depth = bs_depth - 1; }
                        if (bs_depth == 0) {
                            current_family = 0;
                            current_table = 0;
                        }
                    } elif (_cstr_starts_with(trimmed, "chain ") == 1) {
                        current_chain = _parse_chain_header(trimmed);
                        if (bs_depth < 15) {
                            bs_depth = bs_depth + 1;
                            store64(&diff_bstack + bs_depth * 8, BLOCK_CHAIN);
                        }
                    } elif (_classify_block_open(trimmed) != BLOCK_NONE) {
                        if (bs_depth < 15) {
                            bs_depth = bs_depth + 1;
                            store64(&diff_bstack + bs_depth * 8,
                            _classify_block_open(trimmed));
                        }
                    } elif (current_block == BLOCK_CHAIN) {
                        if (_cstr_starts_with(trimmed, "type ") == 1) {
                            # not a rule
                        } elif (_cstr_starts_with(trimmed, "policy ") == 1) {
                            # not a rule
                        } elif (load8(trimmed) == 35) {
                            # comment line
                        } else {
                            var bh = _strip_handle_suffix(trimmed);
                            var lr = _live_rule_new(current_family,
                            current_table,
                            current_chain,
                            load64(bh),
                            load64(bh + 8));
                            vec_push(rules, lr);
                        }
                    }
                }
            }
            line_start = i + 1;
        }
        i = i + 1;
    }
    return rules;
}

# ================================================================
# Target rule extraction — walk a Firewall, yield Vec of LiveRule
# tuples (with handle=0 — target rules don't have handles).
# ================================================================

fn _family_to_cstr(fam: i64): cstring {
    if (fam == FAMILY_INET) { return "inet"; }
    if (fam == FAMILY_IP) { return "ip"; }
    if (fam == FAMILY_IP6) { return "ip6"; }
    if (fam == FAMILY_ARP) { return "arp"; }
    if (fam == FAMILY_BRIDGE) { return "bridge"; }
    if (fam == FAMILY_NETDEV) { return "netdev"; }
    return "inet";
}

fn _render_to_cstr(s: Str): cstring {
    var slen = str_len(s);
    var out = alloc(slen + 1);
    memcpy(out, str_data(s), slen);
    store8(out + slen, 0);
    return out;
}

fn diff_target_rules(fw: i64): i64 {
    var rules = vec_new();
    var tables = firewall_tables(fw);
    var tlen = vec_len(tables);
    var ti = 0;
    while (ti < tlen) {
        var t = vec_get(tables, ti);
        var family_cstr = _family_to_cstr(table_family(t));
        var table_name = table_name(t);
        var chains = table_chains(t);
        var clen = vec_len(chains);
        var ci = 0;
        while (ci < clen) {
            var ch = vec_get(chains, ci);
            var chain_name = chain_name(ch);
            var crules = chain_rules(ch);
            var rlen = vec_len(crules);
            var ri = 0;
            while (ri < rlen) {
                var cr = vec_get(crules, ri);
                var rendered = chain_rule_render(cr);
                var body = _render_to_cstr(rendered);
                vec_push(rules, _live_rule_new(family_cstr, table_name,
                chain_name, body, 0));
                ri = ri + 1;
            }
            ci = ci + 1;
        }
        ti = ti + 1;
    }
    return rules;
}

# ================================================================
# Diff computation — emit nft commands to converge live → target.
# Returns Vec<cstring>: each entry is a complete nft command line
# (including trailing newline) suitable for piping into `nft -f -`.
# ================================================================

# Match a target rule against the live ruleset. Returns 1 if any
# live rule has the same (family, table, chain, body); 0 otherwise.
fn _target_in_live(target_rule: i64, live_rules: i64): i64 {
    var fam = live_rule_family(target_rule);
    var tab = live_rule_table(target_rule);
    var chn = live_rule_chain(target_rule);
    var body = live_rule_body(target_rule);
    var n = vec_len(live_rules);
    var i = 0;
    while (i < n) {
        var lr = vec_get(live_rules, i);
        if (streq(live_rule_family(lr), fam) == 1
        && streq(live_rule_table(lr), tab) == 1
        && streq(live_rule_chain(lr), chn) == 1
        && streq(live_rule_body(lr), body) == 1) {
            return 1;
        }
        i = i + 1;
    }
    return 0;
}

# Mirror: is live rule present in target?
fn _live_in_target(live_rule: i64, target_rules: i64): i64 {
    return _target_in_live(live_rule, target_rules);
}

# Build "add rule FAM TAB CHN BODY\n"
fn _emit_add_rule(rule: i64): cstring {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "add rule ");
    str_builder_add_cstr(sb, live_rule_family(rule));
    str_builder_add_cstr(sb, " ");
    str_builder_add_cstr(sb, live_rule_table(rule));
    str_builder_add_cstr(sb, " ");
    str_builder_add_cstr(sb, live_rule_chain(rule));
    str_builder_add_cstr(sb, " ");
    str_builder_add_cstr(sb, live_rule_body(rule));
    str_builder_add_cstr(sb, "\n");
    return _render_to_cstr(str_builder_build(sb));
}

# Build "delete rule FAM TAB CHN handle N\n"
fn _emit_del_rule(rule: i64): cstring {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "delete rule ");
    str_builder_add_cstr(sb, live_rule_family(rule));
    str_builder_add_cstr(sb, " ");
    str_builder_add_cstr(sb, live_rule_table(rule));
    str_builder_add_cstr(sb, " ");
    str_builder_add_cstr(sb, live_rule_chain(rule));
    str_builder_add_cstr(sb, " handle ");
    str_builder_add_int(sb, live_rule_handle(rule));
    str_builder_add_cstr(sb, "\n");
    return _render_to_cstr(str_builder_build(sb));
}

# Compute the diff: returns Vec<cstring> of nft commands.
# Empty vec = already in sync.
fn diff_compute(target_fw: i64, live_raw: Str): i64 {
    var ops = vec_new();
    var target_rules = diff_target_rules(target_fw);
    var live_rules = diff_parse_live(live_raw);

    # Adds: target rules not in live.
    var t = 0;
    var tn = vec_len(target_rules);
    while (t < tn) {
        var tr = vec_get(target_rules, t);
        if (_target_in_live(tr, live_rules) == 0) {
            vec_push(ops, _emit_add_rule(tr));
        }
        t = t + 1;
    }

    # Deletes: live rules not in target.
    var l = 0;
    var ln = vec_len(live_rules);
    while (l < ln) {
        var lr = vec_get(live_rules, l);
        if (_live_in_target(lr, target_rules) == 0) {
            vec_push(ops, _emit_del_rule(lr));
        }
        l = l + 1;
    }

    return ops;
}

# ================================================================
# Apply a diff — concatenate ops into a single `nft -f -` invocation
# so the kernel applies them atomically (transaction semantics).
# ================================================================

fn diff_apply(ops: i64): i64 {
    var n = vec_len(ops);
    if (n == 0) { return nein_ok(); }

    var sb = str_builder_new();
    var i = 0;
    while (i < n) {
        str_builder_add_cstr(sb, vec_get(ops, i));
        i = i + 1;
    }
    var combined = str_builder_build(sb);
    return apply_ruleset_str(combined);
}

# ================================================================
# Convenience: list live + compute diff + apply.
# Returns Vec<cstring> of ops that WERE applied, or Err on failure.
# ================================================================

fn nein_diff(target_fw: i64): i64 {
    var live_res = list_ruleset();
    if (is_err_result(live_res) == 1) { return live_res; }
    var live_raw = payload(live_res);
    var ops = diff_compute(target_fw, live_raw);
    var apply_res = diff_apply(ops);
    if (is_err_result(apply_res) == 1) { return apply_res; }
    return Ok(ops);
}

# --- sign.cyr ---

# nein sign module — Ed25519-signed rulesets (1.6.1)
#
# A stored ruleset carries an Ed25519 signature so a verifier (aegis) can
# detect at-rest tampering before applying it. The signed message is the
# rendered nft body bytes ONLY — render once, sign the bytes, apply the
# same bytes. The header pubkey is a carrier; the trust root is always the
# caller-supplied key.
#
# Envelope (.nftsig), plain UTF-8:
#   nein-sig: v1
#   nein-sig-alg: ed25519
#   nein-sig-keyid: <label>
#   nein-sig-pubkey: <64 hex>
#   nein-sig-digest: <64 hex sha256(body)>   (audit aid — not trusted)
#   nein-sig-sig: <128 hex>
#   -----BEGIN NFT RULESET-----
#   <verbatim firewall_render body>
#   -----END NFT RULESET-----
#
# Crypto comes from sigil (Ed25519 + hex + sha256); apply reuses apply.cyr.
# Key material sizes (sigil): sk = 64 bytes (seed32||pk32), pk = 32, sig = 64.

# ================================================================
# Envelope constants
# ================================================================

fn _sign_begin(): cstring { return "-----BEGIN NFT RULESET-----"; }
fn _sign_end(): cstring { return "-----END NFT RULESET-----"; }

# Build a Str {data, len} record pointing at existing bytes (no copy).
fn _sign_str(data: i64, len: i64): i64 {
    var s = alloc(16);
    store64(s, data);
    store64(s + 8, len);
    return s;
}

# Substring search: index of needle (cstring) in hay[0,hlen), or -1.
fn _sign_find(hay: i64, hlen: i64, needle: cstring): i64 {
    var nlen = strlen(needle);
    if (nlen == 0) { return 0; }
    if (nlen > hlen) { return 0 - 1; }
    var i = 0;
    var last = hlen - nlen;
    while (i <= last) {
        var j = 0;
        var ok = 1;
        while (j < nlen) {
            if (load8(hay + i + j) != load8(needle + j)) { ok = 0; break; }
            j = j + 1;
        }
        if (ok == 1) { return i; }
        i = i + 1;
    }
    return 0 - 1;
}

# ================================================================
# Signing
# ================================================================

# Generate a fresh Ed25519 keypair. sk_out: 64 bytes, pk_out: 32 bytes
# (both caller-allocated). Returns 1 on success, 0 on entropy failure.
fn sign_keygen(sk_out: i64, pk_out: i64): i64 {
    return ed25519_generate_keypair(sk_out, pk_out);
}

# Sign an already-rendered nft body with a 64-byte secret key. `key_id` is
# an optional operator label (validate_identifier charset), or 0 for
# "unnamed". Returns Ok(Str envelope) | Err(NEIN_ERR_SIG_KEY).
fn sign_ruleset_body(body: i64, sk: i64, key_id: cstring): i64 {
    if (sk == 0) { return nein_err(NEIN_ERR_SIG_KEY); }
    var kid = key_id;
    if (kid == 0) { kid = "unnamed"; }
    if (is_err_result(validate_identifier(kid)) == 1) { return nein_err(NEIN_ERR_SIG_KEY); }

    var body_data = str_data(body);
    var body_len = str_len(body);

    var sig = alloc(64);
    ed25519_sign(sk, body_data, body_len, sig);
    var digest = alloc(32);
    sha256(body_data, body_len, digest);

    var sig_hex = hex_encode(sig, 64);        # 128 chars
    var pk_hex = hex_encode(sk + 32, 32);     # pk is the 2nd half of sk
    var digest_hex = hex_encode(digest, 32);  # 64 chars

    var sb = str_builder_new();
    str_builder_add_cstr(sb, "nein-sig: v1\nnein-sig-alg: ed25519\nnein-sig-keyid: ");
    str_builder_add_cstr(sb, kid);
    str_builder_add_cstr(sb, "\nnein-sig-pubkey: ");
    str_builder_add_cstr(sb, pk_hex);
    str_builder_add_cstr(sb, "\nnein-sig-digest: ");
    str_builder_add_cstr(sb, digest_hex);
    str_builder_add_cstr(sb, "\nnein-sig-sig: ");
    str_builder_add_cstr(sb, sig_hex);
    str_builder_add_cstr(sb, "\n");
    str_builder_add_cstr(sb, _sign_begin());
    str_builder_add_cstr(sb, "\n");
    # body verbatim
    str_builder_add_cstr(sb, _sign_body_cstr(body_data, body_len));
    str_builder_add_cstr(sb, "\n");
    str_builder_add_cstr(sb, _sign_end());
    str_builder_add_cstr(sb, "\n");
    return Ok(str_builder_build(sb));
}

# Null-terminate the body bytes so str_builder_add_cstr copies them whole.
fn _sign_body_cstr(data: i64, len: i64): cstring {
    var out = alloc(len + 1);
    memcpy(out, data, len);
    store8(out + len, 0);
    return out;
}

# Validate `fw`, render it, and sign the rendered body. Returns
# Ok(Str envelope) | Err (firewall_validate's Err, or NEIN_ERR_SIG_KEY).
fn sign_ruleset(fw: i64, sk: i64, key_id: cstring): i64 {
    var vr = firewall_validate(fw);
    if (is_err_result(vr) == 1) { return vr; }
    return sign_ruleset_body(firewall_render(fw), sk, key_id);
}

# ================================================================
# Parsing — SignedRuleset record
#   [pubkey_hex:8][sig_hex:8][keyid:8][body_data:8][body_len:8] = 40 bytes
# ================================================================

fn signed_pubkey_hex(sr: i64): cstring { return load64(sr); }
fn signed_sig_hex(sr: i64): cstring { return load64(sr + 8); }
fn signed_keyid(sr: i64): cstring { return load64(sr + 16); }
fn signed_body(sr: i64): i64 { return _sign_str(load64(sr + 24), load64(sr + 32)); }

# Extract a `prefix`-tagged header value (up to end-of-line) from the
# header region hay[0,limit). Returns an alloc'd NUL-terminated cstr, or 0.
fn _sign_header(hay: i64, limit: i64, prefix: cstring): cstring {
    var at = _sign_find(hay, limit, prefix);
    if (at < 0) { return 0; }
    var p = at + strlen(prefix);
    var start = p;
    while (p < limit) {
        if (load8(hay + p) == 10) { break; }   # '\n'
        p = p + 1;
    }
    var vlen = p - start;
    var out = alloc(vlen + 1);
    memcpy(out, hay + start, vlen);
    store8(out + vlen, 0);
    return out;
}

# Parse an envelope into a SignedRuleset record. Structure/charset only —
# does NOT verify the signature. Returns Ok(ptr) | Err.
fn parse_signed_ruleset(signed: i64): i64 {
    var data = str_data(signed);
    var len = str_len(signed);

    # Body region is delimited; headers must come before BEGIN.
    var begin_at = _sign_find(data, len, _sign_begin());
    var end_at = _sign_find(data, len, _sign_end());
    if (begin_at < 0) { return nein_err(NEIN_ERR_SIG_MALFORMED); }
    if (end_at < 0) { return nein_err(NEIN_ERR_SIG_MALFORMED); }
    if (end_at <= begin_at) { return nein_err(NEIN_ERR_SIG_MALFORMED); }

    # Version + algorithm gates (headers only searched in [0, begin_at)).
    var ver = _sign_header(data, begin_at, "nein-sig: ");
    if (ver == 0) { return nein_err(NEIN_ERR_SIG_MALFORMED); }
    if (streq(ver, "v1") == 0) { return nein_err(NEIN_ERR_SIG_VERSION); }
    var alg = _sign_header(data, begin_at, "nein-sig-alg: ");
    if (alg == 0) { return nein_err(NEIN_ERR_SIG_MALFORMED); }
    if (streq(alg, "ed25519") == 0) { return nein_err(NEIN_ERR_SIG_UNSUPPORTED_ALG); }

    var pubkey_hex = _sign_header(data, begin_at, "nein-sig-pubkey: ");
    var sig_hex = _sign_header(data, begin_at, "nein-sig-sig: ");
    var keyid = _sign_header(data, begin_at, "nein-sig-keyid: ");
    if (pubkey_hex == 0) { return nein_err(NEIN_ERR_SIG_MALFORMED); }
    if (sig_hex == 0) { return nein_err(NEIN_ERR_SIG_MALFORMED); }
    if (keyid == 0) { keyid = "unnamed"; }
    # Hex length + charset gates.
    if (strlen(pubkey_hex) != 64) { return nein_err(NEIN_ERR_SIG_MALFORMED); }
    if (strlen(sig_hex) != 128) { return nein_err(NEIN_ERR_SIG_MALFORMED); }
    if (hex_is_valid(pubkey_hex, 64) == 0) { return nein_err(NEIN_ERR_SIG_MALFORMED); }
    if (hex_is_valid(sig_hex, 128) == 0) { return nein_err(NEIN_ERR_SIG_MALFORMED); }

    # Body = bytes between BEGIN's trailing '\n' and the '\n' before END.
    var body_start = begin_at + strlen(_sign_begin());
    if (load8(data + body_start) == 10) { body_start = body_start + 1; }
    var body_stop = end_at;
    if (body_stop > body_start) {
        if (load8(data + body_stop - 1) == 10) { body_stop = body_stop - 1; }
    }
    var body_len = body_stop - body_start;
    if (body_len < 0) { body_len = 0; }

    var sr = alloc(40);
    store64(sr, pubkey_hex);
    store64(sr + 8, sig_hex);
    store64(sr + 16, keyid);
    store64(sr + 24, data + body_start);
    store64(sr + 32, body_len);
    return Ok(sr);
}

# ================================================================
# Verify
# ================================================================

# Internal: verify a parsed record against 32 trusted pubkey bytes.
fn _sign_verify_parsed(sr: i64, pubkey: i64): i64 {
    # Header pubkey must byte-match the caller-supplied trusted key.
    var hdr_pk = alloc(32);
    if (hex_decode_into(signed_pubkey_hex(sr), 64, hdr_pk) == 0) {
        return nein_err(NEIN_ERR_SIG_MALFORMED);
    }
    if (memeq(hdr_pk, pubkey, 32) == 0) { return nein_err(NEIN_ERR_SIG_KEY_MISMATCH); }

    var sig = alloc(64);
    if (hex_decode_into(signed_sig_hex(sr), 128, sig) == 0) {
        return nein_err(NEIN_ERR_SIG_MALFORMED);
    }
    var body = signed_body(sr);
    if (ed25519_verify(pubkey, str_data(body), str_len(body), sig) == 1) {
        return nein_ok();
    }
    return nein_err(NEIN_ERR_BAD_SIGNATURE);
}

# Verify a signed envelope against a trusted 32-byte pubkey.
# Ok(0) iff it parses AND header pubkey == supplied AND the signature
# verifies over the body. Fail-closed.
fn verify_ruleset(signed: i64, pubkey: i64): i64 {
    var pr = parse_signed_ruleset(signed);
    if (is_err_result(pr) == 1) { return pr; }
    return _sign_verify_parsed(payload(pr), pubkey);
}

# Verify against a 64-char hex pubkey instead of raw bytes.
fn verify_ruleset_hex(signed: i64, pubkey_hex: cstring): i64 {
    if (strlen(pubkey_hex) != 64) { return nein_err(NEIN_ERR_SIG_MALFORMED); }
    if (hex_is_valid(pubkey_hex, 64) == 0) { return nein_err(NEIN_ERR_SIG_MALFORMED); }
    var pk = alloc(32);
    hex_decode_into(pubkey_hex, 64, pk);
    return verify_ruleset(signed, pk);
}

# ================================================================
# Verified apply — fail-closed: verify, and ONLY then apply the body.
# apply.cyr never learns about signatures; it applies raw bytes.
# ================================================================

fn apply_signed_ruleset(signed: i64, pubkey: i64): i64 {
    var pr = parse_signed_ruleset(signed);
    if (is_err_result(pr) == 1) { return pr; }
    var sr = payload(pr);
    var vr = _sign_verify_parsed(sr, pubkey);
    if (is_err_result(vr) == 1) { return vr; }   # fail-closed: never apply
    return apply_ruleset_str(signed_body(sr));
}

fn apply_signed_ruleset_hex(signed: i64, pubkey_hex: cstring): i64 {
    if (strlen(pubkey_hex) != 64) { return nein_err(NEIN_ERR_SIG_MALFORMED); }
    if (hex_is_valid(pubkey_hex, 64) == 0) { return nein_err(NEIN_ERR_SIG_MALFORMED); }
    var pk = alloc(32);
    hex_decode_into(pubkey_hex, 64, pk);
    return apply_signed_ruleset(signed, pk);
}

# --- mcp.cyr ---

# nein mcp module — MCP tool descriptors + handlers over bote's core
#
# Exposes nein's firewall operations as Model Context Protocol tools so
# an agent host can drive nein through bote's Dispatcher / ToolRegistry.
# nein owns no transport — the consuming binary builds the dispatcher and
# a transport (stdio/http/...), then calls `nein_tools_register(d)` to
# mount these tools. Handlers follow bote's 2.0 ABI: fn(args, claims) ->
# result_cstr, where `args` is the raw JSON `arguments` object (cstr) and
# the return is a `{"content":[...],"isError":bool}` envelope cstr.
#
# Tools (merged agent-ergonomic + diff surface):
#   nein_status   {}                                  -> table/rule summary
#   nein_allow    {protocol,port,source?,table?,chain?} -> add accept rule (live)
#   nein_deny     {protocol,port,source?,table?,chain?} -> add drop rule (live)
#   nein_validate {protocol,port,source?,table?,chain?} -> ok / error (no apply)
#   nein_list     {table?,chain?}                      -> live rules (filtered)
#   nein_diff     {rules:[{protocol,port,verdict}]}    -> nft ops vs live (preview)
#
# Depends on the vendored bote-core bundle (src/vendor/bote-core.cyr): the
# dispatcher/registry/schema/jsonx surface + _json_emit_escaped. Backing
# nein ops come from the modules included ahead of this one (inspect.cyr,
# apply.cyr, validate.cyr, diff.cyr, rule.cyr, ...).

# ================================================================
# Result envelope — mirrors bote's fs_tools `_fs_result`. bote-core
# omits content.cyr, so the MCP text-content envelope is hand-built
# (str_builder + _json_emit_escaped for injection-safe escaping).
# ================================================================

fn _mcp_result(msg: cstring, is_err: i64): cstring {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"content\":[{\"type\":\"text\",\"text\":\"");
    _json_emit_escaped(sb, msg);
    str_builder_add_cstr(sb, "\"}],\"isError\":");
    if (is_err == 1) { str_builder_add_cstr(sb, "true}"); }
    else { str_builder_add_cstr(sb, "false}"); }
    return str_data(str_builder_build(sb));
}

fn _mcp_ok(msg: cstring): cstring { return _mcp_result(msg, 0); }
fn _mcp_err(msg: cstring): cstring { return _mcp_result(msg, 1); }

# Public envelope builders — daimon's future firewall tools (1.6.2) reuse
# these so every consumer emits the identical injection-safe MCP envelope
# instead of re-deriving (and re-escaping) it. Same output as _mcp_ok/_err.
fn nein_mcp_ok(msg: cstring): cstring { return _mcp_result(msg, 0); }
fn nein_mcp_err(msg: cstring): cstring { return _mcp_result(msg, 1); }

# ================================================================
# Access-control gate (1.6.1 setup for daimon's 1.6.2 tools).
# The host may register nein's tools WITH a gate fn — fn(name, claims) ->
# 1 permit / 0 deny — via nein_tools_register_gated. Each handler consults
# it first. bote's `claims` is a reserved 0 today (2.x ABI); the gate is
# threaded claims-ready but decides on host policy, not on dereferencing
# claims. With no gate (plain nein_tools_register) behavior is unchanged.
# ================================================================

var _nein_gate = 0;

# Returns 0 if the tool is permitted (no gate, or gate says permit), else
# an "access denied" error envelope the handler returns directly.
fn _nein_gate_check(name: cstring, claims: i64): cstring {
    if (_nein_gate == 0) { return 0; }
    if (fncall2(_nein_gate, name, claims) == 1) { return 0; }
    return _mcp_err("access denied: tool gated by host policy");
}

# ================================================================
# Shared arg validation for the port-rule tools (allow/deny/validate).
# Returns Ok(0) if {protocol,port,source?,table?,chain?} are all valid,
# else Err with a NeinError code — the caller maps it to a message.
# Reads are re-done by each handler; this only validates.
# ================================================================

fn _mcp_valid_proto(proto: cstring): i64 {
    if (proto == 0) { return 0; }
    if (streq(proto, "tcp") == 1) { return 1; }
    if (streq(proto, "udp") == 1) { return 1; }
    return 0;
}

# Validate the shared rule args. Returns 0 if all valid, or a cstr error
# message if not (so handlers can return it directly).
fn _mcp_check_rule_args(args: cstring): cstring {
    var proto = jsonx_get_str(args, "protocol");
    if (proto == 0) { return "missing 'protocol' (tcp or udp)"; }
    if (_mcp_valid_proto(proto) == 0) { return "unsupported protocol (use tcp or udp)"; }

    var port_raw = jsonx_get_raw(args, "port");
    if (port_raw == 0) { return "missing 'port'"; }
    var port = atoi(port_raw);
    if (port < 1) { return "port out of range (1-65535)"; }
    if (port > 65535) { return "port out of range (1-65535)"; }

    var table = jsonx_get_str(args, "table");
    if (table == 0) { table = "filter"; }
    if (is_err_result(validate_identifier(table)) == 1) { return "invalid 'table' name"; }

    var chain = jsonx_get_str(args, "chain");
    if (chain == 0) { chain = "input"; }
    if (is_err_result(validate_identifier(chain)) == 1) { return "invalid 'chain' name"; }

    var src = jsonx_get_str(args, "source");
    if (src != 0) {
        if (is_err_result(validate_addr(src)) == 1) { return "invalid 'source' CIDR/address"; }
    }
    return 0;
}

# Build the nft rule body from validated args + a verdict cstr. Caller
# has already run _mcp_check_rule_args, so components are injection-safe.
fn _mcp_build_rule(args: cstring, verdict: cstring): cstring {
    var sb = str_builder_new();
    var src = jsonx_get_str(args, "source");
    if (src != 0) {
        str_builder_add_cstr(sb, "ip saddr ");
        str_builder_add_cstr(sb, src);
        str_builder_add_cstr(sb, " ");
    }
    str_builder_add_cstr(sb, jsonx_get_str(args, "protocol"));
    str_builder_add_cstr(sb, " dport ");
    str_builder_add_int(sb, atoi(jsonx_get_raw(args, "port")));
    str_builder_add_cstr(sb, " ");
    str_builder_add_cstr(sb, verdict);
    return str_data(str_builder_build(sb));
}

# ================================================================
# Handlers
# ================================================================

# nein_status {} -> live firewall summary (table count + rule count).
fn _nein_status_handler(args: cstring, claims: i64): cstring {
    var g = _nein_gate_check("nein_status", claims);
    if (g != 0) { return g; }
    var res = status();
    if (is_err_result(res) == 1) {
        return _mcp_err("nein_status: nft query failed (needs root + nft installed)");
    }
    var st = payload(res);
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "tables=");
    str_builder_add_int(sb, vec_len(status_tables(st)));
    str_builder_add_cstr(sb, " total_rules=");
    str_builder_add_int(sb, status_total_rules(st));
    return _mcp_ok(str_data(str_builder_build(sb)));
}

# Shared allow/deny body: validate, build rule, apply live, report.
fn _mcp_apply_verdict(args: cstring, verdict: cstring, label: cstring): cstring {
    var bad = _mcp_check_rule_args(args);
    if (bad != 0) { return _mcp_err(bad); }

    var table = jsonx_get_str(args, "table");
    if (table == 0) { table = "filter"; }
    var chain = jsonx_get_str(args, "chain");
    if (chain == 0) { chain = "input"; }

    var rule = _mcp_build_rule(args, verdict);
    var res = add_rule_live("inet", table, chain, rule);
    if (is_err_result(res) == 1) {
        return _mcp_err("apply failed (needs root + nft; verify the table/chain exist)");
    }
    var sb = str_builder_new();
    str_builder_add_cstr(sb, label);
    str_builder_add_cstr(sb, ": inet ");
    str_builder_add_cstr(sb, table);
    str_builder_add_cstr(sb, " ");
    str_builder_add_cstr(sb, chain);
    str_builder_add_cstr(sb, " ");
    str_builder_add_cstr(sb, rule);
    return _mcp_ok(str_data(str_builder_build(sb)));
}

# nein_allow {protocol,port,source?,table?,chain?} -> add accept rule (live).
fn _nein_allow_handler(args: cstring, claims: i64): cstring {
    var g = _nein_gate_check("nein_allow", claims);
    if (g != 0) { return g; }
    return _mcp_apply_verdict(args, "accept", "allowed");
}

# nein_deny {protocol,port,source?,table?,chain?} -> add drop rule (live).
fn _nein_deny_handler(args: cstring, claims: i64): cstring {
    var g = _nein_gate_check("nein_deny", claims);
    if (g != 0) { return g; }
    return _mcp_apply_verdict(args, "drop", "denied");
}

# nein_validate {protocol,port,source?,table?,chain?} -> ok / error (no apply).
fn _nein_validate_handler(args: cstring, claims: i64): cstring {
    var g = _nein_gate_check("nein_validate", claims);
    if (g != 0) { return g; }
    var bad = _mcp_check_rule_args(args);
    if (bad != 0) { return _mcp_err(bad); }
    return _mcp_ok("valid");
}

# nein_list {table?,chain?} -> live rules (optionally filtered), as a JSON
# array in the text content: [{family,table,chain,rule,handle}, ...].
fn _nein_list_handler(args: cstring, claims: i64): cstring {
    var g = _nein_gate_check("nein_list", claims);
    if (g != 0) { return g; }
    var res = list_ruleset_with_handles();
    if (is_err_result(res) == 1) {
        return _mcp_err("nein_list: nft query failed (needs root + nft installed)");
    }
    var rules = diff_parse_live(payload(res));
    var ftable = jsonx_get_str(args, "table");
    var fchain = jsonx_get_str(args, "chain");

    var sb = str_builder_new();
    str_builder_add_cstr(sb, "[");
    var n = vec_len(rules);
    var count = 0;
    var i = 0;
    while (i < n) {
        var lr = vec_get(rules, i);
        var keep = 1;
        if (ftable != 0) {
            if (streq(live_rule_table(lr), ftable) == 0) { keep = 0; }
        }
        if (fchain != 0) {
            if (streq(live_rule_chain(lr), fchain) == 0) { keep = 0; }
        }
        if (keep == 1) {
            if (count > 0) { str_builder_add_cstr(sb, ","); }
            str_builder_add_cstr(sb, "{\"family\":\"");
            _json_emit_escaped(sb, live_rule_family(lr));
            str_builder_add_cstr(sb, "\",\"table\":\"");
            _json_emit_escaped(sb, live_rule_table(lr));
            str_builder_add_cstr(sb, "\",\"chain\":\"");
            _json_emit_escaped(sb, live_rule_chain(lr));
            str_builder_add_cstr(sb, "\",\"rule\":\"");
            _json_emit_escaped(sb, live_rule_body(lr));
            str_builder_add_cstr(sb, "\",\"handle\":");
            str_builder_add_int(sb, live_rule_handle(lr));
            str_builder_add_cstr(sb, "}");
            count = count + 1;
        }
        i = i + 1;
    }
    str_builder_add_cstr(sb, "]");
    return _mcp_ok(str_data(str_builder_build(sb)));
}

# nein_diff {rules:[{protocol,port,verdict?}]} -> nft ops to converge the
# live ruleset onto the given target rules (PREVIEW — does not apply).
# Target is built in table `filter` / chain `input` (family inet). Rules
# without a verdict default to accept. Returns {"ops":[...],"count":N}.
fn _nein_diff_handler(args: cstring, claims: i64): cstring {
    var g = _nein_gate_check("nein_diff", claims);
    if (g != 0) { return g; }
    var arr = jsonx_get_raw(args, "rules");
    if (arr == 0) { return _mcp_err("missing 'rules' array"); }

    var fw = firewall_new();
    var t = table_new("filter", FAMILY_INET);
    var c = chain_base("input", CHAIN_FILTER, HOOK_INPUT, 0, POLICY_DROP);

    var alen = strlen(arr);
    var count = 0;
    var i = 0;
    while (i < alen) {
        if (load8(arr + i) != 123) {   # '{'
            i = i + 1;
        } else {
            # find the matching top-level '}' (brace-depth walk)
            var depth = 1;
            var j = i + 1;
            while (depth > 0) {
                if (j >= alen) { depth = 0; }
                else {
                    var cj = load8(arr + j);
                    if (cj == 123) { depth = depth + 1; }
                    elif (cj == 125) { depth = depth - 1; }
                    j = j + 1;
                }
            }
            # copy element arr[i, j) as a NUL-terminated object cstr
            var elen = j - i;
            var elem = alloc(elen + 1);
            memcpy(elem, arr + i, elen);
            store8(elem + elen, 0);

            var proto = jsonx_get_str(elem, "protocol");
            if (proto == 0) { return _mcp_err("a rule is missing 'protocol'"); }
            if (_mcp_valid_proto(proto) == 0) { return _mcp_err("a rule has an unsupported protocol"); }
            var port_raw = jsonx_get_raw(elem, "port");
            if (port_raw == 0) { return _mcp_err("a rule is missing 'port'"); }
            var port = atoi(port_raw);
            if (port < 1) { return _mcp_err("a rule 'port' is out of range (1-65535)"); }
            if (port > 65535) { return _mcp_err("a rule 'port' is out of range (1-65535)"); }

            var vd = verdict_accept();
            var verdict_s = jsonx_get_str(elem, "verdict");
            if (verdict_s != 0) {
                if (streq(verdict_s, "drop") == 1) { vd = verdict_drop(); }
                elif (streq(verdict_s, "accept") == 0) { return _mcp_err("a rule 'verdict' must be accept or drop"); }
            }
            var proto_id = PROTO_TCP;
            if (streq(proto, "udp") == 1) { proto_id = PROTO_UDP; }

            var rule = rule_new(vd);
            rule_add_match(rule, match_protocol(proto_id));
            rule_add_match(rule, match_dport(port));
            chain_add_rule(c, rule);
            count = count + 1;
            i = j;
        }
    }
    if (count == 0) { return _mcp_err("no rules provided"); }

    table_add_chain(t, c);
    firewall_add_table(fw, t);

    var live = list_ruleset();
    if (is_err_result(live) == 1) {
        return _mcp_err("nein_diff: nft query failed (needs root + nft installed)");
    }
    var ops = diff_compute(fw, payload(live));

    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"ops\":[");
    var n = vec_len(ops);
    var k = 0;
    while (k < n) {
        if (k > 0) { str_builder_add_cstr(sb, ","); }
        str_builder_add_cstr(sb, "\"");
        _json_emit_escaped(sb, vec_get(ops, k));
        str_builder_add_cstr(sb, "\"");
        k = k + 1;
    }
    str_builder_add_cstr(sb, "],\"count\":");
    str_builder_add_int(sb, n);
    str_builder_add_cstr(sb, "}");
    return _mcp_ok(str_data(str_builder_build(sb)));
}

# ================================================================
# Registration — mount nein's tools on an existing bote dispatcher.
# Each descriptor carries bote ToolAnnotations (read-only vs destructive)
# and profile tags (firewall / firewall_admin) so a host can filter and
# gate them by side-effect without any dependency on bote's reserved
# claims. This is what daimon's 1.6.2 firewall tools build on.
# ================================================================

# Profile vecs: read-only tools -> {firewall}; mutating -> {firewall,
# firewall_admin} so a host can expose the admin set only to privileged
# agents (tools/list?profile=...).
fn _nein_pf_ro(): i64 {
    var v = vec_new();
    vec_push(v, "firewall");
    return v;
}

fn _nein_pf_admin(): i64 {
    var v = vec_new();
    vec_push(v, "firewall");
    vec_push(v, "firewall_admin");
    return v;
}

# --- Tool table — single source of truth for the 6 tools ----------------
# Both integration paths (bote-dispatcher registration below, and the
# daimon-friendly dispatch adapter) read from these accessors, so names /
# descriptions / read-only classification never drift between them. A host
# that dispatches by name (daimon's model) uses nein_tool_name/desc/
# read_only/admin to register descriptors and nein_mcp_dispatch to route.

fn nein_tool_count(): i64 { return 6; }

fn nein_tool_name(i: i64): cstring {
    if (i == 0) { return "nein_status"; }
    if (i == 1) { return "nein_allow"; }
    if (i == 2) { return "nein_deny"; }
    if (i == 3) { return "nein_validate"; }
    if (i == 4) { return "nein_list"; }
    if (i == 5) { return "nein_diff"; }
    return "";
}

fn nein_tool_desc(i: i64): cstring {
    if (i == 0) { return "get current nftables firewall status (table count, rule count); args {}"; }
    if (i == 1) { return "add an accept rule to the live firewall; args {protocol, port, source?, table?, chain?}"; }
    if (i == 2) { return "add a drop rule to the live firewall; args {protocol, port, source?, table?, chain?}"; }
    if (i == 3) { return "validate a port-rule request (no apply); args {protocol, port, source?, table?, chain?}"; }
    if (i == 4) { return "list live firewall rules, optionally filtered; args {table?, chain?}"; }
    if (i == 5) { return "preview nft ops to reach target rules (no apply); args {rules:[{protocol,port,verdict}]}"; }
    return "";
}

# 1 = read-only (no side effects); 0 = mutating (live apply). Hosts should
# gate the mutating tools to privileged agents.
fn nein_tool_read_only(i: i64): i64 {
    if (i == 1) { return 0; }   # nein_allow
    if (i == 2) { return 0; }   # nein_deny
    return 1;                    # status / validate / list / diff
}

# 1 = firewall_admin profile (the mutating tools); 0 = firewall only.
fn nein_tool_admin(i: i64): i64 {
    if (nein_tool_read_only(i) == 0) { return 1; }
    return 0;
}

fn _nein_handler(i: i64): i64 {
    if (i == 0) { return &_nein_status_handler; }
    if (i == 1) { return &_nein_allow_handler; }
    if (i == 2) { return &_nein_deny_handler; }
    if (i == 3) { return &_nein_validate_handler; }
    if (i == 4) { return &_nein_list_handler; }
    if (i == 5) { return &_nein_diff_handler; }
    return 0;
}

# --- Path A: bote-dispatcher registration -------------------------------
# For hosts that run a bote Dispatcher. Register descriptor (schema +
# annotations + profiles) and bind the handler, from the tool table.
fn _nein_reg(dispatcher: i64, reg: i64, i: i64): i64 {
    var ann = ann_read_only();
    var pf = _nein_pf_ro();
    if (nein_tool_read_only(i) == 0) {
        ann = ann_destructive();
        pf = _nein_pf_admin();
    }
    var td = tool_def_new(nein_tool_name(i), nein_tool_desc(i), schema_new("object", 0, vec_new()));
    td = tool_def_with_annotations(td, ann);
    td = tool_def_with_profiles(td, pf);
    registry_register(reg, td);
    dispatcher_handle(dispatcher, nein_tool_name(i), _nein_handler(i));
    return 0;
}

fn nein_tools_register(dispatcher: i64): i64 {
    var reg = dispatcher_registry(dispatcher);
    var i = 0;
    while (i < nein_tool_count()) {
        _nein_reg(dispatcher, reg, i);
        i = i + 1;
    }
    return 0;
}

# Like nein_tools_register, but installs a host access-control gate:
# `gate_fp` = fn(tool_name: cstring, claims: i64) -> 1 permit / 0 deny.
# Every handler consults it before acting; a denied call returns an
# "access denied" envelope and never touches the firewall.
fn nein_tools_register_gated(dispatcher: i64, gate_fp: i64): i64 {
    _nein_gate = gate_fp;
    return nein_tools_register(dispatcher);
}

# --- Path B: daimon-friendly dispatch adapter ---------------------------
# For hosts that route MCP calls by name (daimon's mcp_dispatch_builtin
# model) rather than standing up a bote Dispatcher. The host registers
# descriptors from the tool table and forwards every "nein_*" call to
# nein_mcp_dispatch. Install the gate first with nein_mcp_set_gate.

# Install the access-control gate for the dispatch-adapter path (same
# gate the gated register uses, minus the dispatcher).
fn nein_mcp_set_gate(gate_fp: i64): i64 {
    _nein_gate = gate_fp;
    return 0;
}

# Route a tool call by name -> the handler's MCP result envelope cstr, or
# an "unknown tool" error envelope. Handlers consult the installed gate.
fn nein_mcp_dispatch(name: cstring, args: cstring, claims: i64): cstring {
    var i = 0;
    while (i < nein_tool_count()) {
        if (streq(name, nein_tool_name(i)) == 1) {
            return fncall2(_nein_handler(i), args, claims);
        }
        i = i + 1;
    }
    return _mcp_err("unknown nein tool");
}
