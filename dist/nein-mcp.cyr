# ================================================================
# String renderers for enum constants
# ================================================================

fn _proto_str(p) {
    if (p == PROTO_TCP) { return "tcp"; }
    if (p == PROTO_UDP) { return "udp"; }
    if (p == PROTO_ICMP) { return "icmp"; }
    if (p == PROTO_ICMPV6) { return "icmpv6"; }
    return "unknown";
}

fn _rate_unit_str(u) {
    if (u == RATE_SECOND) { return "second"; }
    if (u == RATE_MINUTE) { return "minute"; }
    if (u == RATE_HOUR) { return "hour"; }
    if (u == RATE_DAY) { return "day"; }
    return "second";
}

fn _quota_mode_str(m) {
    if (m == QUOTA_OVER) { return "over"; }
    if (m == QUOTA_UNTIL) { return "until"; }
    return "over";
}

fn _quota_unit_str(u) {
    if (u == QUNIT_BYTES) { return "bytes"; }
    if (u == QUNIT_KBYTES) { return "kbytes"; }
    if (u == QUNIT_MBYTES) { return "mbytes"; }
    if (u == QUNIT_GBYTES) { return "gbytes"; }
    return "bytes";
}

fn _pkt_type_str(p) {
    if (p == PKT_UNICAST) { return "unicast"; }
    if (p == PKT_BROADCAST) { return "broadcast"; }
    if (p == PKT_MULTICAST) { return "multicast"; }
    return "unicast";
}

fn _ipv6_ext_hdr_str(h) {
    if (h == EXT_HOP_BY_HOP) { return "hbh"; }
    if (h == EXT_ROUTING) { return "rt"; }
    if (h == EXT_FRAGMENT) { return "frag"; }
    if (h == EXT_DESTINATION) { return "dst"; }
    if (h == EXT_MOBILITY) { return "mh"; }
    if (h == EXT_AUTH) { return "auth"; }
    return "unknown";
}

fn _cmp_op_str(op) {
    if (op == NFT_CMP_EQ) { return "=="; }
    if (op == NFT_CMP_NE) { return "!="; }
    if (op == NFT_CMP_LT) { return "<"; }
    if (op == NFT_CMP_GT) { return ">"; }
    if (op == NFT_CMP_LE) { return "<="; }
    if (op == NFT_CMP_GE) { return ">="; }
    return "==";
}

fn _reject_reason_str(r) {
    if (r == REJECT_ICMP_HOST_UNREACH) { return "icmp type host-unreachable"; }
    if (r == REJECT_ICMP_PORT_UNREACH) { return "icmp type port-unreachable"; }
    if (r == REJECT_ICMP_NET_UNREACH) { return "icmp type net-unreachable"; }
    if (r == REJECT_ICMP_ADMIN_PROHIB) { return "icmp type admin-prohibited"; }
    if (r == REJECT_ICMPX_ADMIN_PROHIB) { return "icmpx type admin-prohibited"; }
    if (r == REJECT_TCP_RESET) { return "tcp reset"; }
    return "icmp type port-unreachable";
}

fn _log_level_str(l) {
    if (l == NFT_LOG_EMERG) { return "emerg"; }
    if (l == NFT_LOG_ALERT) { return "alert"; }
    if (l == NFT_LOG_CRIT) { return "crit"; }
    if (l == NFT_LOG_ERR) { return "err"; }
    if (l == NFT_LOG_WARN) { return "warn"; }
    if (l == NFT_LOG_NOTICE) { return "notice"; }
    if (l == NFT_LOG_INFO) { return "info"; }
    if (l == NFT_LOG_DEBUG) { return "debug"; }
    return "info";
}

# ================================================================
# Match struct — tagged union: { type, val1, val2, val3 }
# Layout: [type:8][val1:8][val2:8][val3:8] = 32 bytes
#   val1/val2/val3 meaning depends on type (string ptr, int, etc.)
# ================================================================

fn match_new(mtype: i64, v1: i64, v2: i64, v3: i64): i64 {
    var m = alloc(32);
    store64(m, mtype);
    store64(m + 8, v1);
    store64(m + 16, v2);
    store64(m + 24, v3);
    return m;
}

fn match_type(m: i64): i64 { return load64(m); }
fn match_val1(m: i64): i64 { return load64(m + 8); }
fn match_val2(m: i64): i64 { return load64(m + 16); }
fn match_val3(m: i64): i64 { return load64(m + 24); }

