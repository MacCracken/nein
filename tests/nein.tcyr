fn main() {
    alloc_init();

    # error
    test_error();

    # validate
    test_validate_identifier();
    test_validate_addr();
    test_validate_iface();
    test_validate_ct_state();
    test_validate_comment();
    test_validate_log_prefix();
    test_validate_nft_element();
    test_validate_family();
    test_dangerous_chars_all();

    # rule
    test_rule_render_basic();
    test_rule_render_verdicts();
    test_rule_render_matches();
    test_rule_render_log_advanced();
    test_rule_validate();

    # set
    test_set_render();
    test_set_validate();
    test_map_render();
    test_map_validate();

    # chain
    test_chain_render();

    # table
    test_table_render();
    test_table_render_order();
    test_define_validate();
    test_flowtable();
    test_ct_timeout();

    # nat
    test_nat_render();
    test_nat_validate();
    test_nat_dnat_range();

    # firewall
    test_firewall();
    test_firewall_validate();

    # builder
    test_builder();

    return assert_summary();
}

