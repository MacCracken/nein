[package]
name = "nein"
version = "${file:VERSION}"
description = "nein — programmatic nftables firewall"
license = "GPL-3.0-only"
repository = "https://github.com/MacCracken/nein"
language = "cyrius"
cyrius = "6.2.11"

[build]
entry = "src/main.cyr"
output = "build/nein"

# `[lib]` declares the modules `cyrius distlib` concatenates into
# `dist/nein.cyr` — the single-file bundle consumed by stiva / aegis
# / daimon / sutra. Order matches `src/main.cyr`'s include chain:
# error → validate → primitives → aggregator → feature modules →
# integrators. Pattern lifted from agnosys / agnostik 1.2.x.
[lib]
modules = [
    "src/lib/error.cyr",
    "src/lib/validate.cyr",
    "src/lib/rule.cyr",
    "src/lib/set.cyr",
    "src/lib/nat.cyr",
    "src/lib/chain.cyr",
    "src/lib/table.cyr",
    "src/lib/firewall.cyr",
    "src/lib/builder.cyr",
    "src/lib/policy.cyr",
    "src/lib/geoip.cyr",
    "src/lib/mesh.cyr",
    "src/lib/bridge.cyr",
    "src/lib/engine.cyr",
    "src/lib/config.cyr",
    "src/lib/netns.cyr",
    "src/lib/apply.cyr",
    "src/lib/inspect.cyr",
    "src/lib/diff.cyr",
]

[deps]
stdlib = [
    "string",
    "fmt",
    "alloc",
    "vec",
    "str",
    "syscalls",
    "io",
    "args",
    "assert",
    "tagged",
    "hashmap",
    "process",
    "bench",
    "fnptr",
    "callback",
    "freelist",
    "fs",
    "net",
    "regex",
    "chrono",
    "sakshi",
]

[deps.agnosys]
git = "https://github.com/MacCracken/agnosys.git"
path = "../agnosys"
tag = "1.4.3"
modules = ["dist/agnosys-core.cyr"]
