# ================================================================
# Verdict struct — { type, val1, val2, val3, val4 }
# Layout: [type:8][val1:8][val2:8][val3:8][val4:8] = 40 bytes
# ================================================================

fn verdict_new(vtype, v1, v2, v3, v4) {
    var v = alloc(40);
    store64(v, vtype);
    store64(v + 8, v1);
    store64(v + 16, v2);
    store64(v + 24, v3);
    store64(v + 32, v4);
    return v;
}

fn verdict_type(v) { return load64(v); }
fn verdict_val1(v) { return load64(v + 8); }
fn verdict_val2(v) { return load64(v + 16); }
fn verdict_val3(v) { return load64(v + 24); }
fn verdict_val4(v) { return load64(v + 32); }

