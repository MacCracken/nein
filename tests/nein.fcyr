# nein fuzz harness — validate + rule modules
# All functions must handle arbitrary input without crashing.

include "src/lib/error.cyr"
include "src/lib/validate.cyr"
include "src/lib/rule.cyr"
include "src/lib/set.cyr"
include "src/lib/nat.cyr"
include "src/lib/chain.cyr"
include "src/lib/table.cyr"
include "src/lib/firewall.cyr"
include "src/lib/builder.cyr"
include "src/lib/policy.cyr"
include "src/lib/geoip.cyr"
include "src/lib/mesh.cyr"
include "src/lib/bridge.cyr"
include "src/lib/engine.cyr"
include "src/lib/config.cyr"
include "src/lib/netns.cyr"

fn fuzz_validate(data, len) {
    if (len == 0) { return 0; }
    var copy = alloc(len + 1);
    memcpy(copy, data, len);
    store8(copy + len, 0);

    validate_identifier(copy);
    validate_addr(copy);
    validate_iface(copy);
    validate_ct_state(copy);
    validate_comment(copy);
    validate_log_prefix(copy);
    validate_nft_element(copy);
    validate_family(copy);

    # Also fuzz config enum dispatchers — must never crash
    cfg_parse_family(copy);
    cfg_parse_chain_type(copy);
    cfg_parse_hook(copy);
    cfg_parse_policy(copy);
    cfg_parse_protocol(copy);
    cfg_parse_rate_unit(copy);
    cfg_parse_quota_mode(copy);
    cfg_parse_quota_unit(copy);
    cfg_parse_pkt_type(copy);
    cfg_parse_ipv6_ext_hdr(copy);
    cfg_parse_cmp_op(copy);
    cfg_parse_log_level(copy);
    cfg_parse_reject_reason(copy);
    cfg_parse_set_type(copy);
    cfg_parse_set_flag(copy);
    cfg_parse_transport(copy);
    return 0;
}

fn fuzz_nat(data, len) {
    if (len == 0) { return 0; }
    var copy = alloc(len + 1);
    memcpy(copy, data, len);
    store8(copy + len, 0);

    # DNAT with fuzzed address
    var n = nat_dnat(PROTO_TCP, 8080, copy, 80, 0);
    nat_render(n);
    nat_validate(n);

    # SNAT with fuzzed addresses
    n = nat_snat(copy, "1.2.3.4", 0);
    nat_render(n);
    nat_validate(n);

    # Masquerade with fuzzed iface
    n = nat_masquerade("10.0.0.0/8", copy, 0);
    nat_render(n);
    nat_validate(n);

    # Redirect with fuzzed comment
    n = nat_redirect(PROTO_TCP, 80, 8080, copy);
    nat_render(n);
    nat_validate(n);

    return 0;
}

fn fuzz_rule_render(data, len) {
    if (len == 0) { return 0; }
    var copy = alloc(len + 1);
    memcpy(copy, data, len);
    store8(copy + len, 0);

    # Build a rule with fuzzed strings in various positions
    var r = rule_new(verdict_accept());
    rule_add_match(r, match_source_addr(copy));
    rule_add_match(r, match_protocol(PROTO_TCP));
    rule_add_match(r, match_dport(80));
    rule_add_match(r, match_iif(copy));
    rule_set_comment(r, copy);
    rule_render(r);

    # Fuzz with raw match
    r = rule_new(verdict_drop());
    rule_add_match(r, match_raw(copy));
    rule_render(r);

    # Fuzz validate
    rule_validate(r);

    return 0;
}

fn main() {
    alloc_init();

    # Smoke: normal inputs
    fuzz_validate("eth0", 4);
    fuzz_validate("10.0.0.1", 8);
    fuzz_validate("inet", 4);

    # Hostile
    fuzz_validate("evil;drop", 9);
    fuzz_validate("a{b}c|d`e$f", 11);

    # Rule rendering with normal input
    fuzz_rule_render("10.0.0.1", 8);
    fuzz_rule_render("eth0", 4);

    # Rule rendering with hostile input
    fuzz_rule_render("evil;drop{}", 11);

    # NAT fuzz
    fuzz_nat("10.0.0.1", 8);
    fuzz_nat("evil;addr", 9);
    fuzz_nat("2001:db8::1", 11);

    # Boundary: max lengths
    var big[256];
    memset(&big, 97, 255);
    store8(&big + 255, 0);
    fuzz_validate(&big, 255);
    fuzz_rule_render(&big, 255);

    println("fuzz: ok");
    return 0;
}

var r = main();
syscall(60, r);
