# ================================================================
# Error tests
# ================================================================

fn test_error() {
    test_group("error");
    assert(ERR_NFT_FAILED != 0, "ERR_NFT_FAILED nonzero");
    assert(ERR_INVALID_RULE != 0, "ERR_INVALID_RULE nonzero");
    assert(ERR_TABLE_NOT_FOUND != 0, "ERR_TABLE_NOT_FOUND nonzero");
    assert(ERR_CHAIN_NOT_FOUND != 0, "ERR_CHAIN_NOT_FOUND nonzero");
    assert(ERR_PERMISSION_DENIED != 0, "ERR_PERMISSION_DENIED nonzero");
    assert(ERR_PARSE != 0, "ERR_PARSE nonzero");
    assert(ERR_IO != 0, "ERR_IO nonzero");

    assert(ERR_NFT_FAILED != ERR_INVALID_RULE, "nft != invalid");
    assert(ERR_INVALID_RULE != ERR_TABLE_NOT_FOUND, "invalid != table");
    assert(ERR_TABLE_NOT_FOUND != ERR_CHAIN_NOT_FOUND, "table != chain");
    assert(ERR_CHAIN_NOT_FOUND != ERR_PERMISSION_DENIED, "chain != perm");
    assert(ERR_PERMISSION_DENIED != ERR_PARSE, "perm != parse");
    assert(ERR_PARSE != ERR_IO, "parse != io");

    var e = nein_err(ERR_NFT_FAILED);
    assert(is_err_result(e) == 1, "nein_err returns Err");
    assert_eq(err_code(e), ERR_NFT_FAILED, "err_code extracts code");

    var ok = nein_ok();
    assert(is_ok(ok) == 1, "nein_ok returns Ok");
    return 0;
}

# ================================================================
# Validate tests
# ================================================================

fn test_validate_identifier() {
    test_group("validate_identifier");
    assert(is_ok(validate_identifier("filter")) == 1, "filter ok");
    assert(is_ok(validate_identifier("my_table")) == 1, "my_table ok");
    assert(is_ok(validate_identifier("agnos-policy")) == 1, "agnos-policy ok");
    assert(is_ok(validate_identifier("0eth0")) == 1, "numeric start ok");
    assert(is_ok(validate_identifier("123")) == 1, "all numeric ok");
    assert(is_err_result(validate_identifier("")) == 1, "empty rejected");
    assert(is_err_result(validate_identifier("has space")) == 1, "space rejected");
    assert(is_err_result(validate_identifier("evil;drop")) == 1, "semicolon rejected");
    assert(is_err_result(validate_identifier("has{brace")) == 1, "brace rejected");

    var buf64[520];
    memset(&buf64, 97, 64);
    store8(&buf64 + 64, 0);
    assert(is_ok(validate_identifier(&buf64)) == 1, "64 chars ok");
    memset(&buf64, 97, 65);
    store8(&buf64 + 65, 0);
    assert(is_err_result(validate_identifier(&buf64)) == 1, "65 chars rejected");
    return 0;
}

fn test_validate_addr() {
    test_group("validate_addr");
    assert(is_ok(validate_addr("10.0.0.1")) == 1, "10.0.0.1 ok");
    assert(is_ok(validate_addr("192.168.0.0/16")) == 1, "CIDR ok");
    assert(is_ok(validate_addr("172.17.0.2")) == 1, "172 ok");
    assert(is_ok(validate_addr("::1")) == 1, "::1 ok");
    assert(is_ok(validate_addr("fe80::/10")) == 1, "fe80 CIDR ok");
    assert(is_ok(validate_addr("2001:db8::1")) == 1, "2001:db8 ok");
    assert(is_err_result(validate_addr("")) == 1, "empty rejected");
    assert(is_err_result(validate_addr("not_an_addr")) == 1, "alpha rejected");
    assert(is_err_result(validate_addr("10.0.0.1;drop")) == 1, "semicolon rejected");
    assert(is_err_result(validate_addr("10.0.0.1|evil")) == 1, "pipe rejected");
    return 0;
}

fn test_validate_iface() {
    test_group("validate_iface");
    assert(is_ok(validate_iface("eth0")) == 1, "eth0 ok");
    assert(is_ok(validate_iface("br-container")) == 1, "br-container ok");
    assert(is_ok(validate_iface("veth1.2")) == 1, "veth1.2 ok");
    assert(is_ok(validate_iface("lo")) == 1, "lo ok");
    assert(is_err_result(validate_iface("")) == 1, "empty rejected");
    assert(is_err_result(validate_iface("evil;drop")) == 1, "semicolon rejected");

    var buf16[24];
    memset(&buf16, 97, 15);
    store8(&buf16 + 15, 0);
    assert(is_ok(validate_iface(&buf16)) == 1, "15 chars ok");
    memset(&buf16, 97, 16);
    store8(&buf16 + 16, 0);
    assert(is_err_result(validate_iface(&buf16)) == 1, "16 chars rejected");
    return 0;
}

fn test_validate_ct_state() {
    test_group("validate_ct_state");
    assert(is_ok(validate_ct_state("new")) == 1, "new ok");
    assert(is_ok(validate_ct_state("established")) == 1, "established ok");
    assert(is_ok(validate_ct_state("related")) == 1, "related ok");
    assert(is_ok(validate_ct_state("invalid")) == 1, "invalid ok");
    assert(is_ok(validate_ct_state("untracked")) == 1, "untracked ok");
    assert(is_err_result(validate_ct_state("bogus")) == 1, "bogus rejected");
    assert(is_err_result(validate_ct_state("established; drop")) == 1, "injection rejected");
    return 0;
}

fn test_validate_comment() {
    test_group("validate_comment");
    assert(is_ok(validate_comment("SSH access")) == 1, "normal comment ok");
    assert(is_ok(validate_comment("container port 8080->80")) == 1, "arrow comment ok");
    assert(is_err_result(validate_comment("has \"quotes\"")) == 1, "quotes rejected");
    assert(is_err_result(validate_comment("has;semicolon")) == 1, "semicolon rejected");
    assert(is_err_result(validate_comment("has{brace")) == 1, "brace rejected");
    assert(is_err_result(validate_comment("has}brace")) == 1, "close brace rejected");
    assert(is_err_result(validate_comment("has|pipe")) == 1, "pipe rejected");
    assert(is_err_result(validate_comment("has`tick")) == 1, "backtick rejected");
    assert(is_err_result(validate_comment("has$dollar")) == 1, "dollar rejected");

    var buf130[136];
    memset(&buf130, 97, 128);
    store8(&buf130 + 128, 0);
    assert(is_ok(validate_comment(&buf130)) == 1, "128 chars ok");
    memset(&buf130, 97, 129);
    store8(&buf130 + 129, 0);
    assert(is_err_result(validate_comment(&buf130)) == 1, "129 chars rejected");
    return 0;
}

fn test_validate_log_prefix() {
    test_group("validate_log_prefix");
    assert(is_ok(validate_log_prefix("NEIN_DROP: ")) == 1, "prefix ok");
    assert(is_ok(validate_log_prefix("fw-input ")) == 1, "fw-input ok");
    assert(is_err_result(validate_log_prefix("has\"quote")) == 1, "quote rejected");
    assert(is_err_result(validate_log_prefix("has;semi")) == 1, "semicolon rejected");

    var buf66[72];
    memset(&buf66, 97, 64);
    store8(&buf66 + 64, 0);
    assert(is_ok(validate_log_prefix(&buf66)) == 1, "64 chars ok");
    memset(&buf66, 97, 65);
    store8(&buf66 + 65, 0);
    assert(is_err_result(validate_log_prefix(&buf66)) == 1, "65 chars rejected");
    return 0;
}

fn test_validate_nft_element() {
    test_group("validate_nft_element");
    assert(is_ok(validate_nft_element("10.0.0.1")) == 1, "ip ok");
    assert(is_ok(validate_nft_element("80")) == 1, "port ok");
    assert(is_ok(validate_nft_element("192.168.0.0/16")) == 1, "cidr ok");
    assert(is_ok(validate_nft_element("::1")) == 1, "ipv6 ok");
    assert(is_err_result(validate_nft_element("")) == 1, "empty rejected");
    assert(is_err_result(validate_nft_element("evil;inject")) == 1, "semicolon rejected");
    assert(is_err_result(validate_nft_element("has\"quote")) == 1, "quote rejected");
    return 0;
}

fn test_validate_family() {
    test_group("validate_family");
    assert(is_ok(validate_family("inet")) == 1, "inet ok");
    assert(is_ok(validate_family("ip")) == 1, "ip ok");
    assert(is_ok(validate_family("ip6")) == 1, "ip6 ok");
    assert(is_ok(validate_family("arp")) == 1, "arp ok");
    assert(is_ok(validate_family("bridge")) == 1, "bridge ok");
    assert(is_ok(validate_family("netdev")) == 1, "netdev ok");
    assert(is_err_result(validate_family("")) == 1, "empty rejected");
    assert(is_err_result(validate_family("ipv4")) == 1, "ipv4 rejected");
    assert(is_err_result(validate_family("filter")) == 1, "filter rejected");
    assert(is_err_result(validate_family("inet; drop")) == 1, "injection rejected");
    return 0;
}

fn test_dangerous_chars_all() {
    test_group("dangerous_chars_exhaustive");
    assert(is_err_result(validate_comment("t;v")) == 1, "comment ; rejected");
    assert(is_err_result(validate_comment("t{v")) == 1, "comment { rejected");
    assert(is_err_result(validate_comment("t}v")) == 1, "comment } rejected");
    assert(is_err_result(validate_comment("t|v")) == 1, "comment | rejected");
    assert(is_err_result(validate_comment("t`v")) == 1, "comment ` rejected");
    assert(is_err_result(validate_comment("t$v")) == 1, "comment $ rejected");
    assert(is_err_result(validate_log_prefix("t;v")) == 1, "prefix ; rejected");
    assert(is_err_result(validate_log_prefix("t{v")) == 1, "prefix { rejected");
    assert(is_err_result(validate_log_prefix("t}v")) == 1, "prefix } rejected");
    assert(is_err_result(validate_log_prefix("t|v")) == 1, "prefix | rejected");
    assert(is_err_result(validate_log_prefix("t`v")) == 1, "prefix ` rejected");
    assert(is_err_result(validate_log_prefix("t$v")) == 1, "prefix $ rejected");
    assert(is_err_result(validate_nft_element("t;v")) == 1, "elem ; rejected");
    assert(is_err_result(validate_nft_element("t{v")) == 1, "elem { rejected");
    assert(is_err_result(validate_nft_element("t|v")) == 1, "elem | rejected");
    return 0;
}

# ================================================================
# Rule render tests
# ================================================================

fn test_rule_render_basic() {
    test_group("rule_render_basic");

    # allow_tcp(443)
    var s = rule_render(allow_tcp(443));
    assert(streq(str_data(s), "tcp dport 443 accept") == 1, "allow_tcp(443)");

    # allow_udp(53)
    s = rule_render(allow_udp(53));
    assert(streq(str_data(s), "udp dport 53 accept") == 1, "allow_udp(53)");

    # deny_source
    s = rule_render(deny_source("10.0.0.0/8"));
    assert(streq(str_data(s), "ip saddr 10.0.0.0/8 drop") == 1, "deny_source");

    # allow_established
    s = rule_render(allow_established());
    assert(streq(str_data(s), "ct state { established, related } accept") == 1, "established");

    # allow_service
    s = rule_render(allow_service("192.168.1.0/24", PROTO_TCP, 8090));
    assert(streq(str_data(s), "ip saddr 192.168.1.0/24 tcp dport 8090 accept") == 1, "allow_service");

    # with comment
    var r = allow_tcp(22);
    rule_set_comment(r, "SSH access");
    s = rule_render(r);
    assert(streq(str_data(s), "tcp dport 22 accept comment \"SSH access\"") == 1, "with comment");

    return 0;
}

fn test_rule_render_verdicts() {
    test_group("rule_render_verdicts");

    # reject
    var s = rule_render(rule_new(verdict_reject()));
    assert(streq(str_data(s), "reject") == 1, "reject");

    # return
    s = rule_render(rule_new(verdict_return()));
    assert(streq(str_data(s), "return") == 1, "return");

    # counter
    var r = rule_new(verdict_counter());
    rule_add_match(r, match_protocol(PROTO_TCP));
    rule_add_match(r, match_dport(80));
    s = rule_render(r);
    assert(streq(str_data(s), "tcp dport 80 counter") == 1, "counter");

    # jump
    r = rule_new(verdict_jump("container_rules"));
    rule_add_match(r, match_oif("br0"));
    s = rule_render(r);
    assert(streq(str_data(s), "oif \"br0\" jump container_rules") == 1, "jump");

    # goto
    s = rule_render(rule_new(verdict_goto("other_chain")));
    assert(streq(str_data(s), "goto other_chain") == 1, "goto");

    # log with prefix
    r = rule_new(verdict_log("NEIN_DROP: "));
    rule_add_match(r, match_protocol(PROTO_TCP));
    s = rule_render(r);
    assert(streq(str_data(s), "tcp log prefix \"NEIN_DROP: \"") == 1, "log prefix");

    # log without prefix
    s = rule_render(rule_new(verdict_log(0)));
    assert(streq(str_data(s), "log") == 1, "log bare");

    # set mark
    r = rule_new(verdict_set_mark(42));
    rule_add_match(r, match_protocol(PROTO_TCP));
    rule_add_match(r, match_dport(80));
    s = rule_render(r);
    assert(streq(str_data(s), "tcp dport 80 meta mark set 42") == 1, "set mark");

    # set ct mark
    s = rule_render(rule_new(verdict_set_ct_mark(255)));
    assert(streq(str_data(s), "ct mark set 255") == 1, "set ct mark");

    # reject with tcp reset
    r = rule_new(verdict_reject_with(REJECT_TCP_RESET));
    rule_add_match(r, match_protocol(PROTO_TCP));
    rule_add_match(r, match_dport(80));
    s = rule_render(r);
    assert(streq(str_data(s), "tcp dport 80 reject with tcp reset") == 1, "reject tcp reset");

    # reject with icmp
    s = rule_render(rule_new(verdict_reject_with(REJECT_ICMP_HOST_UNREACH)));
    assert(streq(str_data(s), "reject with icmp type host-unreachable") == 1, "reject icmp host");

    # reject with icmpx
    s = rule_render(rule_new(verdict_reject_with(REJECT_ICMPX_ADMIN_PROHIB)));
    assert(streq(str_data(s), "reject with icmpx type admin-prohibited") == 1, "reject icmpx");

    # counter named
    r = rule_new(verdict_counter_named("http_hits"));
    rule_add_match(r, match_protocol(PROTO_TCP));
    rule_add_match(r, match_dport(80));
    s = rule_render(r);
    assert(streq(str_data(s), "tcp dport 80 counter name \"http_hits\"") == 1, "counter named");

    return 0;
}

fn test_rule_render_matches() {
    test_group("rule_render_matches");

    # sport
    var r = rule_new(verdict_accept());
    rule_add_match(r, match_protocol(PROTO_TCP));
    rule_add_match(r, match_sport(1024));
    var s = rule_render(r);
    assert(streq(str_data(s), "tcp sport 1024 accept") == 1, "sport");

    # dport range
    r = rule_new(verdict_accept());
    rule_add_match(r, match_protocol(PROTO_TCP));
    rule_add_match(r, match_dport_range(8000, 9000));
    s = rule_render(r);
    assert(streq(str_data(s), "tcp dport 8000-9000 accept") == 1, "dport range");

    # dest addr
    s = rule_render(rule_add_match(rule_new(verdict_drop()), match_dest_addr("10.0.0.1")));
    assert(streq(str_data(s), "ip daddr 10.0.0.1 drop") == 1, "dest addr");

    # ipv6 source
    s = rule_render(rule_add_match(rule_new(verdict_accept()), match_source_addr6("fe80::/10")));
    assert(streq(str_data(s), "ip6 saddr fe80::/10 accept") == 1, "source addr6");

    # ipv6 dest
    s = rule_render(rule_add_match(rule_new(verdict_drop()), match_dest_addr6("::1")));
    assert(streq(str_data(s), "ip6 daddr ::1 drop") == 1, "dest addr6");

    # deny_source6
    s = rule_render(deny_source6("2001:db8::/32"));
    assert(streq(str_data(s), "ip6 saddr 2001:db8::/32 drop") == 1, "deny_source6");

    # icmp protocol
    s = rule_render(rule_add_match(rule_new(verdict_accept()), match_protocol(PROTO_ICMP)));
    assert(streq(str_data(s), "icmp accept") == 1, "icmp");

    # icmpv6 protocol
    s = rule_render(rule_add_match(rule_new(verdict_accept()), match_protocol(PROTO_ICMPV6)));
    assert(streq(str_data(s), "icmpv6 accept") == 1, "icmpv6");

    # set lookup
    s = rule_render(rule_add_match(rule_new(verdict_drop()), match_set_lookup("ip saddr", "blocklist")));
    assert(streq(str_data(s), "ip saddr @blocklist drop") == 1, "set lookup");

    # ct helper
    s = rule_render(rule_add_match(rule_new(verdict_accept()), match_ct_helper("ftp")));
    assert(streq(str_data(s), "ct helper \"ftp\" accept") == 1, "ct helper");

    # tcp flags
    s = rule_render(rule_add_match(rule_new(verdict_drop()), match_tcp_flags("syn, fin")));
    assert(streq(str_data(s), "tcp flags { syn, fin } drop") == 1, "tcp flags");

    # icmp type
    s = rule_render(rule_add_match(rule_new(verdict_accept()), match_icmp_type("echo-request")));
    assert(streq(str_data(s), "icmp type echo-request accept") == 1, "icmp type");

    # icmpv6 type
    s = rule_render(rule_add_match(rule_new(verdict_accept()), match_icmpv6_type("echo-request")));
    assert(streq(str_data(s), "icmpv6 type echo-request accept") == 1, "icmpv6 type");

    # meta mark
    s = rule_render(rule_add_match(rule_new(verdict_accept()), match_meta_mark(1)));
    assert(streq(str_data(s), "meta mark 1 accept") == 1, "meta mark");

    # limit
    r = rule_new(verdict_accept());
    rule_add_match(r, match_limit(10, RATE_SECOND, 20));
    s = rule_render(r);
    assert(streq(str_data(s), "limit rate 10/second burst 20 packets accept") == 1, "limit");

    # quota over
    s = rule_render(rule_add_match(rule_new(verdict_drop()), match_quota(QUOTA_OVER, 25, QUNIT_MBYTES)));
    assert(streq(str_data(s), "quota over 25 mbytes drop") == 1, "quota over");

    # quota until
    s = rule_render(rule_add_match(rule_new(verdict_accept()), match_quota(QUOTA_UNTIL, 100, QUNIT_GBYTES)));
    assert(streq(str_data(s), "quota until 100 gbytes accept") == 1, "quota until");

    # flow offload
    s = rule_render(rule_add_match(rule_new(verdict_accept()), match_flow_offload("ft")));
    assert(streq(str_data(s), "flow offload @ft accept") == 1, "flow offload");

    # ct timeout set
    s = rule_render(rule_add_match(rule_new(verdict_accept()), match_ct_timeout_set("tcp-long")));
    assert(streq(str_data(s), "ct timeout set \"tcp-long\" accept") == 1, "ct timeout set");

    # icmp type + code
    s = rule_render(rule_add_match(rule_new(verdict_drop()), match_icmp_type_code("echo-request", 0)));
    assert(streq(str_data(s), "icmp type echo-request icmp code 0 drop") == 1, "icmp type+code");

    # icmpv6 type + code
    s = rule_render(rule_add_match(rule_new(verdict_drop()), match_icmpv6_type_code("echo-request", 0)));
    assert(streq(str_data(s), "icmpv6 type echo-request icmpv6 code 0 drop") == 1, "icmpv6 type+code");

    # vlan id
    s = rule_render(rule_add_match(rule_new(verdict_accept()), match_vlan_id(100)));
    assert(streq(str_data(s), "vlan id 100 accept") == 1, "vlan id");

    # dscp
    s = rule_render(rule_add_match(rule_new(verdict_accept()), match_dscp(46)));
    assert(streq(str_data(s), "ip dscp 46 accept") == 1, "dscp");

    # ipv6 ext hdr
    s = rule_render(rule_add_match(rule_new(verdict_drop()), match_ipv6_ext_hdr(EXT_ROUTING)));
    assert(streq(str_data(s), "exthdr rt exists drop") == 1, "ipv6 ext hdr");

    # frag off
    s = rule_render(rule_add_match(rule_new(verdict_drop()), match_frag_off(8192, NFT_CMP_NE, 0)));
    assert(streq(str_data(s), "ip frag-off & 0x2000 != 0x0 drop") == 1, "frag off more-fragments");

    # pkt type broadcast
    s = rule_render(rule_add_match(rule_new(verdict_drop()), match_pkt_type(PKT_BROADCAST)));
    assert(streq(str_data(s), "meta pkttype broadcast drop") == 1, "pkt type broadcast");

    # pkt type multicast
    s = rule_render(rule_add_match(rule_new(verdict_accept()), match_pkt_type(PKT_MULTICAST)));
    assert(streq(str_data(s), "meta pkttype multicast accept") == 1, "pkt type multicast");

    # conn limit
    r = rule_new(verdict_drop());
    rule_add_match(r, match_protocol(PROTO_TCP));
    rule_add_match(r, match_dport(22));
    rule_add_match(r, match_conn_limit(10));
    rule_set_comment(r, "SSH conn limit");
    s = rule_render(r);
    assert(streq(str_data(s), "tcp dport 22 ct count over 10 drop comment \"SSH conn limit\"") == 1, "conn limit");

    # raw
    s = rule_render(rule_add_match(rule_new(verdict_accept()), match_raw("dport { 80, 443, 8080 }")));
    assert(streq(str_data(s), "dport { 80, 443, 8080 } accept") == 1, "raw match");

    return 0;
}

fn test_rule_render_log_advanced() {
    test_group("rule_render_log_advanced");

    # full
    var s = rule_render(rule_new(verdict_log_advanced("NEIN: ", NFT_LOG_WARN, 1, 128)));
    assert(streq(str_data(s), "log prefix \"NEIN: \" level warn group 1 snaplen 128") == 1, "log advanced full");

    # level only
    s = rule_render(rule_new(verdict_log_advanced(0, NFT_LOG_DEBUG, 0, 0)));
    assert(streq(str_data(s), "log level debug") == 1, "log advanced level");

    # group only
    s = rule_render(rule_new(verdict_log_advanced(0, 0, 5, 0)));
    assert(streq(str_data(s), "log group 5") == 1, "log advanced group");

    # bare
    s = rule_render(rule_new(verdict_log_advanced(0, 0, 0, 0)));
    assert(streq(str_data(s), "log") == 1, "log advanced bare");

    return 0;
}

# ================================================================
# Rule validate tests
# ================================================================

fn test_rule_validate() {
    test_group("rule_validate");

    # Good rule
    assert(is_ok(rule_validate(allow_service("10.0.0.0/8", PROTO_TCP, 80))) == 1, "good rule ok");

    # Bad addr
    assert(is_err_result(rule_validate(deny_source("10.0.0.1; flush ruleset"))) == 1, "bad addr rejected");

    # Bad iface
    var r = rule_new(verdict_accept());
    rule_add_match(r, match_iif("eth0; drop"));
    assert(is_err_result(rule_validate(r)) == 1, "bad iface rejected");

    # Bad comment
    r = allow_tcp(22);
    rule_set_comment(r, "has \"quotes\"");
    assert(is_err_result(rule_validate(r)) == 1, "bad comment rejected");

    # Bad jump target
    assert(is_err_result(rule_validate(rule_new(verdict_jump("evil;chain")))) == 1, "bad jump rejected");

    # Bad goto target
    assert(is_err_result(rule_validate(rule_new(verdict_goto("bad;chain")))) == 1, "bad goto rejected");

    # Good goto
    assert(is_ok(rule_validate(rule_new(verdict_goto("valid_chain")))) == 1, "good goto ok");

    # Bad log prefix
    assert(is_err_result(rule_validate(rule_new(verdict_log("bad;prefix")))) == 1, "bad log prefix rejected");

    # Good log prefix
    assert(is_ok(rule_validate(rule_new(verdict_log("GOOD: ")))) == 1, "good log ok");

    # Port range valid
    r = rule_new(verdict_accept());
    rule_add_match(r, match_dport_range(80, 443));
    assert(is_ok(rule_validate(r)) == 1, "port range ok");

    # Port range equal
    r = rule_new(verdict_accept());
    rule_add_match(r, match_dport_range(80, 80));
    assert(is_ok(rule_validate(r)) == 1, "port range equal ok");

    # Port range inverted
    r = rule_new(verdict_accept());
    rule_add_match(r, match_dport_range(443, 80));
    assert(is_err_result(rule_validate(r)) == 1, "port range inverted rejected");

    # Raw match skipped
    r = rule_new(verdict_accept());
    rule_add_match(r, match_raw("anything goes here;{}"));
    assert(is_ok(rule_validate(r)) == 1, "raw match skipped");

    # DSCP valid/invalid
    r = rule_new(verdict_accept());
    rule_add_match(r, match_dscp(63));
    assert(is_ok(rule_validate(r)) == 1, "dscp 63 ok");
    r = rule_new(verdict_accept());
    rule_add_match(r, match_dscp(64));
    assert(is_err_result(rule_validate(r)) == 1, "dscp 64 rejected");

    # VLAN ID valid/invalid
    r = rule_new(verdict_accept());
    rule_add_match(r, match_vlan_id(4094));
    assert(is_ok(rule_validate(r)) == 1, "vlan 4094 ok");
    r = rule_new(verdict_accept());
    rule_add_match(r, match_vlan_id(4095));
    assert(is_err_result(rule_validate(r)) == 1, "vlan 4095 rejected");

    # Bad counter named
    assert(is_err_result(rule_validate(rule_new(verdict_counter_named("bad;counter")))) == 1, "bad counter rejected");
    assert(is_ok(rule_validate(rule_new(verdict_counter_named("my-counter")))) == 1, "good counter ok");

    # Bad log advanced prefix
    assert(is_err_result(rule_validate(rule_new(verdict_log_advanced("bad;prefix", 0, 0, 0)))) == 1, "bad adv prefix rejected");
    assert(is_ok(rule_validate(rule_new(verdict_log_advanced("TEST: ", NFT_LOG_INFO, 0, 0)))) == 1, "good adv prefix ok");

    # Bad set lookup
    r = rule_new(verdict_accept());
    rule_add_match(r, match_set_lookup("ip saddr", "bad;set"));
    assert(is_err_result(rule_validate(r)) == 1, "bad set_lookup rejected");

    # Bad ct helper
    r = rule_new(verdict_accept());
    rule_add_match(r, match_ct_helper("bad;helper"));
    assert(is_err_result(rule_validate(r)) == 1, "bad ct_helper rejected");

    # Bad flow offload
    r = rule_new(verdict_accept());
    rule_add_match(r, match_flow_offload("bad;ft"));
    assert(is_err_result(rule_validate(r)) == 1, "bad flow_offload rejected");

    # Bad ct timeout set
    r = rule_new(verdict_accept());
    rule_add_match(r, match_ct_timeout_set("evil;timeout"));
    assert(is_err_result(rule_validate(r)) == 1, "bad ct_timeout rejected");

    # Bad icmp type
    r = rule_new(verdict_accept());
    rule_add_match(r, match_icmp_type("bad;type"));
    assert(is_err_result(rule_validate(r)) == 1, "bad icmp_type rejected");

    return 0;
}

# ================================================================
# Set tests
# ================================================================

fn test_set_render() {
    test_group("set_render");

    # Basic set with elements
    var s = nft_set_new("blocklist", SET_IPV4_ADDR);
    nft_set_add_element(s, "10.0.0.1");
    nft_set_add_element(s, "10.0.0.2");
    nft_set_add_element(s, "192.168.1.0/24");
    var rendered = nft_set_render(s);
    assert(str_contains_cstr(rendered, "set blocklist") == 1, "set name");
    assert(str_contains_cstr(rendered, "type ipv4_addr") == 1, "set type");
    assert(str_contains_cstr(rendered, "10.0.0.1, 10.0.0.2, 192.168.1.0/24") == 1, "set elements");

    # Set with flags
    s = nft_set_new("ratelimit", SET_IPV4_ADDR);
    nft_set_add_flag(s, SETFLAG_INTERVAL);
    nft_set_add_flag(s, SETFLAG_TIMEOUT);
    rendered = nft_set_render(s);
    assert(str_contains_cstr(rendered, "flags interval, timeout") == 1, "set flags");

    # Empty set
    s = nft_set_new("empty", SET_INET_SERVICE);
    rendered = nft_set_render(s);
    assert(str_contains_cstr(rendered, "set empty") == 1, "empty name");
    assert(str_contains_cstr(rendered, "type inet_service") == 1, "empty type");

    # Ports
    s = nft_set_new("webports", SET_INET_SERVICE);
    nft_set_add_element(s, "80");
    nft_set_add_element(s, "443");
    nft_set_add_element(s, "8080");
    rendered = nft_set_render(s);
    assert(str_contains_cstr(rendered, "80, 443, 8080") == 1, "port elements");

    # IPv6
    s = nft_set_new("v6block", SET_IPV6_ADDR);
    nft_set_add_element(s, "::1");
    nft_set_add_element(s, "fe80::/10");
    rendered = nft_set_render(s);
    assert(str_contains_cstr(rendered, "type ipv6_addr") == 1, "ipv6 type");
    assert(str_contains_cstr(rendered, "::1, fe80::/10") == 1, "ipv6 elements");

    return 0;
}

fn test_set_validate() {
    test_group("set_validate");

    var s = nft_set_new("test", SET_IPV4_ADDR);
    nft_set_add_element(s, "10.0.0.1");
    assert(is_ok(nft_set_validate(s)) == 1, "good set ok");

    s = nft_set_new("bad;name", SET_IPV4_ADDR);
    assert(is_err_result(nft_set_validate(s)) == 1, "bad name rejected");

    s = nft_set_new("test", SET_IPV4_ADDR);
    nft_set_add_element(s, "evil;inject");
    assert(is_err_result(nft_set_validate(s)) == 1, "bad element rejected");

    return 0;
}

fn test_map_render() {
    test_group("map_render");

    # Basic map
    var m = nft_map_new("country_verdict", SET_IPV4_ADDR);
    nft_map_add_entry(m, "10.0.0.0/8", MAPV_ACCEPT, 0);
    nft_map_add_entry(m, "192.168.0.0/16", MAPV_DROP, 0);
    var rendered = nft_map_render(m);
    assert(str_contains_cstr(rendered, "map country_verdict") == 1, "map name");
    assert(str_contains_cstr(rendered, "type ipv4_addr : verdict") == 1, "map type");
    assert(str_contains_cstr(rendered, "10.0.0.0/8 : accept") == 1, "map accept entry");
    assert(str_contains_cstr(rendered, "192.168.0.0/16 : drop") == 1, "map drop entry");

    # Jump map
    m = nft_map_new("dispatch", SET_INET_SERVICE);
    nft_map_add_entry(m, "80", MAPV_JUMP, "web_chain");
    nft_map_add_entry(m, "22", MAPV_JUMP, "ssh_chain");
    rendered = nft_map_render(m);
    assert(str_contains_cstr(rendered, "80 : jump web_chain") == 1, "jump entry 80");
    assert(str_contains_cstr(rendered, "22 : jump ssh_chain") == 1, "jump entry 22");

    # Empty map
    m = nft_map_new("empty", SET_IPV4_ADDR);
    rendered = nft_map_render(m);
    assert(str_contains_cstr(rendered, "map empty") == 1, "empty map");

    return 0;
}

fn test_map_validate() {
    test_group("map_validate");

    var m = nft_map_new("test", SET_IPV4_ADDR);
    nft_map_add_entry(m, "10.0.0.1", MAPV_ACCEPT, 0);
    nft_map_add_entry(m, "10.0.0.2", MAPV_JUMP, "mychain");
    assert(is_ok(nft_map_validate(m)) == 1, "good map ok");

    m = nft_map_new("bad;name", SET_IPV4_ADDR);
    assert(is_err_result(nft_map_validate(m)) == 1, "bad name rejected");

    m = nft_map_new("test", SET_IPV4_ADDR);
    nft_map_add_entry(m, "evil;key", MAPV_ACCEPT, 0);
    assert(is_err_result(nft_map_validate(m)) == 1, "bad key rejected");

    m = nft_map_new("test", SET_IPV4_ADDR);
    nft_map_add_entry(m, "10.0.0.1", MAPV_JUMP, "bad;chain");
    assert(is_err_result(nft_map_validate(m)) == 1, "bad jump target rejected");

    return 0;
}

# ================================================================
# Chain tests
# ================================================================

fn test_chain_render() {
    test_group("chain_render");

    # Base chain
    var c = chain_base("input", CHAIN_FILTER, HOOK_INPUT, 0, POLICY_DROP);
    var rendered = chain_render(c);
    assert(str_contains_cstr(rendered, "chain input") == 1, "base chain name");
    assert(str_contains_cstr(rendered, "type filter hook input priority 0; policy drop;") == 1, "base header");

    # Regular chain
    c = chain_regular("my_chain");
    rendered = chain_render(c);
    assert(str_contains_cstr(rendered, "chain my_chain") == 1, "regular name");

    # Chain with rules
    c = chain_base("input", CHAIN_FILTER, HOOK_INPUT, 0, POLICY_DROP);
    chain_add_rule(c, allow_tcp(22));
    chain_add_rule(c, allow_tcp(443));
    rendered = chain_render(c);
    assert(str_contains_cstr(rendered, "tcp dport 22 accept") == 1, "rule 1");
    assert(str_contains_cstr(rendered, "tcp dport 443 accept") == 1, "rule 2");

    # NAT chain type
    c = chain_base("prerouting", CHAIN_NAT, HOOK_PREROUTING, 0 - 100, POLICY_ACCEPT);
    rendered = chain_render(c);
    assert(str_contains_cstr(rendered, "type nat hook prerouting priority -100; policy accept;") == 1, "nat chain");

    return 0;
}

# ================================================================
# Table tests
# ================================================================

fn test_table_render() {
    test_group("table_render");

    # Empty table
    var t = table_new("filter", FAMILY_INET);
    var rendered = table_render(t);
    assert(str_contains_cstr(rendered, "table inet filter") == 1, "table header");

    # Table with define
    t = table_new("filter", FAMILY_INET);
    table_add_define(t, define_new("LAN", "192.168.0.0/16"));
    rendered = table_render(t);
    assert(str_contains_cstr(rendered, "define $LAN = 192.168.0.0/16;") == 1, "define in table");

    # Table with set
    t = table_new("filter", FAMILY_INET);
    var s = nft_set_new("blocklist", SET_IPV4_ADDR);
    nft_set_add_element(s, "10.0.0.1");
    nft_set_add_element(s, "10.0.0.2");
    table_add_set(t, s);
    rendered = table_render(t);
    assert(str_contains_cstr(rendered, "set blocklist") == 1, "set in table");
    assert(str_contains_cstr(rendered, "10.0.0.1, 10.0.0.2") == 1, "set elements in table");

    # Table with map
    t = table_new("filter", FAMILY_INET);
    var m = nft_map_new("portmap", SET_INET_SERVICE);
    nft_map_add_entry(m, "80", MAPV_JUMP, "web");
    table_add_map(t, m);
    rendered = table_render(t);
    assert(str_contains_cstr(rendered, "map portmap") == 1, "map in table");
    assert(str_contains_cstr(rendered, "80 : jump web") == 1, "map entry in table");

    # Table with chain
    t = table_new("filter", FAMILY_INET);
    var c = chain_base("input", CHAIN_FILTER, HOOK_INPUT, 0, POLICY_DROP);
    chain_add_rule(c, allow_established());
    chain_add_rule(c, allow_tcp(22));
    table_add_chain(t, c);
    rendered = table_render(t);
    assert(str_contains_cstr(rendered, "chain input") == 1, "chain in table");
    assert(str_contains_cstr(rendered, "ct state { established, related } accept") == 1, "rule in chain");

    return 0;
}

fn test_table_render_order() {
    test_group("table_render_order");

    var t = table_new("filter", FAMILY_INET);
    table_add_define(t, define_new("WAN", "eth0"));

    var devs = vec_new();
    vec_push(devs, "eth0");
    table_add_flowtable(t, flowtable_new("ft", 0, devs));
    table_add_ct_timeout(t, ct_timeout_new("tcp-timeout", PROTO_TCP));
    table_add_set(t, nft_set_new("myset", SET_IPV4_ADDR));
    table_add_map(t, nft_map_new("mymap", SET_INET_SERVICE));
    table_add_chain(t, chain_regular("mychain"));

    var rendered = table_render(t);
    var rd = str_data(rendered);

    # Check ordering: define < flowtable < ct timeout < set < map < chain
    var def_pos = str_index_of_cstr(rendered, "define $WAN");
    var ft_pos = str_index_of_cstr(rendered, "flowtable ft");
    var ct_pos = str_index_of_cstr(rendered, "ct timeout tcp-timeout");
    var set_pos = str_index_of_cstr(rendered, "set myset");
    var map_pos = str_index_of_cstr(rendered, "map mymap");
    var chain_pos = str_index_of_cstr(rendered, "chain mychain");

    assert(def_pos < ft_pos, "define before flowtable");
    assert(ft_pos < ct_pos, "flowtable before ct_timeout");
    assert(ct_pos < set_pos, "ct_timeout before set");
    assert(set_pos < map_pos, "set before map");
    assert(map_pos < chain_pos, "map before chain");

    return 0;
}

fn test_define_validate() {
    test_group("define_validate");
    assert(is_ok(define_validate(define_new("MY_VAR", "10.0.0.1"))) == 1, "good define ok");
    assert(is_err_result(define_validate(define_new("bad;name", "value"))) == 1, "bad name rejected");
    assert(is_err_result(define_validate(define_new("ok", "evil;inject"))) == 1, "bad value rejected");
    return 0;
}

fn test_flowtable() {
    test_group("flowtable");

    # Render
    var devs = vec_new();
    vec_push(devs, "eth0");
    vec_push(devs, "eth1");
    var ft = flowtable_new("ft", 0, devs);
    var rendered = flowtable_render(ft);
    assert(str_contains_cstr(rendered, "flowtable ft {") == 1, "ft name");
    assert(str_contains_cstr(rendered, "hook ingress priority 0;") == 1, "ft hook");
    assert(str_contains_cstr(rendered, "devices = { eth0, eth1 }") == 1, "ft devices");

    # Validate good
    devs = vec_new();
    vec_push(devs, "eth0");
    ft = flowtable_new("ft", 0, devs);
    assert(is_ok(flowtable_validate(ft)) == 1, "good ft ok");

    # Validate empty devices
    ft = flowtable_new("ft", 0, vec_new());
    assert(is_err_result(flowtable_validate(ft)) == 1, "empty devices rejected");

    # Validate bad name
    devs = vec_new();
    vec_push(devs, "eth0");
    ft = flowtable_new("bad;ft", 0, devs);
    assert(is_err_result(flowtable_validate(ft)) == 1, "bad ft name rejected");

    # Validate bad device
    devs = vec_new();
    vec_push(devs, "evil;dev");
    ft = flowtable_new("ft", 0, devs);
    assert(is_err_result(flowtable_validate(ft)) == 1, "bad device rejected");

    return 0;
}

fn test_ct_timeout() {
    test_group("ct_timeout");

    # Render with l3proto and policy
    var ct = ct_timeout_new("tcp-long", PROTO_TCP);
    ct_timeout_set_l3proto(ct, FAMILY_IP);
    ct_timeout_add_timeout(ct, "established", 7200);
    ct_timeout_add_timeout(ct, "close_wait", 60);
    var rendered = ct_timeout_render(ct);
    assert(str_contains_cstr(rendered, "ct timeout tcp-long {") == 1, "ct name");
    assert(str_contains_cstr(rendered, "protocol tcp;") == 1, "ct proto");
    assert(str_contains_cstr(rendered, "l3proto ip;") == 1, "ct l3proto");
    assert(str_contains_cstr(rendered, "established: 7200, close_wait: 60") == 1, "ct policy");

    # Render without l3proto
    ct = ct_timeout_new("udp-short", PROTO_UDP);
    ct_timeout_add_timeout(ct, "unreplied", 30);
    rendered = ct_timeout_render(ct);
    assert(str_contains_cstr(rendered, "protocol udp;") == 1, "udp proto");

    # Validate good
    ct = ct_timeout_new("my-timeout", PROTO_TCP);
    ct_timeout_add_timeout(ct, "established", 3600);
    assert(is_ok(ct_timeout_validate(ct)) == 1, "good ct ok");

    # Validate bad protocol
    ct = ct_timeout_new("t", PROTO_ICMP);
    assert(is_err_result(ct_timeout_validate(ct)) == 1, "bad proto rejected");

    # Validate bad l3proto
    ct = ct_timeout_new("t", PROTO_TCP);
    ct_timeout_set_l3proto(ct, FAMILY_BRIDGE);
    assert(is_err_result(ct_timeout_validate(ct)) == 1, "bad l3proto rejected");

    # Validate bad name
    ct = ct_timeout_new("bad;name", PROTO_TCP);
    assert(is_err_result(ct_timeout_validate(ct)) == 1, "bad ct name rejected");

    # Validate bad state
    ct = ct_timeout_new("ok", PROTO_TCP);
    ct_timeout_add_timeout(ct, "evil;state", 100);
    assert(is_err_result(ct_timeout_validate(ct)) == 1, "bad state rejected");

    return 0;
}

# ================================================================
# NAT tests
# ================================================================

fn test_nat_render() {
    test_group("nat_render");

    # DNAT IPv4
    var n = port_forward(8080, "172.17.0.2", 80);
    var rd = str_data(nat_render(n));
    assert(streq(rd, "tcp dport 8080 dnat to 172.17.0.2:80 comment \"container port fwd\"") == 1, "port_forward");

    # DNAT IPv6 brackets
    n = nat_dnat(PROTO_TCP, 443, "2001:db8::1", 8443, 0);
    rd = str_data(nat_render(n));
    assert(streq(rd, "tcp dport 443 dnat to [2001:db8::1]:8443") == 1, "dnat ipv6 brackets");

    # DNAT IPv4 no brackets
    n = nat_dnat(PROTO_TCP, 80, "10.0.0.1", 8080, 0);
    rd = str_data(nat_render(n));
    assert(streq(rd, "tcp dport 80 dnat to 10.0.0.1:8080") == 1, "dnat ipv4 no brackets");

    # DNAT with comment
    n = nat_dnat(PROTO_TCP, 443, "10.0.0.1", 8443, "TLS forward");
    var rendered = nat_render(n);
    assert(str_contains_cstr(rendered, "dnat to 10.0.0.1:8443") == 1, "dnat target");
    assert(str_contains_cstr(rendered, "comment \"TLS forward\"") == 1, "dnat comment");

    # SNAT plain
    n = nat_snat("10.0.0.0/8", "1.2.3.4", 0);
    rd = str_data(nat_render(n));
    assert(streq(rd, "ip saddr 10.0.0.0/8 snat to 1.2.3.4") == 1, "snat");

    # SNAT with comment
    n = nat_snat("10.0.0.0/8", "1.2.3.4", "outbound SNAT");
    rendered = nat_render(n);
    assert(str_contains_cstr(rendered, "snat to 1.2.3.4") == 1, "snat target");
    assert(str_contains_cstr(rendered, "comment \"outbound SNAT\"") == 1, "snat comment");

    # MASQUERADE no oif
    n = nat_masquerade("10.0.0.0/8", 0, 0);
    rd = str_data(nat_render(n));
    assert(streq(rd, "ip saddr 10.0.0.0/8 masquerade") == 1, "masquerade no oif");

    # MASQUERADE with oif + comment
    n = container_masquerade("172.17.0.0/16", "eth0");
    rd = str_data(nat_render(n));
    assert(streq(rd, "ip saddr 172.17.0.0/16 oif \"eth0\" masquerade comment \"container outbound NAT\"") == 1, "container_masquerade");

    # REDIRECT plain
    n = nat_redirect(PROTO_TCP, 80, 8080, 0);
    rd = str_data(nat_render(n));
    assert(streq(rd, "tcp dport 80 redirect to :8080") == 1, "redirect");

    # REDIRECT with comment
    n = nat_redirect(PROTO_TCP, 80, 8080, "local redirect");
    rendered = nat_render(n);
    assert(str_contains_cstr(rendered, "redirect to :8080") == 1, "redirect target");
    assert(str_contains_cstr(rendered, "comment \"local redirect\"") == 1, "redirect comment");

    return 0;
}

fn test_nat_validate() {
    test_group("nat_validate");

    # Good DNAT
    assert(is_ok(nat_validate(port_forward(8080, "172.17.0.2", 80))) == 1, "good DNAT ok");

    # Bad SNAT addr
    var n = nat_snat("10.0.0.0/8; drop", "1.2.3.4", 0);
    assert(is_err_result(nat_validate(n)) == 1, "bad SNAT source rejected");

    n = nat_snat("10.0.0.0/8", "bad;addr", 0);
    assert(is_err_result(nat_validate(n)) == 1, "bad SNAT target rejected");

    # Bad MASQUERADE iface
    n = nat_masquerade("10.0.0.0/8", "eth0; drop", 0);
    assert(is_err_result(nat_validate(n)) == 1, "bad masquerade iface rejected");

    # Bad DNAT comment
    n = nat_dnat(PROTO_TCP, 80, "10.0.0.1", 8080, "bad;comment");
    assert(is_err_result(nat_validate(n)) == 1, "bad DNAT comment rejected");

    # Bad REDIRECT comment
    n = nat_redirect(PROTO_TCP, 80, 8080, "bad;comment");
    assert(is_err_result(nat_validate(n)) == 1, "bad redirect comment rejected");

    # Bad MASQUERADE comment
    n = nat_masquerade("10.0.0.0/8", 0, "bad;comment");
    assert(is_err_result(nat_validate(n)) == 1, "bad masquerade comment rejected");

    # Good SNAT/redirect/masquerade with valid comments
    assert(is_ok(nat_validate(nat_snat("10.0.0.0/8", "1.2.3.4", "valid"))) == 1, "good SNAT ok");
    assert(is_ok(nat_validate(nat_redirect(PROTO_TCP, 80, 8080, "valid"))) == 1, "good redirect ok");

    return 0;
}

fn test_nat_dnat_range() {
    test_group("nat_dnat_range");

    # Render IPv4
    var n = port_range_forward(80, 89, "172.17.0.2", 8080);
    var rendered = nat_render(n);
    assert(str_contains_cstr(rendered, "tcp dport 80-89 dnat to 172.17.0.2:8080-8089") == 1, "range forward");

    # Render IPv6
    n = nat_dnat_range(PROTO_TCP, 80, 89, "2001:db8::1", 8080, 8089, 0);
    var rd = str_data(nat_render(n));
    assert(streq(rd, "tcp dport 80-89 dnat to [2001:db8::1]:8080-8089") == 1, "range ipv6 brackets");

    # With comment
    n = nat_dnat_range(PROTO_TCP, 80, 89, "10.0.0.1", 8080, 8089, "web range");
    rendered = nat_render(n);
    assert(str_contains_cstr(rendered, "comment \"web range\"") == 1, "range comment");

    # Validate good
    assert(is_ok(nat_validate(port_range_forward(80, 89, "172.17.0.2", 8080))) == 1, "good range ok");

    # Validate bad addr
    n = nat_dnat_range(PROTO_TCP, 80, 89, "evil;addr", 8080, 8089, 0);
    assert(is_err_result(nat_validate(n)) == 1, "bad addr rejected");

    # Inverted dest
    n = nat_dnat_range(PROTO_TCP, 89, 80, "10.0.0.1", 8080, 8089, 0);
    assert(is_err_result(nat_validate(n)) == 1, "inverted dest rejected");

    # Size mismatch
    n = nat_dnat_range(PROTO_TCP, 80, 89, "10.0.0.1", 8080, 8085, 0);
    assert(is_err_result(nat_validate(n)) == 1, "size mismatch rejected");

    # Bad comment
    n = nat_dnat_range(PROTO_TCP, 80, 89, "10.0.0.1", 8080, 8089, "bad;comment");
    assert(is_err_result(nat_validate(n)) == 1, "bad range comment rejected");

    # Single port (start == end)
    n = nat_dnat_range(PROTO_TCP, 80, 80, "10.0.0.1", 8080, 8080, 0);
    assert(is_ok(nat_validate(n)) == 1, "single port range ok");

    return 0;
}

# ================================================================
# Firewall tests
# ================================================================

fn test_firewall() {
    test_group("firewall");

    # Empty firewall
    var fw = firewall_new();
    var rendered = firewall_render(fw);
    assert(str_len(rendered) == 0, "empty render");

    # Add table
    firewall_add_table(fw, table_new("test", FAMILY_INET));
    assert(vec_len(firewall_tables(fw)) == 1, "one table");

    # Multiple tables
    fw = firewall_new();
    firewall_add_table(fw, table_new("t1", FAMILY_INET));
    firewall_add_table(fw, table_new("t2", FAMILY_IP));
    rendered = firewall_render(fw);
    assert(str_contains_cstr(rendered, "table inet t1") == 1, "table t1");
    assert(str_contains_cstr(rendered, "table ip t2") == 1, "table t2");
    assert(vec_len(firewall_tables(fw)) == 2, "two tables");

    # Dry run flag
    fw = firewall_new();
    firewall_set_dry_run(fw, 1);
    assert(firewall_dry_run(fw) == 1, "dry run set");

    return 0;
}

fn test_firewall_validate() {
    test_group("firewall_validate");

    # Empty is valid
    assert(is_ok(firewall_validate(firewall_new())) == 1, "empty valid");

    # Bad table name rejected
    var fw = firewall_new();
    firewall_add_table(fw, table_new("evil;drop", FAMILY_INET));
    assert(is_err_result(firewall_validate(fw)) == 1, "bad table name rejected");

    # Bad chain name rejected
    fw = firewall_new();
    var t = table_new("good", FAMILY_INET);
    table_add_chain(t, chain_regular("bad;chain"));
    firewall_add_table(fw, t);
    assert(is_err_result(firewall_validate(fw)) == 1, "bad chain name rejected");

    # Good firewall passes
    fw = firewall_new();
    t = table_new("filter", FAMILY_INET);
    var c = chain_base("input", CHAIN_FILTER, HOOK_INPUT, 0, POLICY_DROP);
    chain_add_rule(c, allow_tcp(22));
    table_add_chain(t, c);
    firewall_add_table(fw, t);
    assert(is_ok(firewall_validate(fw)) == 1, "good firewall ok");

    # Bad rule in chain rejected
    fw = firewall_new();
    t = table_new("filter", FAMILY_INET);
    c = chain_regular("input");
    var bad = rule_new(verdict_accept());
    rule_add_match(bad, match_source_addr("evil;addr"));
    chain_add_rule(c, bad);
    table_add_chain(t, c);
    firewall_add_table(fw, t);
    assert(is_err_result(firewall_validate(fw)) == 1, "bad rule in chain rejected");

    return 0;
}

# ================================================================
# Builder tests
# ================================================================

fn test_builder() {
    test_group("builder");

    # basic_host_firewall
    var fw = basic_host_firewall();
    var rendered = firewall_render(fw);
    assert(str_contains_cstr(rendered, "table inet filter") == 1, "host fw table");
    assert(str_contains_cstr(rendered, "policy drop") == 1, "host fw policy");
    assert(str_contains_cstr(rendered, "ct state { established, related } accept") == 1, "host fw established");
    assert(str_contains_cstr(rendered, "dport 22 accept") == 1, "host fw SSH");

    # container_bridge
    fw = container_bridge("br0", "172.17.0.0/16", "eth0");
    rendered = firewall_render(fw);
    assert(str_contains_cstr(rendered, "table inet filter") == 1, "bridge filter");
    assert(str_contains_cstr(rendered, "table ip nat") == 1, "bridge nat");
    assert(str_contains_cstr(rendered, "container to internet") == 1, "bridge internet");
    assert(str_contains_cstr(rendered, "masquerade") == 1, "bridge masquerade");

    # service_policy
    var ports = vec_new();
    vec_push(ports, _port_pair_new(PROTO_TCP, 8090));
    fw = service_policy("10.0.0.1", ports);
    rendered = firewall_render(fw);
    assert(str_contains_cstr(rendered, "ip saddr 10.0.0.1") == 1, "service policy source");
    assert(str_contains_cstr(rendered, "dport 8090") == 1, "service policy port");

    # All builder firewalls validate
    assert(is_ok(firewall_validate(basic_host_firewall())) == 1, "host fw validates");
    assert(is_ok(firewall_validate(container_bridge("br0", "172.17.0.0/16", "eth0"))) == 1, "bridge validates");

    return 0;
}

