# nein benchmarks — error + validate + rule modules

include "src/lib/error.cyr"
include "src/lib/validate.cyr"
include "src/lib/rule.cyr"

# --- validate ---

fn bench_validate_identifier_short() { validate_identifier("eth0"); return 0; }
fn bench_validate_identifier_long() { validate_identifier("my_really_long_table_name_for_container_network"); return 0; }
fn bench_validate_addr_ipv4() { validate_addr("192.168.1.100"); return 0; }
fn bench_validate_addr_cidr() { validate_addr("10.0.0.0/8"); return 0; }
fn bench_validate_addr_ipv6() { validate_addr("fe80::1"); return 0; }
fn bench_validate_iface() { validate_iface("br-container"); return 0; }
fn bench_validate_comment() { validate_comment("container port mapping 8080 to internal 80"); return 0; }
fn bench_validate_ct_state() { validate_ct_state("established"); return 0; }
fn bench_validate_family() { validate_family("inet"); return 0; }

# --- rule render ---

fn bench_rule_render_simple() {
    var r = allow_tcp(443);
    rule_render(r);
    return 0;
}

fn bench_rule_render_service() {
    var r = allow_service("192.168.1.0/24", PROTO_TCP, 8090);
    rule_set_comment(r, "bench service rule");
    rule_render(r);
    return 0;
}

fn bench_rule_render_complex() {
    var r = rule_new(verdict_accept());
    rule_add_match(r, match_source_addr("10.0.0.0/8"));
    rule_add_match(r, match_protocol(PROTO_TCP));
    rule_add_match(r, match_dport(443));
    rule_add_match(r, match_iif("eth0"));
    rule_add_match(r, match_ct_state("established, related"));
    rule_add_match(r, match_limit(100, RATE_SECOND, 200));
    rule_set_comment(r, "complex rule bench");
    rule_render(r);
    return 0;
}

# --- rule validate ---

fn bench_rule_validate_simple() {
    var r = allow_tcp(443);
    rule_validate(r);
    return 0;
}

fn bench_rule_validate_complex() {
    var r = rule_new(verdict_accept());
    rule_add_match(r, match_source_addr("10.0.0.0/8"));
    rule_add_match(r, match_protocol(PROTO_TCP));
    rule_add_match(r, match_dport(443));
    rule_add_match(r, match_iif("eth0"));
    rule_set_comment(r, "complex rule bench");
    rule_validate(r);
    return 0;
}

# --- nein_err / nein_ok ---

fn bench_nein_err() { nein_err(ERR_INVALID_RULE); return 0; }
fn bench_nein_ok() { nein_ok(); return 0; }

fn main() {
    alloc_init();
    var all = vec_new();
    var b = 0;

    b = bench_new("validate_identifier/short"); bench_run(b, &bench_validate_identifier_short, 100000); vec_push(all, b);
    b = bench_new("validate_identifier/long"); bench_run(b, &bench_validate_identifier_long, 100000); vec_push(all, b);
    b = bench_new("validate_addr/ipv4"); bench_run(b, &bench_validate_addr_ipv4, 100000); vec_push(all, b);
    b = bench_new("validate_addr/cidr"); bench_run(b, &bench_validate_addr_cidr, 100000); vec_push(all, b);
    b = bench_new("validate_addr/ipv6"); bench_run(b, &bench_validate_addr_ipv6, 100000); vec_push(all, b);
    b = bench_new("validate_iface"); bench_run(b, &bench_validate_iface, 100000); vec_push(all, b);
    b = bench_new("validate_comment"); bench_run(b, &bench_validate_comment, 100000); vec_push(all, b);
    b = bench_new("validate_ct_state"); bench_run(b, &bench_validate_ct_state, 100000); vec_push(all, b);
    b = bench_new("validate_family"); bench_run(b, &bench_validate_family, 100000); vec_push(all, b);

    b = bench_new("rule_render/simple"); bench_run(b, &bench_rule_render_simple, 100000); vec_push(all, b);
    b = bench_new("rule_render/service"); bench_run(b, &bench_rule_render_service, 100000); vec_push(all, b);
    b = bench_new("rule_render/complex"); bench_run(b, &bench_rule_render_complex, 100000); vec_push(all, b);

    b = bench_new("rule_validate/simple"); bench_run(b, &bench_rule_validate_simple, 100000); vec_push(all, b);
    b = bench_new("rule_validate/complex"); bench_run(b, &bench_rule_validate_complex, 100000); vec_push(all, b);

    b = bench_new("nein_err"); bench_run(b, &bench_nein_err, 1000000); vec_push(all, b);
    b = bench_new("nein_ok"); bench_run(b, &bench_nein_ok, 1000000); vec_push(all, b);

    bench_report_all(all);
    return 0;
}

var r = main();
syscall(60, r);
