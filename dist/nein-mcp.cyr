# --- error.cyr ---

# nein error types
#
# NeinError as integer enum constants.
# Uses stdlib tagged Result: Ok(value) / Err(code) from tagged.cyr.

enum NeinError {
    ERR_NFT_FAILED = 1;
    ERR_INVALID_RULE = 2;
    ERR_TABLE_NOT_FOUND = 3;
    ERR_CHAIN_NOT_FOUND = 4;
    # Prefixed `NEIN_ERR_` to avoid symbol collisions with sibling AGNOS
    # enums included in the same single-pass build: originally agnosys-core's
    # SysError (bare `ERR_PERMISSION_DENIED` / `ERR_IO`, dropped at 1.5.4),
    # and — from 1.6.0 — bote's `BoteErrTag`, which defines a bare
    # `ERR_PARSE` (=4) and `ERR_IO` (=11). The prefix keeps nein's values
    # fixed (last-definition-wins would otherwise clobber them), so the
    # consumer-facing nein_err_code() contract holds.
    NEIN_ERR_PERMISSION_DENIED = 5;
    NEIN_ERR_PARSE = 6;
    NEIN_ERR_IO = 7;
    # Signed-ruleset errors (1.6.1). Additive — values 1..7 unchanged, so
    # the nein_err_code() contract holds.
    NEIN_ERR_BAD_SIGNATURE = 8;       # ed25519_verify returned 0 over the body
    NEIN_ERR_SIG_MALFORMED = 9;       # envelope structure / charset invalid
    NEIN_ERR_SIG_VERSION = 10;        # nein-sig: value != v1
    NEIN_ERR_SIG_UNSUPPORTED_ALG = 11; # nein-sig-alg: value != ed25519
    NEIN_ERR_SIG_KEY_MISMATCH = 12;   # header pubkey != caller-supplied pubkey
    NEIN_ERR_SIG_KEY = 13;            # null / short key material passed to sign
}

# --- Result helpers ---

# Return Ok(0)
fn nein_ok(): i64 {
    return Ok(0);
}

# Return Err(code)
fn nein_err(code: i64): i64 {
    return Err(code);
}

# Extract the error code from an Err result
fn nein_err_code(r: i64): i64 {
    return payload(r);
}

# --- validate.cyr ---

# nein input validation
#
# All strings interpolated into nftables syntax pass through these
# validators to prevent injection of arbitrary nft commands.
#
# Returns: packed Result — Ok(0) on valid, Err(ERR_INVALID_RULE) on reject.

# Dangerous characters that could inject nftables commands or break syntax.
# ; { } | \n \r \0 ` $
#
# Checked by scanning each byte of the input string.

fn _is_dangerous_char(c: i64): i64 {
    if (c == 59) { return 1; }    # ;
    if (c == 123) { return 1; }   # {
    if (c == 125) { return 1; }   # }
    if (c == 124) { return 1; }   # |
    if (c == 10) { return 1; }    # \n
    if (c == 13) { return 1; }    # \r
    if (c == 0) { return 1; }     # \0 (mid-string)
    if (c == 96) { return 1; }    # `
    if (c == 36) { return 1; }    # $
    return 0;
}

fn _has_dangerous_char(s: cstring): i64 {
    var len = strlen(s);
    var i = 0;
    while (i < len) {
        if (_is_dangerous_char(load8(s + i)) == 1) { return 1; }
        i = i + 1;
    }
    return 0;
}

fn _has_quote(s: cstring): i64 {
    var len = strlen(s);
    var i = 0;
    while (i < len) {
        if (load8(s + i) == 34) { return 1; }   # "
        i = i + 1;
    }
    return 0;
}

# Check if a character is alphanumeric or _ or -
fn _is_ident_char(c: i64): i64 {
    # a-z
    if (c >= 97 && c <= 122) { return 1; }
    # A-Z
    if (c >= 65 && c <= 90) { return 1; }
    # 0-9
    if (c >= 48 && c <= 57) { return 1; }
    # _ -
    if (c == 95) { return 1; }
    if (c == 45) { return 1; }
    return 0;
}

# Check if a character is valid for interface names (alnum, -, _, .)
fn _is_iface_char(c: i64): i64 {
    if (_is_ident_char(c) == 1) { return 1; }
    if (c == 46) { return 1; }   # .
    return 0;
}

# Check if a character is valid in IP/CIDR notation (hex digits, . : /)
fn _is_addr_char(c: i64): i64 {
    # 0-9
    if (c >= 48 && c <= 57) { return 1; }
    # a-f
    if (c >= 97 && c <= 102) { return 1; }
    # A-F
    if (c >= 65 && c <= 70) { return 1; }
    # . : /
    if (c == 46) { return 1; }
    if (c == 58) { return 1; }
    if (c == 47) { return 1; }
    return 0;
}

# --- Public validators ---

# Validate an nftables identifier (table name, chain name).
# Must be non-empty, alphanumeric plus _ and -, at most 64 chars.
fn validate_identifier(s: cstring): i64 {
    var len = strlen(s);
    if (len == 0) { return nein_err(ERR_INVALID_RULE); }
    if (len > 64) { return nein_err(ERR_INVALID_RULE); }

    var i = 0;
    while (i < len) {
        if (_is_ident_char(load8(s + i)) == 0) {
            return nein_err(ERR_INVALID_RULE);
        }
        i = i + 1;
    }
    return nein_ok();
}

# Validate an IP address or CIDR string.
# Allows only characters valid in IP/CIDR notation (hex digits, . : /).
# Rejects dangerous injection characters and non-address strings.
fn validate_addr(s: cstring): i64 {
    var len = strlen(s);
    if (len == 0) { return nein_err(ERR_INVALID_RULE); }

    # Fast reject: only allow valid addr chars
    var i = 0;
    while (i < len) {
        if (_is_addr_char(load8(s + i)) == 0) {
            return nein_err(ERR_INVALID_RULE);
        }
        i = i + 1;
    }

    # Must contain at least one digit to be a plausible address
    var has_digit = 0;
    i = 0;
    while (i < len) {
        var c = load8(s + i);
        if (c >= 48 && c <= 57) { has_digit = 1; }
        i = i + 1;
    }
    if (has_digit == 0) { return nein_err(ERR_INVALID_RULE); }

    # Must contain . or : to be IPv4 or IPv6
    var has_dot = 0;
    var has_colon = 0;
    i = 0;
    while (i < len) {
        var c = load8(s + i);
        if (c == 46) { has_dot = 1; }
        if (c == 58) { has_colon = 1; }
        i = i + 1;
    }
    if (has_dot == 0 && has_colon == 0) { return nein_err(ERR_INVALID_RULE); }

    return nein_ok();
}

# Validate an nftables address family.
# Must be one of: inet, ip, ip6, arp, bridge, netdev.
fn validate_family(s: cstring): i64 {
    if (streq(s, "inet") == 1) { return nein_ok(); }
    if (streq(s, "ip") == 1) { return nein_ok(); }
    if (streq(s, "ip6") == 1) { return nein_ok(); }
    if (streq(s, "arp") == 1) { return nein_ok(); }
    if (streq(s, "bridge") == 1) { return nein_ok(); }
    if (streq(s, "netdev") == 1) { return nein_ok(); }
    return nein_err(ERR_INVALID_RULE);
}

# Validate a network interface name.
# Up to 15 chars, alphanumeric plus - _ .
fn validate_iface(s: cstring): i64 {
    var len = strlen(s);
    if (len == 0) { return nein_err(ERR_INVALID_RULE); }
    if (len > 15) { return nein_err(ERR_INVALID_RULE); }

    var i = 0;
    while (i < len) {
        if (_is_iface_char(load8(s + i)) == 0) {
            return nein_err(ERR_INVALID_RULE);
        }
        i = i + 1;
    }
    return nein_ok();
}

# Validate a connection tracking state.
# Must be: new, established, related, invalid, untracked.
fn validate_ct_state(s: cstring): i64 {
    if (streq(s, "new") == 1) { return nein_ok(); }
    if (streq(s, "established") == 1) { return nein_ok(); }
    if (streq(s, "related") == 1) { return nein_ok(); }
    if (streq(s, "invalid") == 1) { return nein_ok(); }
    if (streq(s, "untracked") == 1) { return nein_ok(); }
    return nein_err(ERR_INVALID_RULE);
}

# Validate a comment string.
# Rejects double quotes and dangerous chars. Max 128 chars.
fn validate_comment(s: cstring): i64 {
    var len = strlen(s);
    if (len > 128) { return nein_err(ERR_INVALID_RULE); }
    if (_has_quote(s) == 1) { return nein_err(ERR_INVALID_RULE); }
    if (_has_dangerous_char(s) == 1) { return nein_err(ERR_INVALID_RULE); }
    return nein_ok();
}

# Validate a log prefix string.
# Same constraints as comments but max 64 chars (nftables limit).
fn validate_log_prefix(s: cstring): i64 {
    var len = strlen(s);
    if (len > 64) { return nein_err(ERR_INVALID_RULE); }
    if (_has_quote(s) == 1) { return nein_err(ERR_INVALID_RULE); }
    if (_has_dangerous_char(s) == 1) { return nein_err(ERR_INVALID_RULE); }
    return nein_ok();
}

# Validate a set/map element string.
# Non-empty, no dangerous chars, no quotes.
fn validate_nft_element(s: cstring): i64 {
    var len = strlen(s);
    if (len == 0) { return nein_err(ERR_INVALID_RULE); }
    if (_has_quote(s) == 1) { return nein_err(ERR_INVALID_RULE); }
    if (_has_dangerous_char(s) == 1) { return nein_err(ERR_INVALID_RULE); }
    return nein_ok();
}

